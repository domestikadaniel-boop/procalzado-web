<script is:inline>
// ═══ CARRITO ═══
const WA_PHONE = '573213154654';
const cartKey = 'procalzado_cart';
let cart = JSON.parse(localStorage.getItem(cartKey) || '[]');

function saveCart() { localStorage.setItem(cartKey, JSON.stringify(cart)); }

function updateCartBadge() {
  const total = cart.reduce((s, i) => s + i.qty, 0);
  const badge = document.getElementById('cartBadge');
  if (!badge) return;
  badge.textContent = total;
  badge.classList.toggle('show', total > 0);
}

function renderCart() {
  const items = document.getElementById('cartItems');
  const empty = document.getElementById('cartEmpty');
  const footer = document.getElementById('cartFooter');
  const totalWrap = document.getElementById('cartTotalWrap');
  if (!items) return;

  if (cart.length === 0) {
    items.innerHTML = '';
    empty.style.display = 'block';
    footer.style.display = 'none';
    return;
  }
  empty.style.display = 'none';
  footer.style.display = 'block';

  items.innerHTML = cart.map((it, idx) => `
    <div class="cart-item">
      ${it.img ? `<img src="${it.img}" alt="${it.name}" width="60" height="60"/>` : '<div class="cart-item-noimg">👢</div>'}
      <div class="cart-item-info">
        <div class="cart-item-brand">${it.brand || ''}</div>
        <a href="/productos/${it.slug}" class="cart-item-name">${it.name}</a>
        <div class="cart-item-meta">
          ${it.color ? `<span>Color: <strong>${it.color}</strong></span>` : ''}
          ${it.size ? `<span>Talla: <strong>${it.size}</strong></span>` : ''}
        </div>
        ${it.price ? `<div class="cart-item-price">$${Number(it.price).toLocaleString('es-CO')}</div>` : '<div class="cart-item-price-na">Precio a consultar</div>'}
      </div>
      <div class="cart-item-actions">
        <div class="qty-control">
          <button type="button" data-action="dec" data-idx="${idx}">−</button>
          <span>${it.qty}</span>
          <button type="button" data-action="inc" data-idx="${idx}">+</button>
        </div>
        <button type="button" class="cart-item-remove" data-action="rm" data-idx="${idx}" aria-label="Eliminar">🗑</button>
      </div>
    </div>
  `).join('');

  // Calcular total solo de items con precio
  const itemsWithPrice = cart.filter(i => i.price);
  if (itemsWithPrice.length === cart.length && cart.length > 0) {
    const total = cart.reduce((s, i) => s + (i.price * i.qty), 0);
    document.getElementById('cartTotal').textContent = '$' + total.toLocaleString('es-CO');
    totalWrap.style.display = 'flex';
  } else {
    totalWrap.style.display = 'none';
  }

  // Wire actions
  items.querySelectorAll('[data-action]').forEach(btn => btn.addEventListener('click', e => {
    const idx = parseInt(e.currentTarget.dataset.idx);
    const action = e.currentTarget.dataset.action;
    if (action === 'inc') cart[idx].qty++;
    if (action === 'dec') { cart[idx].qty--; if (cart[idx].qty < 1) cart.splice(idx, 1); }
    if (action === 'rm') cart.splice(idx, 1);
    saveCart(); updateCartBadge(); renderCart();
  }));
}

function openCart() {
  document.getElementById('cartDrawer').classList.add('open');
  document.getElementById('cartOverlay').classList.add('show');
  document.getElementById('cartDrawer').setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
  renderCart();
}
function closeCart() {
  document.getElementById('cartDrawer').classList.remove('open');
  document.getElementById('cartOverlay').classList.remove('show');
  document.getElementById('cartDrawer').setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
}

// API global para que cualquier página pueda agregar al carrito
window.addToCart = function(item, qty) {
  // item: {productId, slug, name, brand, color, size, price, img}, qty opcional (default 1)
  const addQty = qty || 1;
  const existing = cart.findIndex(i => i.productId === item.productId && i.color === item.color && i.size === item.size);
  if (existing >= 0) {
    cart[existing].qty += addQty;
  } else {
    cart.push({...item, qty: addQty});
  }
  saveCart(); updateCartBadge();
  showToast(`✓ Agregado al carrito${addQty > 1 ? ` (${addQty} pares)` : ''}`);
};

window.showToast = function(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
};

// Listeners
document.addEventListener('DOMContentLoaded', () => {
  updateCartBadge();
  document.getElementById('cartClose')?.addEventListener('click', closeCart);
  document.getElementById('cartOverlay')?.addEventListener('click', closeCart);
  // Nav drawer (móvil)
  const navdrawer = document.getElementById('navdrawer');
  const navOverlay = document.getElementById('navdrawerOverlay');
  const openNav = () => { navdrawer?.classList.add('open'); navOverlay?.classList.add('open'); document.body.style.overflow = 'hidden'; };
  const closeNav = () => { navdrawer?.classList.remove('open'); navOverlay?.classList.remove('open'); document.body.style.overflow = ''; };
  document.getElementById('navHamburger')?.addEventListener('click', openNav);
  document.getElementById('navdrawerClose')?.addEventListener('click', closeNav);
  navOverlay?.addEventListener('click', closeNav);

  // ── BUSCADOR DEL HEADER ──
  const hsData = JSON.parse(document.getElementById('headerSearchData')?.textContent || '[]');
  const hsWrap = document.getElementById('headerSearch');
  const hsOverlay = document.getElementById('headerSearchOverlay');
  const hsInput = document.getElementById('headerSearchInput');
  const hsSug = document.getElementById('headerSearchSuggestions');
  function openSearch(){ hsWrap?.classList.add('open'); hsOverlay?.classList.add('open'); setTimeout(()=>hsInput?.focus(),80); }
  function closeSearch(){ hsWrap?.classList.remove('open'); hsOverlay?.classList.remove('open'); if(hsSug) hsSug.innerHTML=''; if(hsInput) hsInput.value=''; }
  function fmt(n){ return '$' + Number(n).toLocaleString('es-CO'); }
  function hl(text, q){ if(!q) return text; const re=new RegExp('(\\b'+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi'); return text.replace(re,'<mark>$1</mark>'); }
  function wordMatch(str, q){ const re=new RegExp('\\b'+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'i'); return re.test(str); }
  function renderHs(q){
    if(!hsSug) return;
    if(!q){ hsSug.innerHTML=''; return; }
    const matches=hsData.filter(it=>wordMatch(it.name,q)||wordMatch(it.brand,q)).slice(0,8);
    if(matches.length===0){ hsSug.innerHTML='<div class="hs-empty">Sin coincidencias para “'+q+'”</div>'; return; }
    hsSug.innerHTML=matches.map(m=>{
      const price = m.sale ? fmt(m.sale) : (m.price ? fmt(m.price) : '');
      return '<a class="hs-item" href="/productos/'+m.slug+'">'+
        (m.img?'<img src="'+m.img+'" alt=""/>':'<div class="hs-item-noimg">👢</div>')+
        '<div><div class="hs-brand">'+m.brand+'</div><div class="hs-name">'+hl(m.name,q)+'</div></div>'+
        (price?'<div class="hs-price">'+price+'</div>':'')+
      '</a>';
    }).join('');
  }
  document.getElementById('headerSearchBtn')?.addEventListener('click', openSearch);
  document.getElementById('headerSearchClose')?.addEventListener('click', closeSearch);
  hsOverlay?.addEventListener('click', closeSearch);
  hsInput?.addEventListener('input', e=>renderHs(e.target.value.trim()));
  document.addEventListener('keydown', e=>{ if(e.key==='Escape') closeSearch(); });
  document.getElementById('cartClearBtn')?.addEventListener('click', () => {
    if (confirm('¿Vaciar todo el carrito?')) { cart = []; saveCart(); updateCartBadge(); renderCart(); }
  });
  document.getElementById('cartWaBtn')?.addEventListener('click', () => {
    if (cart.length === 0) return;
    let msg = '*Hola Procalzado, me interesan estos productos:*\n\n';
    cart.forEach((it, i) => {
      msg += `${i + 1}. *${it.brand ? it.brand + ' ' : ''}${it.name}*\n`;
      if (it.color) msg += `   Color: ${it.color}\n`;
      if (it.size) msg += `   Talla: ${it.size}\n`;
      msg += `   Cantidad: ${it.qty}\n`;
      if (it.price) msg += `   Precio: $${Number(it.price).toLocaleString('es-CO')}\n`;
      msg += `   Link: https://procalzado.com/productos/${it.slug}\n\n`;
    });
    window.open(`https://wa.me/${WA_PHONE}?text=${encodeURIComponent(msg)}`, '_blank');
  });

  // ── HEADER TRANSPARENTE → SÓLIDO AL SCROLL ──
  const hdr = document.querySelector('header');
  const hasHero = document.querySelector('.hero-banner, .gender-hero');
  function checkScroll() {
    if (!hdr) return;
    if (!hasHero || window.scrollY > 10) {
      hdr.classList.add('header-solid');
    } else {
      hdr.classList.remove('header-solid');
    }
  }
  window.addEventListener('scroll', checkScroll, { passive: true });
  checkScroll();
});

// ═══ AUTH STATE ═══
(function initAuth(){
  var cfgEl = document.getElementById('sbConfig');
  if (!cfgEl) return;
  var cfg = JSON.parse(cfgEl.textContent || '{}');
  if (!cfg.url || !cfg.key) return;
  if (typeof supabase === 'undefined' || !supabase.createClient) { setTimeout(initAuth, 100); return; }
  var sb = supabase.createClient(cfg.url, cfg.key);
  window.__sb = sb;

  sb.auth.getSession().then(function(r) {
    var user = r.data && r.data.session && r.data.session.user;
    var userBtn = document.getElementById('userBtn');
    var navAcct = document.getElementById('navdrawerAccount');
    if (user) {
      if (userBtn) userBtn.href = '/cuenta';
      if (navAcct) navAcct.textContent = 'Mi Cuenta';
    } else {
      if (userBtn) userBtn.href = '/cuenta/login';
      if (navAcct) { navAcct.href = '/cuenta/login'; navAcct.textContent = 'Iniciar Sesión'; }
    }
  });

  sb.auth.onAuthStateChange(function(ev, session) {
    var userBtn = document.getElementById('userBtn');
    var navAcct = document.getElementById('navdrawerAccount');
    if (session && session.user) {
      if (userBtn) userBtn.href = '/cuenta';
      if (navAcct) { navAcct.href = '/cuenta'; navAcct.textContent = 'Mi Cuenta'; }
    } else {
      if (userBtn) userBtn.href = '/cuenta/login';
      if (navAcct) { navAcct.href = '/cuenta/login'; navAcct.textContent = 'Iniciar Sesión'; }
    }
  });
})();
</script>
</body>
</html>
