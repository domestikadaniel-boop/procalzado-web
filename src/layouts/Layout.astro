</div>
<div class="header-search-overlay" id="headerSearchOverlay"></div>

<!-- DRAWER NAVEGACIÓN (móvil) -->
<div class="navdrawer-overlay" id="navdrawerOverlay"></div>
<aside class="navdrawer" id="navdrawer" aria-hidden="true">
  <div class="navdrawer-header">
    <span>Menú</span>
    <button class="navdrawer-close" id="navdrawerClose" type="button" aria-label="Cerrar">&times;</button>
