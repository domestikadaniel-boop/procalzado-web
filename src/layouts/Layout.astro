---
import { getSearchIndex } from '../lib/supabase';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}
const { title, description = 'Compra botas de caucho, botas de lluvia, botas de moto, botas de trabajo, sandalias y zapatos industriales en Colombia. Procalzado: distribuidor autorizado.', canonical, ogImage } = Astro.props;
const siteUrl = 'https://procalzado.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;

// Enlaces de navegación principal (género + recomendaciones)
const navLinks = [
  { label: 'Hombre', href: '/hombre' },
  { label: 'Mujer', href: '/mujer' },
  { label: 'Niños', href: '/ninos' },
  { label: 'Recomendaciones', href: '/recomendaciones', highlight: true },
];
const currentPath = Astro.url.pathname;
const searchIndex = await getSearchIndex();
---
<!DOCTYPE html>
<html lang="es-CO">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>{title}</title>
<meta name="description" content={description}/>
<meta name="robots" content="index, follow, max-image-preview:large"/>
<link rel="canonical" href={canonicalUrl}/>
<meta name="author" content="Procalzado"/>
<meta name="geo.region" content="CO"/>
<meta property="og:title" content={title}/>
<meta property="og:description" content={description}/>
<meta property="og:type" content="website"/>
<meta property="og:image" content={ogImage || `${siteUrl}/og-image.png`}/>
<meta property="og:site_name" content="Procalzado"/>
<meta property="og:locale" content="es_CO"/>
<meta name="theme-color" content="#FF0000"/>
<link rel="icon" type="image/x-icon" href="/favicon.ico"/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700&family=Bebas+Neue&display=swap"/></noscript>
<script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<style is:global>
:root{--red:#FF0000;--black:#000;--white:#fff;--grey:#F2F2F2;--grey2:#E5E5E5;--muted:#4A4A4A;--wa:#25D366;--wa-dk:#1BA44F;--fd:'Bebas Neue','Barlow',sans-serif;--fb:'Barlow',sans-serif;--header-h:64px}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--fb);background:var(--white);color:var(--black);overflow-x:hidden}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--grey)}::-webkit-scrollbar-thumb{background:var(--red);border-radius:3px}
a{color:inherit;text-decoration:none}

/* HEADER */
header{position:fixed;top:0;left:0;right:0;z-index:300;background:transparent;height:var(--header-h);display:flex;align-items:center;justify-content:space-between;padding:0 clamp(1rem,4vw,3rem);transition:background .3s,box-shadow .3s}
header.header-solid{background:var(--white);box-shadow:0 1px 4px rgba(0,0,0,.08)}
header.header-solid .header-nav-link{color:var(--black)}
header.header-solid .header-nav-link:hover{color:var(--red);background:var(--grey)}
header.header-solid .header-nav-link.active{color:var(--red)}
header.header-solid .header-nav-link.highlight{color:var(--red)}
header.header-solid .header-nav-link.highlight:hover{color:var(--white);background:var(--red)}
header.header-solid .header-icon-btn{color:var(--black)}
header.header-solid .header-icon-btn:hover{background:var(--grey)}
header.header-solid .nav-hamburger{color:var(--black)}
header.header-solid .cart-badge{background:var(--red);color:var(--white)}
.logo{display:flex;align-items:center;text-decoration:none}
.logo-img{height:26px;width:auto;display:block;filter:brightness(0) invert(1);transition:filter .3s}
header.header-solid .logo-img{filter:none}
.header-spacer{height:var(--header-h)}
.header-left{display:flex;align-items:center;gap:.7rem}
.nav-hamburger{display:none;background:none;border:none;color:var(--white);cursor:pointer;padding:.2rem;align-items:center;justify-content:center}
.nav-hamburger svg{width:26px;height:26px;display:block}

/* NAV en el header (desktop) */
.header-nav{display:flex;align-items:center;gap:.2rem}
.header-nav-link{padding:.5rem .9rem;font-family:var(--fb);font-size:.84rem;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:rgba(255,255,255,.85);text-decoration:none;border-radius:5px;transition:color .15s,background .15s;white-space:nowrap}
.header-nav-link:hover{color:var(--white);background:rgba(255,255,255,.1)}
.header-nav-link.active{color:var(--white);box-shadow:inset 0 -3px 0 var(--red)}
.header-nav-link.highlight{color:var(--white);font-weight:700}
.header-nav-link.highlight:hover{color:var(--white);background:var(--red)}

/* DRAWER NAVEGACIÓN (móvil) */
.navdrawer-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:4000;opacity:0;visibility:hidden;transition:opacity .25s}
.navdrawer-overlay.open{opacity:1;visibility:visible}
.navdrawer{position:fixed;top:0;left:0;bottom:0;width:78%;max-width:320px;background:var(--white);z-index:4001;transform:translateX(-100%);transition:transform .28s ease;display:flex;flex-direction:column;overflow-y:auto}
.navdrawer.open{transform:translateX(0)}
.navdrawer-header{display:flex;align-items:center;justify-content:space-between;padding:1.5rem 1.5rem 1rem;position:sticky;top:0;background:var(--white);z-index:1}
.navdrawer-header span{font-family:var(--fd);font-size:1.6rem;letter-spacing:.04em;color:var(--black)}
.navdrawer-close{background:none;border:1px solid var(--grey2);color:var(--black);width:36px;height:36px;border-radius:50%;font-size:1.5rem;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center}
.navdrawer-body{padding:1rem 0}
.navdrawer-top-link{display:block;padding:1.1rem 1.5rem;font-family:var(--fb);font-weight:600;text-transform:uppercase;letter-spacing:.04em;font-size:.9rem;color:var(--muted);text-decoration:none;border-bottom:1px solid var(--grey)}
.navdrawer-parent{display:block;padding:1.1rem 1.5rem;font-family:var(--fb);font-weight:700;font-size:1rem;color:var(--black);text-decoration:none;text-transform:uppercase;letter-spacing:.03em;border-bottom:1px solid var(--grey)}
.navdrawer-parent.highlight{color:var(--black);font-weight:700}
.promo-wrap-global{max-width:1280px;margin:0 auto;padding:1.5rem clamp(1rem,4vw,3rem) 0}
.navdrawer-parent:hover,.navdrawer-top-link:hover{color:var(--red)}
.header-right{display:flex;align-items:center;gap:.4rem}
.header-icon-btn{position:relative;background:none;border:none;color:var(--white);cursor:pointer;width:40px;height:40px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;transition:background .15s,opacity .15s;flex-shrink:0}
.header-icon-btn:hover{background:rgba(255,255,255,.12)}
.header-icon-btn svg{width:23px;height:23px;display:block}
.cart-badge{position:absolute;top:-2px;right:-2px;background:var(--white);color:var(--red);font-size:.66rem;font-weight:700;min-width:18px;height:18px;padding:0 4px;border-radius:10px;display:none;align-items:center;justify-content:center;line-height:1}
.cart-badge.show{display:flex}

/* BUSCADOR DESPLEGABLE DEL HEADER */
.header-search{position:fixed;top:0;left:0;right:0;background:var(--white);z-index:3200;transform:translateY(-100%);transition:transform .26s ease;box-shadow:0 6px 24px rgba(0,0,0,.15)}
.header-search.open{transform:translateY(0)}
.header-search-inner{display:flex;align-items:center;gap:.7rem;max-width:760px;margin:0 auto;padding:1rem clamp(1rem,4vw,2rem)}
.header-search .hs-icon{width:22px;height:22px;color:var(--muted);flex-shrink:0}
.header-search input{flex:1;border:none;outline:none;font-family:var(--fb);font-size:1.05rem;color:var(--black);background:none}
.header-search .hs-close{background:none;border:none;font-size:1.8rem;line-height:1;color:var(--muted);cursor:pointer;padding:0 .3rem}
.header-search .hs-close:hover{color:var(--red)}
.header-search-suggestions{max-width:760px;margin:0 auto;padding:0 clamp(1rem,4vw,2rem);max-height:60vh;overflow-y:auto}
.header-search-suggestions:not(:empty){padding-bottom:1rem}
.hs-item{display:flex;align-items:center;gap:.8rem;padding:.6rem .4rem;border-radius:8px;text-decoration:none;color:var(--black);border-bottom:1px solid var(--grey2)}
.hs-item:hover{background:var(--grey)}
.hs-item img{width:46px;height:46px;object-fit:cover;border-radius:6px;flex-shrink:0;background:var(--grey)}
.hs-item-noimg{width:46px;height:46px;border-radius:6px;background:var(--grey);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0}
.hs-brand{font-size:.68rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--red)}
.hs-name{font-size:.92rem;font-weight:600;line-height:1.15}
.hs-name mark{background:none;color:var(--red);padding:0;border-radius:0;font-weight:700}
.hs-price{margin-left:auto;font-family:var(--fb);font-weight:700;font-size:.9rem;white-space:nowrap}
.hs-empty{padding:1.2rem .4rem;color:var(--muted);font-size:.9rem;text-align:center}
.header-search-overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:3100;opacity:0;visibility:hidden;transition:opacity .26s}
.header-search-overlay.open{opacity:1;visibility:visible}

/* HERO */
.hero{background:var(--black);color:var(--white);padding:clamp(2rem,5vw,4rem) clamp(1rem,4vw,3rem);position:relative;overflow:hidden;min-height:calc(88vh - 64px);display:flex;align-items:center}
.hero::after{content:'';position:absolute;right:-80px;top:-60px;width:400px;height:400px;background:var(--red);clip-path:polygon(30% 0%,100% 0%,100% 100%,60% 100%);opacity:.1;pointer-events:none}
.hero-inner{max-width:1280px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:center;position:relative;z-index:1}
.hero-tag{display:inline-block;background:var(--red);color:var(--white);font-size:.68rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;padding:.28rem .7rem;border-radius:2px;margin-bottom:1.4rem}
.hero h1{font-family:var(--fd);font-size:clamp(2.8rem,6.5vw,5rem);line-height:.95;letter-spacing:.03em;margin-bottom:1.4rem}
.hero h1 .accent{color:var(--red)}
.hero-sub{font-size:1rem;font-weight:300;color:rgba(255,255,255,.88);max-width:420px;line-height:1.7}
.hero-stats{display:flex;gap:2rem;margin-top:2.8rem}
.stat{border-left:3px solid var(--red);padding-left:1rem}
.stat-num{font-family:var(--fd);font-size:2.3rem;line-height:1;color:var(--white)}
.stat-label{font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.72);margin-top:.2rem}
.hero-badge{flex-shrink:0;display:flex;align-items:center;justify-content:center}

/* FILTER BAR */
.filter-bar{background:var(--grey);border-bottom:1px solid var(--grey2);padding:.85rem clamp(1rem,4vw,3rem);position:sticky;top:64px;z-index:200}
.filter-inner{max-width:1280px;margin:0 auto;display:flex;flex-direction:column;gap:.65rem}
.search-wrap{position:relative;flex:1;min-width:160px;max-width:320px}
.search-wrap svg{position:absolute;left:.85rem;top:50%;transform:translateY(-50%);width:15px;height:15px;color:var(--muted);pointer-events:none;z-index:2}
.search-wrap input{width:100%;padding:.58rem 2.2rem .58rem 2.4rem;border:2px solid var(--grey2);border-radius:6px;background:var(--white);font-family:var(--fb);font-size:.86rem;color:var(--black);outline:none;transition:border-color .2s}
.search-wrap input:focus{border-color:var(--red)}
.search-clear{position:absolute;right:.55rem;top:50%;transform:translateY(-50%);background:var(--grey2);color:var(--muted);border:none;width:20px;height:20px;border-radius:50%;cursor:pointer;font-size:.85rem;line-height:1;display:flex;align-items:center;justify-content:center;padding:0;transition:all .15s;z-index:3}
.search-clear:hover{background:var(--red);color:var(--white)}

/* SEARCH SUGGESTIONS DROPDOWN */
.search-suggestions{position:absolute;top:100%;left:0;right:0;background:var(--white);border:2px solid var(--red);border-radius:8px;margin-top:.4rem;max-height:400px;overflow-y:auto;-webkit-overflow-scrolling:touch;box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:100;display:none}
.search-suggestions.show{display:block;animation:fadeInDrop .18s ease}
@keyframes fadeInDrop{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.suggestion-item{display:flex;align-items:center;gap:.7rem;padding:.6rem .8rem;text-decoration:none;color:inherit;border-bottom:1px solid var(--grey2);transition:background .12s;cursor:pointer}
.suggestion-item:last-child{border-bottom:0}
.suggestion-item:hover,.suggestion-item.active{background:#fff5f5}
.suggestion-item img,.suggestion-noimg{width:40px;height:40px;object-fit:cover;border-radius:4px;background:var(--grey);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.4rem}
.suggestion-info{flex:1;min-width:0}
.suggestion-brand{font-size:.65rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--red);margin-bottom:.05rem}
.suggestion-name{font-family:var(--fd);font-size:.95rem;letter-spacing:.02em;color:var(--black);line-height:1.15;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.suggestion-price{font-size:.82rem;font-weight:700;color:var(--black);flex-shrink:0;white-space:nowrap}
.suggestion-empty{padding:1rem;text-align:center;color:var(--muted);font-size:.85rem}
.suggestion-item mark{background:#ffeb3b;color:var(--black);padding:0 1px;border-radius:2px;font-weight:600}
/* Contenedor que se colapsa - SIEMPRE como modal fullscreen */
.collapsible-filters{position:fixed;top:0;left:0;right:0;bottom:0;background:var(--white);z-index:5000;margin:0!important;padding:0!important;border:0!important;max-height:none!important;overflow-y:auto;-webkit-overflow-scrolling:touch;display:flex;flex-direction:column;padding-bottom:6rem!important}
.collapsible-filters:not(.hidden){animation:slideUp .3s ease}
.collapsible-filters.hidden{display:none!important;opacity:0}

/* Header del modal con botón X */
.filters-modal-header{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.4rem;color:var(--white);background:var(--black);border-bottom:3px solid var(--red);position:sticky;top:0;z-index:2}
.filters-modal-header h3{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.04em;margin:0}
.filters-close-btn{background:none;border:1px solid rgba(255,255,255,.3);color:var(--white);width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:1.4rem;line-height:1;display:flex;align-items:center;justify-content:center;padding:0;transition:all .15s}
.filters-close-btn:hover{background:var(--red);border-color:var(--red)}
.filter-section-title{font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.4rem;margin-top:1.2rem;padding:0 1.4rem}
.filter-section-title:first-child{margin-top:1rem}
.filter-apply{display:block;position:fixed;bottom:0;left:0;right:0;width:100%;padding:1rem;background:var(--red);color:var(--white);border:none;font-family:var(--fb);font-size:.95rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;cursor:pointer;z-index:5001;box-shadow:0 -4px 16px rgba(0,0,0,.1)}
.filter-apply:hover{background:#cc0000}

/* Bloquear scroll del fondo cuando hay filtros abiertos */
body.filters-open{overflow:hidden}
body.filters-open header{display:none}

.toggle-cats-btn{display:flex;align-items:center;gap:.4rem;padding:.5rem 1rem;border:2px solid var(--grey2);border-radius:6px;background:var(--white);font-family:var(--fb);font-size:.8rem;font-weight:600;letter-spacing:.03em;color:var(--muted);cursor:pointer;transition:all .18s;text-transform:uppercase;white-space:nowrap;flex-shrink:0;position:relative}
.toggle-cats-btn svg{width:15px;height:15px;flex-shrink:0}
.toggle-cats-btn:hover{border-color:var(--red);color:var(--red)}
.toggle-cats-btn.active-toggle{background:var(--red);border-color:var(--red);color:var(--white)}
.filter-count-badge{background:var(--red);color:var(--white);font-size:.65rem;font-weight:700;padding:.1rem .35rem;border-radius:8px;min-width:18px;display:inline-flex;align-items:center;justify-content:center}
.toggle-cats-btn.active-toggle .filter-count-badge{background:var(--white);color:var(--red)}
.filter-top-row{display:flex;align-items:center;gap:.7rem}
.pills{display:flex;flex-wrap:wrap;gap:.4rem;padding:0 1.4rem;margin-bottom:.5rem}
.pill{padding:.42rem .95rem;border:2px solid var(--grey2);border-radius:4px;background:var(--white);font-family:var(--fb);font-size:.8rem;font-weight:600;letter-spacing:.03em;cursor:pointer;transition:all .18s;color:var(--muted);text-transform:uppercase;border:2px solid var(--grey2)}
.pill:hover{border-color:var(--red);color:var(--red)}
.pill.active{background:var(--red);border-color:var(--red);color:var(--white)}

/* SUBCATS */
.subcats-wrapper{margin-top:.3rem}
.subcat-pill{font-size:.72rem!important;padding:.3rem .7rem!important;background:var(--grey)!important}
.subcat-pill.active{background:var(--black)!important;border-color:var(--black)!important;color:var(--white)!important}

/* FILTERS PANEL */
.filters-panel{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;padding:1rem;background:var(--grey);border-radius:8px;margin:.5rem 1.4rem 0}
.filter-group{display:flex;flex-direction:column;gap:.5rem}
.filter-group-title{font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--black);padding-bottom:.3rem;border-bottom:1px solid var(--grey2)}
.filter-options{display:flex;flex-direction:column;gap:.3rem}
.filter-check{display:flex;align-items:center;gap:.4rem;font-size:.82rem;cursor:pointer;color:var(--muted);user-select:none}
.filter-check:hover{color:var(--black)}
.filter-check input{accent-color:var(--red);width:18px;height:18px;cursor:pointer}
.filter-price{display:flex;flex-direction:column;gap:.3rem}
.filter-price input{padding:.4rem .55rem;border:1.5px solid var(--grey2);border-radius:5px;font-family:var(--fb);font-size:.8rem;outline:none;width:80px}
.filter-price input:focus{border-color:var(--red)}
.filter-clear{margin:1rem 1.4rem 0!important;padding:.55rem;background:var(--white);border:1px dashed var(--grey2);border-radius:5px;cursor:pointer;font-family:var(--fb);font-size:.78rem;color:var(--muted);transition:all .15s;width:calc(100% - 2.8rem)}
.filter-clear:hover{border-color:var(--red);color:var(--red);background:#fff5f5}

@keyframes slideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}

/* En mobile, ajustes de espaciado */
@media(max-width:640px){
  :root{--header-h:52px}
  header{padding:0 .8rem}
  .logo-img{height:20px}
  .header-icon-btn{width:34px;height:34px}
  .header-icon-btn svg{width:20px;height:20px}
  .header-right{gap:.15rem}
  .filters-panel{grid-template-columns:1fr 1fr;gap:.8rem;padding:.8rem;margin:.5rem 1rem 0}
  .filter-section-title{padding:0 1rem}
  .pills{padding:0 1rem}
  .filter-clear{margin:1rem 1rem 0!important;width:calc(100% - 2rem)}
  .nav-hamburger{display:flex}
  .header-nav{display:none}
}
/* Tablet: la nav horizontal puede no caber; usamos hamburguesa hasta 900px */
@media(max-width:900px){
  .header-nav{display:none}
  .nav-hamburger{display:flex}
}

/* PRODUCTS */
.products-section{max-width:1280px;margin:0 auto;padding:2.2rem clamp(1rem,4vw,3rem) 5rem}
.section-header{display:flex;align-items:baseline;gap:1rem;margin-bottom:1.8rem;border-bottom:3px solid var(--black);padding-bottom:.7rem}
.section-title{font-family:var(--fd);font-size:1.9rem;letter-spacing:.04em}
.section-title .red{color:var(--red)}
.section-count{font-size:.78rem;color:var(--muted);font-weight:500;letter-spacing:.06em;text-transform:uppercase}
.product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.1rem}

/* CARD */
.card{background:var(--white);border-radius:10px;overflow:hidden;cursor:pointer;transition:transform .2s,box-shadow .2s;display:flex;flex-direction:column;animation:fadeUp .32s ease both;text-decoration:none;color:inherit;position:relative}
.card:hover{transform:translateY(-4px);box-shadow:0 10px 32px rgba(0,0,0,.1)}

/* Badge Destacado */
.card-badge-featured{position:absolute;top:.6rem;left:.6rem;background:var(--red);color:var(--white);font-family:var(--fb);font-size:.65rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:.25rem .55rem;border-radius:4px;display:inline-flex;align-items:center;gap:.25rem;z-index:5;box-shadow:0 2px 6px rgba(0,0,0,.2);animation:badgePulse 2s ease-in-out infinite}
.card-badge-featured svg{width:11px;height:11px;flex-shrink:0}
@keyframes badgePulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}
.card-badge-sale{position:absolute;top:.6rem;right:.6rem;background:var(--red);color:var(--white);font-family:var(--fb);font-weight:700;font-size:.75rem;padding:.22rem .5rem;border-radius:4px;z-index:5}
.card-img{width:100%;aspect-ratio:1;background:var(--grey);display:flex;align-items:center;justify-content:center;font-size:3.8rem;overflow:hidden;position:relative;border-radius:10px}
.card-img img{width:100%;height:100%;object-fit:cover}
.card-img .card-img-hover{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .3s ease}
.card:hover .card-img-hover{opacity:1}
.card-body{padding:.7rem .5rem .9rem;flex:1;display:flex;flex-direction:column}
.card-brand{font-size:.65rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--red);margin-bottom:.15rem}
.card-name{font-family:var(--fd);font-size:1.1rem;letter-spacing:.03em;line-height:1.15;margin-bottom:.2rem}
.card-desc{font-size:.75rem;color:var(--muted);line-height:1.35;margin-bottom:.4rem}
.card-cat-tag{font-size:.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:.7rem}
.card-price{font-size:.95rem;font-weight:700;color:var(--black);margin-top:auto;margin-bottom:.3rem}
.card-price-note{font-size:.68rem;color:#444;margin-bottom:.6rem;font-weight:500}
.empty{grid-column:1/-1;text-align:center;padding:5rem 1rem;color:var(--muted)}
.empty strong{font-family:var(--fd);font-size:1.4rem;display:block;margin-bottom:.5rem;color:var(--black)}

/* PRODUCT PAGE */
.product-page{max-width:1280px;margin:0 auto;padding:2rem clamp(1rem,4vw,3rem) 5rem}
.breadcrumb{font-size:.78rem;color:var(--muted);margin-bottom:1.5rem;display:flex;flex-wrap:wrap;gap:.3rem}
.breadcrumb a{color:var(--red);text-decoration:underline}
.product-layout{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:start}
.product-gallery-wrap{position:relative}
.product-gallery{background:var(--white);border:1px solid var(--grey2);border-radius:12px;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:5rem;padding:1rem;position:relative;min-height:300px}
.product-gallery img{max-width:100%;max-height:600px;width:auto;height:auto;object-fit:contain;display:block;user-select:none;-webkit-user-drag:none}
.gallery-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(0,0,0,.6);color:var(--white);border:none;width:42px;height:42px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s,transform .12s;z-index:5;backdrop-filter:blur(4px)}
.gallery-nav:hover{background:var(--red);transform:translateY(-50%) scale(1.05)}
.gallery-nav.prev{left:.8rem}
.gallery-nav.next{right:.8rem}
.gallery-nav svg{width:22px;height:22px}
.gallery-counter{position:absolute;bottom:.8rem;right:.8rem;background:rgba(0,0,0,.65);color:var(--white);padding:.3rem .7rem;border-radius:20px;font-size:.75rem;font-weight:600;letter-spacing:.05em;backdrop-filter:blur(4px);z-index:5}
.product-info h1{font-family:var(--fd);font-size:2.2rem;letter-spacing:.04em;margin-bottom:.5rem}
.product-brand-tag{display:inline-block;background:var(--red);color:var(--white);font-size:.68rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;padding:.25rem .7rem;border-radius:2px;margin-bottom:1rem}
.product-description{font-size:.92rem;line-height:1.7;color:var(--muted);margin-bottom:1.5rem}

/* AVISO ESPECIAL */
.product-notice{padding:.75rem 1rem;border-radius:8px;margin-bottom:1.2rem;font-size:.88rem;font-weight:600;line-height:1.4;border-left:4px solid}
.notice-info{background:#e6f4ff;border-color:#1e88e5;color:#0d47a1}
.notice-warning{background:#fff8e1;border-color:#f59e0b;color:#7c4a03}
.notice-success{background:#e8f5e9;border-color:#16a34a;color:#14532d}
.notice-danger{background:#ffebee;border-color:var(--red);color:#b71c1c}
.specs-table{width:100%;border-collapse:collapse;margin-bottom:1.5rem}
.specs-table th,.specs-table td{text-align:left;padding:.55rem .8rem;font-size:.85rem;border-bottom:1px solid var(--grey2)}
.specs-table th{font-weight:600;color:var(--black);width:140px;background:var(--grey)}
.specs-table td{color:var(--muted)}
.product-variants{margin-bottom:1.5rem}
.variant-title{font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:.5rem}
.size-list,.color-list{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:1rem}
.size-tag-btn{padding:.45rem .8rem;border:2px solid var(--grey2);border-radius:5px;font-size:.85rem;font-weight:600;color:var(--muted);background:var(--white);cursor:pointer;font-family:inherit;transition:all .15s;min-width:42px}
.size-tag-btn:hover{border-color:var(--red);color:var(--red)}
.size-tag-btn.selected{background:var(--black);border-color:var(--black);color:var(--white)}
.color-dot-btn{width:32px;height:32px;border-radius:50%;border:2px solid var(--grey2);cursor:pointer;padding:0;transition:all .15s;position:relative}
.color-dot-btn:hover{transform:scale(1.1)}
.color-dot-btn.selected{border-color:var(--black);box-shadow:0 0 0 2px var(--white) inset}
.color-dot-btn.selected::after{content:'';position:absolute;inset:-5px;border:2px solid var(--red);border-radius:50%}
.product-actions{display:flex;gap:.7rem;flex-wrap:wrap}
.qty-selector{display:flex;align-items:center;gap:1rem;margin-bottom:.3rem;padding:.7rem 1rem;background:var(--grey);border-radius:8px}
.qty-selector label{font-size:.78rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
.qty-input-group{display:flex;align-items:center;gap:0;border:2px solid var(--grey2);border-radius:6px;background:var(--white);overflow:hidden}
.qty-input-group .qty-btn{background:var(--white);border:none;width:32px;height:34px;cursor:pointer;font-size:1.1rem;font-weight:600;color:var(--black);transition:background .15s;font-family:inherit;line-height:1}
.qty-input-group .qty-btn:hover{background:var(--red);color:var(--white)}
.qty-input-group input{width:48px;text-align:center;border:none;border-left:1px solid var(--grey2);border-right:1px solid var(--grey2);padding:.4rem 0;font-size:.9rem;font-weight:600;font-family:inherit;outline:none;-moz-appearance:textfield}
.qty-input-group input::-webkit-outer-spin-button,.qty-input-group input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0}
.btn-add-cart{display:flex;align-items:center;justify-content:center;gap:.5rem;background:var(--black);color:var(--white);padding:.85rem 1.5rem;border:none;border-radius:8px;font-weight:700;font-size:.9rem;text-transform:uppercase;letter-spacing:.04em;cursor:pointer;font-family:inherit;width:100%;transition:background .15s,transform .12s}
.btn-add-cart:hover{background:var(--red);transform:translateY(-1px)}
.btn-add-cart svg{width:18px;height:18px}
.btn-wa{display:flex;align-items:center;justify-content:center;gap:.5rem;background:var(--red);color:var(--white);padding:.8rem 1.5rem;border-radius:8px;font-weight:700;font-size:.9rem;text-transform:uppercase;letter-spacing:.04em;text-decoration:none;transition:background .18s,transform .15s;width:100%}
.btn-wa:hover{background:#cc0000;transform:scale(1.01)}
.btn-wa svg{width:18px;height:18px}

/* FOOTER */
footer{background:var(--black);color:rgba(255,255,255,.72);text-align:center;padding:1.8rem 1rem;font-size:.8rem}
footer strong{color:var(--white)}
footer a{color:#FF4444;text-decoration:underline}

/* TOAST */
.toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(20px);background:var(--black);color:var(--white);padding:.65rem 1.3rem;border-radius:8px;font-size:.85rem;font-weight:500;z-index:600;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;border-left:4px solid var(--red)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* CART DRAWER */
.cart-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:400;opacity:0;pointer-events:none;transition:opacity .25s}
.cart-overlay.show{opacity:1;pointer-events:auto}
.cart-drawer{position:fixed;top:0;right:0;width:min(420px,100vw);height:100vh;background:var(--white);z-index:450;transform:translateX(100%);transition:transform .3s ease;display:flex;flex-direction:column;box-shadow:-8px 0 32px rgba(0,0,0,.15)}
.cart-drawer.open{transform:translateX(0)}
.cart-header{padding:1rem 1.2rem;background:var(--black);color:var(--white);display:flex;align-items:center;justify-content:space-between;border-bottom:3px solid var(--red);flex-shrink:0}
.cart-header h3{font-family:var(--fd);font-size:1.3rem;letter-spacing:.04em}
.cart-close{background:none;border:none;color:var(--white);font-size:1.6rem;cursor:pointer;padding:0 .3rem;line-height:1;transition:color .15s}
.cart-close:hover{color:var(--red)}
.cart-body{flex:1;overflow-y:auto;padding:1rem 1.2rem}
.cart-empty{text-align:center;padding:3rem 1rem;color:var(--muted)}
.cart-empty strong{font-family:var(--fd);font-size:1.3rem;display:block;margin-bottom:.4rem;color:var(--black);letter-spacing:.04em}
.cart-empty p{font-size:.85rem}
.cart-item{display:grid;grid-template-columns:60px 1fr auto;gap:.7rem;padding:.8rem 0;border-bottom:1px solid var(--grey2)}
.cart-item img,.cart-item-noimg{width:60px;height:60px;object-fit:cover;border-radius:6px;background:var(--grey);display:flex;align-items:center;justify-content:center;font-size:1.8rem;flex-shrink:0}
.cart-item-info{min-width:0;display:flex;flex-direction:column;gap:.2rem}
.cart-item-brand{font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--red)}
.cart-item-name{font-family:var(--fd);font-size:1rem;letter-spacing:.02em;line-height:1.2;color:var(--black);text-decoration:none}
.cart-item-name:hover{color:var(--red)}
.cart-item-meta{font-size:.72rem;color:var(--muted);display:flex;gap:.6rem;flex-wrap:wrap}
.cart-item-meta strong{color:var(--black);font-weight:600}
.cart-item-price{font-size:.88rem;font-weight:700;margin-top:.15rem}
.cart-item-price-na{font-size:.72rem;color:var(--muted);font-style:italic;margin-top:.15rem}
.cart-item-actions{display:flex;flex-direction:column;align-items:flex-end;justify-content:space-between;gap:.4rem}
.qty-control{display:flex;align-items:center;gap:.3rem;border:1px solid var(--grey2);border-radius:5px;background:var(--white)}
.qty-control button{background:none;border:none;width:24px;height:24px;cursor:pointer;font-size:.95rem;color:var(--muted);font-weight:600;line-height:1}
.qty-control button:hover{color:var(--red)}
.qty-control span{min-width:18px;text-align:center;font-size:.82rem;font-weight:600}
.cart-item-remove{background:none;border:none;cursor:pointer;font-size:.9rem;opacity:.5;padding:.2rem;transition:opacity .15s}
.cart-item-remove:hover{opacity:1}
.cart-footer{padding:1rem 1.2rem;border-top:2px solid var(--grey2);flex-shrink:0;background:var(--grey)}
.cart-total{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:.5rem;padding:.5rem 0}
.cart-total span{font-size:.82rem;color:var(--muted)}
.cart-total strong{font-family:var(--fd);font-size:1.3rem;letter-spacing:.03em}
.btn-cart-wa{width:100%;display:flex;align-items:center;justify-content:center;gap:.5rem;background:var(--wa);color:var(--white);border:none;padding:.85rem;border-radius:8px;font-weight:700;font-size:.85rem;text-transform:uppercase;letter-spacing:.04em;cursor:pointer;font-family:inherit;transition:background .15s}
.btn-cart-wa:hover{background:var(--wa-dk)}
.btn-cart-wa svg{width:18px;height:18px}
.btn-clear{width:100%;background:none;border:none;color:var(--muted);font-size:.78rem;margin-top:.5rem;cursor:pointer;padding:.4rem;font-family:inherit;text-decoration:underline}
.btn-clear:hover{color:var(--red)}

@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:640px){
  .hero-inner{grid-template-columns:1fr}
  .hero-badge{display:none}
  .hero h1{font-size:clamp(2.4rem,11vw,3.2rem)}
  .product-grid{grid-template-columns:repeat(auto-fill,minmax(145px,1fr))}
  .header-wa span{display:none}
  .product-layout{grid-template-columns:1fr}
  .filters-panel{grid-template-columns:1fr 1fr;gap:.7rem;padding:.7rem}
  .filter-options{gap:.4rem}
  .filter-check{font-size:.78rem;padding:.3rem 0}
  .filter-check input{width:18px;height:18px}
  .filter-bar{padding:.7rem 1rem}
  .toggle-cats-btn{padding:.5rem .7rem}
  .toggle-label{display:none}
  .pills{gap:.3rem}
  .pill{padding:.38rem .7rem;font-size:.74rem}
  .search-wrap{max-width:none}
}
</style>
</head>
<body>
