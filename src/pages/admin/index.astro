// COLORS
function renderColors(){
  $('colorsContainer').innerHTML = formColors.map((c,idx) => `
    <div class="color-block" data-idx="${idx}">
      <div class="color-row1">
        <input type="color" value="${c.hex||'#000000'}" data-action="hex" data-idx="${idx}" title="Color principal"/>
        ${c.dual ? `<input type="color" value="${c.hex2||'#FFFFFF'}" data-action="hex2color" data-idx="${idx}" title="Segundo color"/>` : ''}
        <input type="text" placeholder="Nombre del color (ej: Negro/Rojo)" value="${c.name||''}" data-action="name" data-idx="${idx}"/>
        <button type="button" class="dual-toggle ${c.dual?'active':''}" data-action="toggleDual" data-idx="${idx}" title="${c.dual?'Color simple':'Color dual'}">${c.dual?'◐':'⬤'}</button>
        <button type="button" class="remove-color" data-action="remove" data-idx="${idx}">✕</button>
      </div>
      ${c.dual ? `<div class="color-preview-dual" style="background:linear-gradient(135deg,${c.hex||'#000'} 50%, ${c.hex2||'#FFF'} 50%);width:32px;height:32px;border-radius:50%;border:2px solid var(--white);box-shadow:0 0 0 1px var(--grey2);margin:0 0 .5rem"></div>` : ''}
      <div class="color-imgs" data-imgs="${idx}">
        ${(c.images||[]).map((img,i)=>`<div class="color-img-thumb" style="width:70px;height:70px"><img src="${img.url}" width="70" height="70" style="width:70px;height:70px;object-fit:cover;display:block"/><button type="button" class="x" data-rmimg="${idx}-${i}">×</button></div>`).join('')}
        <button type="button" class="upload-color-btn" data-action="upload" data-idx="${idx}">📷 Subir imagen</button>
      </div>
    </div>`).join('');

  $('colorsContainer').querySelectorAll('[data-action]').forEach(el=>{
    el.addEventListener('change',handleColorChange);
    el.addEventListener('click',handleColorClick);
  });
  $('colorsContainer').querySelectorAll('[data-rmimg]').forEach(el=>{
    el.addEventListener('click',e=>{
      const[ci,ii]=e.target.dataset.rmimg.split('-').map(Number);
      formColors[ci].images.splice(ii,1);
      renderColors();
    });
  });
}

function handleColorChange(e){
  const idx=parseInt(e.target.dataset.idx);
  const action=e.target.dataset.action;
  if(action==='name')formColors[idx].name=e.target.value;
  if(action==='hex'){formColors[idx].hex=e.target.value; renderColors();}
  if(action==='hex2color'){formColors[idx].hex2=e.target.value; renderColors();}
}
function handleColorClick(e){
  const action=e.target.dataset.action;
  const idx=parseInt(e.target.dataset.idx);
  if(action==='remove'){
    if(confirm('¿Eliminar este color?')){formColors.splice(idx,1);renderColors()}
  } else if(action==='upload'){
    activeColorIdx=idx;
    $('hiddenColorInput').click();
  } else if(action==='toggleDual'){
    formColors[idx].dual = !formColors[idx].dual;
    if(formColors[idx].dual && !formColors[idx].hex2) formColors[idx].hex2 = '#FFFFFF';
    renderColors();
  }
}
$('hiddenColorInput').addEventListener('change',async e=>{
  if(activeColorIdx===null)return;
  for(const file of Array.from(e.target.files)){
    const path=`${Date.now()}-${file.name.replace(/[^a-zA-Z0-9.-]/g,'_')}`;
    loading(true);
    const{error}=await supabase.storage.from('product-images').upload(path,file);
    loading(false);
    if(error){alert('Error: '+error.message);continue}
    const{data:{publicUrl}}=supabase.storage.from('product-images').getPublicUrl(path);
    if(!formColors[activeColorIdx].images)formColors[activeColorIdx].images=[];
    formColors[activeColorIdx].images.push({url:publicUrl,existing:false});
  }
  renderColors();
  e.target.value='';
  activeColorIdx=null;
});
$('addColorBtn').addEventListener('click',()=>{
  formColors.push({name:'',hex:'#000000',hex2:'#FFFFFF',dual:false,images:[]});
  renderColors();
});

// FORM OPEN
function openProductForm(p=null){
  editingProduct=p;formColors=[];
  $('formTitle').textContent=p?'Editar Producto':'Nuevo Producto';
  $('productId').value=p?.id||'';$('pName').value=p?.name||'';$('pSlug').value=p?.slug||'';
  $('pBrand').value=p?.brand_id||'';
  // Cargar géneros (de array nuevo o del campo viejo single)
  const productGenders = (p?.genders && p.genders.length > 0) ? p.genders : (p?.gender ? [p.gender] : []);
  document.querySelectorAll('[data-gender]').forEach(inp => {
    inp.checked = productGenders.includes(inp.value);
  });
  $('pPrice').value=p?.price||'';$('pSalePrice').value=p?.sale_price||'';$('pShowPrice').checked=p?.show_price||false;$('pFeatured').checked=p?.featured||false;
  $('pShortDesc').value=p?.short_description||'';$('pDesc').value=p?.description||'';
  $('pNotice').value=p?.notice||'';$('pNoticeType').value=p?.notice_type||'info';

  // Categorías - de la nueva tabla, con fallback a la vieja
  let selectedCatIds = [];
  let primaryCatId = null;
  if (p?.product_categories?.length) {
    selectedCatIds = p.product_categories.map(pc => pc.category_id);
    primaryCatId = p.product_categories.find(pc => pc.is_primary)?.category_id || selectedCatIds[0];
  } else if (p?.category_id) {
    selectedCatIds = [p.category_id];
    primaryCatId = p.category_id;
  }
  renderCategoriesCheckboxes(selectedCatIds, primaryCatId);

  $('specsContainer').innerHTML='';
  const specs=p?.specs||{};Object.entries(specs).forEach(([k,v])=>addSpecRow(k,String(v)));if(!Object.keys(specs).length)addSpecRow();

  // Sizes
  const sizes = p?.product_variants ? [...new Set(p.product_variants.map(v=>v.size))] : [];
  renderSizesGrid(sizes);

  // Colors with their images
  if(p?.product_variants){
    const uniqueColors=[...new Set(p.product_variants.map(v=>v.color))];
    formColors=uniqueColors.map(cname=>{
      const variant=p.product_variants.find(v=>v.color===cname);
      const colorImages=(p.product_images||[]).filter(i=>i.color===cname);
      return{
        name:cname,
        hex:variant?.color_hex||'#000000',
        hex2:variant?.color_hex_2||'#FFFFFF',
        dual:!!variant?.color_hex_2,
        images:colorImages.map(i=>({url:i.url,id:i.id,existing:true}))
      };
    });
  }
  if(!formColors.length)formColors.push({name:'',hex:'#000000',hex2:'#FFFFFF',dual:false,images:[]});
  renderColors();

  $('productModal').classList.add('open');
}

$('addProductBtn').addEventListener('click',()=>openProductForm());
