    return `<tr draggable="true" data-id="${r.id}" class="draggable-row">
      <td style="width:24px;cursor:grab;color:var(--muted);text-align:center">⋮⋮</td>
      <td style="width:60px;padding:.5rem">${img?`<img src="${img.url}" width="50" height="50" style="width:50px;height:50px;object-fit:cover;border-radius:4px;display:block"/>`:'<span style="font-size:1.5rem">👢</span>'}</td>
      <td><strong>${p?.name||'(eliminado)'}</strong><br><span style="font-size:.72rem;color:var(--muted)">${p?.brands?.name||''}</span></td>
      <td style="font-size:.82rem;color:var(--muted);max-width:320px">${r.reason||'<em style="color:var(--grey2)">sin motivo</em>'}</td>
      <td class="actions-cell"><button class="action-btn edit" onclick="window.editPromoProd('${r.id}')">✏️ Editar</button><button class="action-btn delete" onclick="window.deletePromoProd('${r.id}')">🗑️</button></td>
    </tr>`;
  }).join('');
  setupDragAndDrop('promoProdTableBody', promoProducts, 'promo_products');
}
let promoProdSS=null;
function populatePromoProdSelect(){
  const items=products.map(p=>({value:p.id,label:p.name,brand:p.brands?.name||''}));
  promoProdSS=initSearchSelect('promoProdSearch','promoProdList','promoProdSearchWrap','promoProdProduct',items);
}
$('addPromoProdBtn')?.addEventListener('click',()=>{
  $('promoProdId').value='';$('promoProdReason').value='';
  populatePromoProdSelect();promoProdSS?.clear();$('promoProdFormTitle').textContent='Agregar producto';$('promoProdModal').classList.add('open');
});
window.editPromoProd=(id)=>{
  const r=promoProducts.find(x=>x.id===id);if(!r)return;
  populatePromoProdSelect();
  $('promoProdId').value=r.id;promoProdSS?.setValue(r.product_id||'');$('promoProdReason').value=r.reason||'';
  $('promoProdFormTitle').textContent='Editar producto';$('promoProdModal').classList.add('open');
};
window.deletePromoProd=async(id)=>{
  if(!confirm('¿Quitar de la promoción?'))return;
  loading(true);await supabase.from('promo_products').delete().eq('id',id);await loadData();loading(false);showToast('Quitado');
};
$('promoProdSaveBtn')?.addEventListener('click',async()=>{
  const product_id=$('promoProdProduct').value;
  if(!product_id){alert('Selecciona un producto');return}
  const d={product_id,reason:$('promoProdReason').value.trim()||null,active:true};
  loading(true);const id=$('promoProdId').value;
  let error;
  if(id){({error}=await supabase.from('promo_products').update(d).eq('id',id));}
  else{d.display_order=promoProducts.length;({error}=await supabase.from('promo_products').insert(d));}
  loading(false);
  if(error){alert('No se pudo guardar:\n\n'+error.message);return}
  $('promoProdModal').classList.remove('open');await loadData();showToast('Producto guardado ✓');
});

// PROMOS
const PROMO_SLOTS = [
  {slot:'hero', label:'Banner debajo del inicio', hint:'Ideal para productos destacados, ofertas o lanzamientos.'},
  {slot:'mid', label:'Banner en medio del catálogo', hint:'Ideal para promos de temporada (Día del Padre, Navidad, etc.).'}
];
let activePromoUpload = null;
async function loadPromos(){
  const {data} = await supabase.from('promo_blocks').select('*');
  promos = {};
  (data||[]).forEach(b => { promos[b.slot] = b; });
  // Asegurar que existan ambos slots en memoria
  PROMO_SLOTS.forEach(s => { if(!promos[s.slot]) promos[s.slot] = {slot:s.slot, active:false, overlay:35, text_color:'#FFFFFF'}; });
  renderPromos();
}
function renderPromos(){
  const cont = $('promosContainer');
  if(!cont) return;
  cont.innerHTML = PROMO_SLOTS.map(s => {
    const b = promos[s.slot] || {};
    return `<div style="background:var(--white);border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.06);margin-bottom:1.4rem;overflow:hidden">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.1rem;background:var(--black);color:var(--white)">
        <div><strong style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:.04em">${s.label}</strong><div style="font-size:.72rem;opacity:.7">${s.hint}</div></div>
        <label class="toggle-switch"><input type="checkbox" id="promoActive-${s.slot}" data-toggleactive="${s.slot}" ${b.active?'checked':''}/><span class="toggle-slider"></span></label>
      </div>
      <div style="padding:1.2rem;display:grid;grid-template-columns:1fr 1fr;gap:.9rem">
        <div class="field"><label>Texto pequeño (arriba)</label><input type="text" id="promoEyebrow-${s.slot}" value="${(b.eyebrow||'').replace(/"/g,'&quot;')}" placeholder="Ej: NUEVA TEMPORADA"/></div>
        <div class="field"><label>Título grande</label><input type="text" id="promoTitle-${s.slot}" value="${(b.title||'').replace(/"/g,'&quot;')}" placeholder="Ej: Especial Día del Padre"/></div>
        <div class="field full" style="grid-column:1/-1"><label>Subtítulo</label><input type="text" id="promoSubtitle-${s.slot}" value="${(b.subtitle||'').replace(/"/g,'&quot;')}" placeholder="Texto secundario"/></div>
        <div class="field"><label>Texto del botón</label><input type="text" id="promoCtaLabel-${s.slot}" value="${(b.cta_label||'').replace(/"/g,'&quot;')}" placeholder="Ej: Ver colección"/></div>
        <div class="field"><label>Enlace del botón</label><input type="text" id="promoCtaHref-${s.slot}" value="${(b.cta_href||'').replace(/"/g,'&quot;')}" placeholder="Ej: /recomendaciones"/></div>
        <div class="field" style="grid-column:1/-1">
          <label>Imagen de fondo</label>
          <div id="promoImgPreview-${s.slot}" style="margin-bottom:.5rem">${b.image_url?`<div style="position:relative;width:100%;max-width:380px"><img src="${b.image_url}" style="width:100%;border-radius:8px;display:block"/><button type="button" class="x" data-rmpromo="${s.slot}" style="position:absolute;top:6px;right:6px;background:var(--red);color:#fff;border:none;border-radius:50%;width:24px;height:24px;cursor:pointer">×</button></div>`:''}</div>
          <button type="button" class="upload-color-btn" data-uppromo="${s.slot}">📷 Subir imagen</button>
          <input type="hidden" id="promoImageUrl-${s.slot}" value="${b.image_url||''}"/>
          <small style="display:block;color:var(--muted);font-size:.72rem;margin-top:.4rem">Recomendado: <strong>1600 × 500 px</strong> (horizontal), formato <strong>JPG o WebP</strong>, máx. 800 KB.</small>
        </div>
        <div class="field"><label>Color del texto</label><input type="color" id="promoTextColor-${s.slot}" value="${b.text_color||'#FFFFFF'}" style="width:60px;height:38px;padding:2px"/></div>
        <div class="field"><label>Oscurecer imagen (${b.overlay??35}%)</label><input type="range" min="0" max="80" id="promoOverlay-${s.slot}" value="${b.overlay??35}" style="width:100%"/><small style="color:var(--muted);font-size:.72rem">Más oscuro = texto más legible.</small></div>
        <div style="grid-column:1/-1"><button class="btn-save" data-savepromo="${s.slot}">Guardar este banner</button></div>
      </div>
    </div>`;
  }).join('');
  // Listeners
  cont.querySelectorAll('[data-uppromo]').forEach(el=>el.addEventListener('click',()=>{activePromoUpload=el.dataset.uppromo;$('hiddenPromoImageInput').click()}));
  cont.querySelectorAll('[data-rmpromo]').forEach(el=>el.addEventListener('click',()=>{const s=el.dataset.rmpromo;$(`promoImageUrl-${s}`).value='';$(`promoImgPreview-${s}`).innerHTML=''}));
  cont.querySelectorAll('[data-savepromo]').forEach(el=>el.addEventListener('click',()=>savePromo(el.dataset.savepromo)));
  // Guardar activación al instante (no se pierde al re-renderizar)
  cont.querySelectorAll('[data-toggleactive]').forEach(el=>el.addEventListener('change',async()=>{
    const slot=el.dataset.toggleactive;
    const checked=el.checked;
    const {error}=await supabase.from('promo_blocks').update({active:checked,updated_at:new Date().toISOString()}).eq('slot',slot);
    if(error){alert('No se pudo actualizar:\n\n'+error.message);el.checked=!checked;return}
    if(promos[slot])promos[slot].active=checked;
    showToast(checked?'Banner activado ✓ (recuerda reconstruir)':'Banner desactivado');
  }));
}
$('hiddenPromoImageInput').addEventListener('change',async e=>{
  const file=e.target.files[0]; if(!file||!activePromoUpload)return;
  const s=activePromoUpload;
  const path=`promos/${Date.now()}-${file.name.replace(/[^a-zA-Z0-9.-]/g,'_')}`;
  loading(true);
  const{error}=await supabase.storage.from('product-images').upload(path,file);
  loading(false);
  if(error){alert('Error: '+error.message);return}
  const{data:{publicUrl}}=supabase.storage.from('product-images').getPublicUrl(path);
  $(`promoImageUrl-${s}`).value=publicUrl;
  $(`promoImgPreview-${s}`).innerHTML=`<div style="position:relative;width:100%;max-width:380px"><img src="${publicUrl}" style="width:100%;border-radius:8px;display:block"/><button type="button" class="x" data-rmpromo="${s}" style="position:absolute;top:6px;right:6px;background:var(--red);color:#fff;border:none;border-radius:50%;width:24px;height:24px;cursor:pointer">×</button></div>`;
  $(`promoImgPreview-${s}`).querySelector('[data-rmpromo]').addEventListener('click',()=>{$(`promoImageUrl-${s}`).value='';$(`promoImgPreview-${s}`).innerHTML=''});
  e.target.value=''; activePromoUpload=null;
});
async function savePromo(slot){
  const d={
    slot,
    active:$(`promoActive-${slot}`).checked,
    eyebrow:$(`promoEyebrow-${slot}`).value.trim()||null,
    title:$(`promoTitle-${slot}`).value.trim()||null,
    subtitle:$(`promoSubtitle-${slot}`).value.trim()||null,
    cta_label:$(`promoCtaLabel-${slot}`).value.trim()||null,
    cta_href:$(`promoCtaHref-${slot}`).value.trim()||null,
    image_url:$(`promoImageUrl-${slot}`).value||null,
    text_color:$(`promoTextColor-${slot}`).value||'#FFFFFF',
    overlay:parseInt($(`promoOverlay-${slot}`).value)||0,
    updated_at:new Date().toISOString()
  };
  loading(true);
  const {error}=await supabase.from('promo_blocks').upsert(d,{onConflict:'slot'});
  loading(false);
  if(error){alert('No se pudo guardar:\n\n'+error.message);return}
  promos[slot]=d;
  showToast('Banner guardado ✓');
}

// SETTINGS
async function loadSettings() {
  const {data} = await supabase.from('site_settings').select('*');
  if (!data) return;
  const intro = data.find(s => s.key === 'home_intro');
  if (intro) {
    $('setHomeIntro').value = intro.value || '';
    updateIntroPreview();
  }
}

function updateIntroPreview() {
  const text = $('setHomeIntro').value;
  // Convertir **bold** a <strong>
  const html = text.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  $('introPreview').innerHTML = html || '<em style="color:var(--muted)">El texto aparecerá aquí mientras escribes...</em>';
}

$('setHomeIntro')?.addEventListener('input', updateIntroPreview);

$('settingsSaveBtn')?.addEventListener('click', async () => {
  loading(true);
  const value = $('setHomeIntro').value;
  await supabase.from('site_settings').upsert({key: 'home_intro', value, updated_at: new Date().toISOString()});
  loading(false);
  showToast('Configuración guardada ✓');
});

// Cargar settings al inicio
async function showAdminWithSettings(email) {
  await loadSettings();
}

checkAuth();
</script>
<script is:inline define:vars={{sbUrl:import.meta.env.PUBLIC_SUPABASE_URL,sbAnon:import.meta.env.PUBLIC_SUPABASE_ANON_KEY}}>
window.__SUPABASE_URL__=sbUrl;window.__SUPABASE_ANON__=sbAnon;
</script>
</body>
</html>
