---
// Panel admin - todo client-side
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta name="google-site-verification" content="MvuGJKvaZ75dfjRD7_7IIg9Ef_iYIQ8zd_9OceetAmg" />
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Admin | Procalzado</title>
<meta name="robots" content="noindex,nofollow"/>
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet"/>
<style>
:root{--red:#FF0000;--black:#000;--white:#fff;--grey:#F2F2F2;--grey2:#E5E5E5;--muted:#4A4A4A;--green:#25D366}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Barlow',sans-serif;background:var(--grey);color:var(--black);min-height:100vh}
.login-wrap{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:1rem}
.login-box{background:var(--white);border-radius:12px;padding:2.5rem;width:100%;max-width:380px;box-shadow:0 8px 32px rgba(0,0,0,.1);border-top:4px solid var(--red)}
.login-box h1{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;margin-bottom:.3rem;letter-spacing:.04em}
.login-box p{font-size:.85rem;color:var(--muted);margin-bottom:1.5rem}
.field{margin-bottom:1rem}
.field label{display:block;font-size:.75rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:.35rem}
.field input{width:100%;padding:.7rem .9rem;border:2px solid var(--grey2);border-radius:6px;font-size:.9rem;font-family:inherit;outline:none;transition:border-color .2s}
.field input:focus{border-color:var(--red)}
.btn{width:100%;padding:.8rem;background:var(--red);color:var(--white);border:none;border-radius:6px;font-size:.9rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;cursor:pointer;font-family:inherit;transition:opacity .2s}
.btn:hover{opacity:.9}.btn:disabled{opacity:.5;cursor:not-allowed}
.error-msg{background:#ffe6e6;color:#c00;padding:.6rem .8rem;border-radius:6px;font-size:.82rem;margin-bottom:1rem;display:none}
.admin{display:none}
.admin-header{background:var(--black);color:var(--white);padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;border-bottom:3px solid var(--red)}
.admin-header h2{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:.04em}
.admin-header .logout{background:none;border:1px solid rgba(255,255,255,.3);color:var(--white);padding:.4rem .8rem;border-radius:4px;cursor:pointer;font-size:.78rem;font-family:inherit}
.admin-header .logout:hover{border-color:var(--red);color:var(--red)}
.admin-nav{display:flex;background:var(--white);border-bottom:1px solid var(--grey2);padding:0 1.5rem;gap:.3rem;overflow-x:auto}
.tab{padding:.8rem 1.2rem;font-size:.82rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);cursor:pointer;border:none;background:none;border-bottom:3px solid transparent;font-family:inherit}
.tab:hover{color:var(--black)}.tab.active{color:var(--red);border-bottom-color:var(--red)}
.admin-body{max-width:1100px;margin:1.5rem auto;padding:0 1.5rem}
.toolbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;gap:1rem;flex-wrap:wrap}
.toolbar input{padding:.55rem .8rem;border:2px solid var(--grey2);border-radius:6px;font-size:.85rem;font-family:inherit;outline:none;width:220px}
.btn-add{display:flex;align-items:center;gap:.4rem;padding:.6rem 1.2rem;background:var(--red);color:var(--white);border:none;border-radius:6px;font-size:.82rem;font-weight:700;cursor:pointer;font-family:inherit;text-transform:uppercase;letter-spacing:.04em}
.btn-add:hover{opacity:.9}
.product-table{width:100%;background:var(--white);border-radius:8px;overflow-x:auto;box-shadow:0 2px 8px rgba(0,0,0,.06)}
.product-table table{width:100%;border-collapse:collapse}
.product-table th{text-align:left;padding:.7rem .9rem;font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);background:var(--grey);border-bottom:2px solid var(--grey2);white-space:nowrap}
.product-table td{padding:.7rem .9rem;font-size:.85rem;border-bottom:1px solid var(--grey2);vertical-align:middle}
.badge{display:inline-block;padding:.15rem .5rem;border-radius:3px;font-size:.7rem;font-weight:600;text-transform:uppercase}
.badge-active{background:#e6ffe6;color:#0a0}.badge-inactive{background:#ffe6e6;color:#c00}
.action-btn{padding:.35rem .7rem;border:1px solid var(--grey2);border-radius:4px;background:var(--white);cursor:pointer;font-size:.78rem;font-family:inherit;margin-right:.3rem;white-space:nowrap}
.action-btn:hover{border-color:var(--red);color:var(--red)}
.action-btn.edit{background:#f0f7ff;border-color:#cde;color:#369}
.action-btn.edit:hover{background:#ddeeff}
.action-btn.delete:hover{background:#ffe6e6}
.actions-cell{white-space:nowrap}
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;align-items:flex-start;justify-content:center;padding:2rem 1rem;overflow-y:auto}
.modal-bg.open{display:flex}
.form-modal{background:var(--white);border-radius:12px;width:100%;max-width:750px;max-height:90vh;overflow-y:auto;border-top:4px solid var(--red)}
.form-header{padding:1.2rem 1.5rem;border-bottom:1px solid var(--grey2);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--white);z-index:10}
.form-header h3{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:.04em}
.form-close{background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--muted);padding:.2rem .5rem}
.form-close:hover{color:var(--red)}
.form-body{padding:1.5rem}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.form-grid .full{grid-column:1/-1}
.form-body .field{margin-bottom:.8rem}
.form-body .field textarea{width:100%;padding:.6rem .8rem;border:2px solid var(--grey2);border-radius:6px;font-size:.85rem;font-family:inherit;outline:none;resize:vertical;min-height:80px}
.form-body .field textarea:focus{border-color:var(--red)}
.form-body .field select{width:100%;padding:.65rem .8rem;border:2px solid var(--grey2);border-radius:6px;font-size:.85rem;font-family:inherit;outline:none;background:var(--white)}
.form-body .field input[type="checkbox"]{width:auto;margin-right:.5rem}
.form-actions{padding:1rem 1.5rem;border-top:1px solid var(--grey2);display:flex;gap:.7rem;justify-content:flex-end;position:sticky;bottom:0;background:var(--white);z-index:10}
.btn-save{padding:.65rem 1.5rem;background:var(--red);color:var(--white);border:none;border-radius:6px;font-size:.85rem;font-weight:700;cursor:pointer;font-family:inherit}
.btn-cancel{padding:.65rem 1.5rem;background:var(--grey);color:var(--muted);border:none;border-radius:6px;font-size:.85rem;font-weight:600;cursor:pointer;font-family:inherit}
.section-label{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.04em;margin:1.5rem 0 .6rem;padding-bottom:.4rem;border-bottom:2px solid var(--grey2)}

/* TALLAS */
.sizes-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(70px,1fr));gap:.5rem;margin-top:.5rem}
.size-check{position:relative;display:flex;align-items:center;justify-content:center;padding:.5rem;border:2px solid var(--grey2);border-radius:6px;cursor:pointer;font-size:.85rem;font-weight:600;transition:all .15s;background:var(--white);user-select:none}
.size-check:hover{border-color:var(--red)}
.size-check input{display:none}
.size-check.checked{background:var(--red);border-color:var(--red);color:var(--white)}

/* CATEGORÍAS GRID */
.cats-checkbox-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:.5rem;margin-top:.3rem;padding:.7rem;background:var(--grey);border-radius:6px;border:1px solid var(--grey2)}
.cat-check{display:flex;align-items:center;gap:.4rem;padding:.5rem .7rem;border:2px solid var(--grey2);border-radius:5px;background:var(--white);cursor:pointer;font-size:.82rem;transition:all .15s;user-select:none}
.cat-check:hover{border-color:var(--red)}
.cat-check.checked{background:#fff5f5;border-color:var(--red);color:var(--red);font-weight:600}
.cat-check input{margin:0}
.cat-check.is-primary::after{content:'★';color:var(--red);margin-left:auto;font-size:.85rem}

/* GENEROS CHECKBOXES */
.genders-checkbox-row{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.3rem;padding:.7rem;background:var(--grey);border-radius:6px;border:1px solid var(--grey2)}
.gender-check{display:flex;align-items:center;gap:.4rem;padding:.5rem .9rem;border:2px solid var(--grey2);border-radius:5px;background:var(--white);cursor:pointer;font-size:.85rem;transition:all .15s;user-select:none}
.gender-check:hover{border-color:var(--red)}
.gender-check:has(input:checked){background:var(--red);border-color:var(--red);color:var(--white);font-weight:600}
.gender-check input{margin:0}

/* COLORES E IMÁGENES */
.color-block{border:2px solid var(--grey2);border-radius:8px;padding:1rem;margin-bottom:.8rem;background:var(--grey)}
.color-row1{display:flex;gap:.5rem;align-items:center;margin-bottom:.7rem}
.color-row1 input[type="text"]{flex:1;padding:.5rem .7rem;border:1px solid var(--grey2);border-radius:5px;font-size:.85rem;font-family:inherit;background:var(--white)}
.color-row1 input[type="color"]{width:40px;height:36px;padding:2px;border:1px solid var(--grey2);border-radius:5px;cursor:pointer;background:var(--white)}
.color-row1 .remove-color{padding:.4rem .6rem;background:none;border:1px solid var(--grey2);border-radius:5px;cursor:pointer;color:var(--muted);font-size:.85rem;background:var(--white)}
.color-row1 .remove-color:hover{color:var(--red);border-color:var(--red);background:#ffe6e6}
.color-row1 .dual-toggle{padding:.35rem .55rem;background:var(--white);border:1px solid var(--grey2);border-radius:5px;cursor:pointer;color:var(--muted);font-size:1rem;line-height:1;transition:all .15s}
.color-row1 .dual-toggle:hover{border-color:var(--red);color:var(--red)}
.color-row1 .dual-toggle.active{background:var(--black);border-color:var(--black);color:var(--white)}
.color-imgs{display:flex;flex-wrap:wrap;gap:.4rem;align-items:center}
.color-img-thumb{position:relative;width:70px!important;height:70px!important;max-width:70px!important;max-height:70px!important;border-radius:5px;overflow:hidden;border:2px solid var(--white);flex-shrink:0;display:block}
.color-img-thumb img{width:70px!important;height:70px!important;max-width:70px!important;max-height:70px!important;object-fit:cover;display:block}
.color-img-thumb .x{position:absolute;top:1px;right:1px;background:var(--red);color:var(--white);border:none;border-radius:50%;width:18px;height:18px;font-size:.65rem;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;z-index:2}
.upload-color-btn{padding:.45rem .8rem;background:var(--white);border:1px dashed var(--grey2);border-radius:5px;cursor:pointer;font-size:.78rem;font-family:inherit;color:var(--muted)}
.upload-color-btn:hover{border-color:var(--red);color:var(--red)}

.add-row-btn{padding:.5rem 1rem;background:var(--white);border:2px dashed var(--grey2);border-radius:6px;cursor:pointer;font-size:.82rem;font-family:inherit;color:var(--muted);margin-top:.4rem;width:100%}
.add-row-btn:hover{border-color:var(--red);color:var(--red);background:#fff5f5}

/* SPECS */
.spec-row{display:flex;gap:.5rem;margin-bottom:.4rem;align-items:center}
.spec-row input{flex:1;padding:.4rem .6rem;border:1px solid var(--grey2);border-radius:4px;font-size:.82rem;font-family:inherit}
.spec-row button{padding:.3rem .55rem;background:var(--white);border:1px solid var(--grey2);border-radius:4px;cursor:pointer;color:var(--muted);font-size:.9rem;line-height:1}
.spec-row button:hover{color:var(--red);border-color:var(--red)}

.toggle-switch{position:relative;display:inline-block;width:36px;height:20px;cursor:pointer}
.toggle-switch input{opacity:0;width:0;height:0}
.toggle-slider{position:absolute;inset:0;background:#ccc;border-radius:20px;transition:.2s}
.toggle-slider::before{content:'';position:absolute;height:14px;width:14px;left:3px;bottom:3px;background:white;border-radius:50%;transition:.2s}
.toggle-switch input:checked+.toggle-slider{background:var(--green)}
.toggle-switch input:checked+.toggle-slider::before{transform:translateX(16px)}

@media(max-width:640px){.form-grid{grid-template-columns:1fr}}
.draggable-row{cursor:default;transition:background .15s}
.draggable-row:hover{background:rgba(255,0,0,.03)!important}
.draggable-row td:first-child{cursor:grab}
.draggable-row td:first-child:active{cursor:grabbing}
.order-input:focus{outline:2px solid var(--red);border-color:var(--red)}
.spinner{display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:var(--white);border-radius:50%;animation:spin .6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-overlay{position:fixed;inset:0;background:rgba(255,255,255,.8);z-index:600;display:none;align-items:center;justify-content:center;font-size:1.1rem;font-weight:600;color:var(--muted)}
.loading-overlay.show{display:flex}
.toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(20px);background:var(--black);color:var(--white);padding:.65rem 1.3rem;border-radius:8px;font-size:.85rem;z-index:700;opacity:0;transition:all .3s;pointer-events:none;border-left:4px solid var(--green)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.search-select{position:relative}
.search-select-input{width:100%;padding:.55rem .7rem;border:1px solid var(--grey2);border-radius:6px;font-size:.88rem;font-family:inherit;box-sizing:border-box}
.search-select-input:focus{outline:none;border-color:var(--red)}
.search-select-list{position:absolute;top:100%;left:0;right:0;max-height:220px;overflow-y:auto;background:var(--white);border:1px solid var(--grey2);border-top:none;border-radius:0 0 6px 6px;z-index:50;display:none;box-shadow:0 4px 12px rgba(0,0,0,.1)}
.search-select.open .search-select-list{display:block}
.search-select-item{padding:.5rem .7rem;cursor:pointer;font-size:.85rem;border-bottom:1px solid #f2f2f2}
.search-select-item:hover,.search-select-item.highlighted{background:#fff5f5}
.search-select-item .ss-brand{font-size:.72rem;color:var(--muted)}
.search-select-empty{padding:.5rem .7rem;font-size:.82rem;color:var(--muted);font-style:italic}
</style>
</head>
<body>
<div class="loading-overlay" id="loadingOverlay">Cargando...</div>
<div class="toast" id="toast"></div>

<div class="login-wrap" id="loginWrap">
  <div class="login-box">
    <h1>PROCALZADO ADMIN</h1>
    <p>Panel de administración de productos</p>
    <div class="error-msg" id="loginError"></div>
    <div class="field"><label>Email</label><input type="email" id="loginEmail" placeholder="tu@email.com"/></div>
    <div class="field"><label>Contraseña</label><input type="password" id="loginPass" placeholder="••••••••"/></div>
    <button class="btn" id="loginBtn" type="button">Entrar</button>
  </div>
</div>

<div class="admin" id="adminPanel">
  <div class="admin-header">
    <h2>PROCALZADO — ADMIN</h2>
    <div style="display:flex;align-items:center;gap:.8rem">
      <span style="font-size:.78rem;color:rgba(255,255,255,.6)" id="adminEmail"></span>
      <a href="/" style="color:rgba(255,255,255,.6);font-size:.78rem;text-decoration:underline">Ver sitio</a>
      <button class="logout" id="logoutBtn">Cerrar sesión</button>
    </div>
  </div>
  <div class="admin-nav">
    <button class="tab active" data-tab="products">Productos</button>
    <button class="tab" data-tab="brands">Marcas</button>
    <button class="tab" data-tab="categories">Categorías</button>
    <button class="tab" data-tab="recommended">Recomendados</button>
    <button class="tab" data-tab="promos">Promos</button>
    <button class="tab" data-tab="promopage">Promoción</button>
    <button class="tab" data-tab="settings">Configuración</button>
  </div>
  <div class="admin-body">
    <div id="tab-products">
      <div class="toolbar"><input type="text" id="adminSearch" placeholder="Buscar productos..."/><button class="btn-add" id="addProductBtn">+ Nuevo producto</button></div>
      <div class="product-table"><table><thead><tr><th style="width:24px"></th><th style="width:60px">Img</th><th>Nombre</th><th>Marca</th><th>Categoría</th><th>Precio</th><th>Estado</th><th>Acciones</th></tr></thead><tbody id="productTableBody"></tbody></table></div>
    </div>
    <div id="tab-brands" style="display:none">
      <div class="toolbar"><span style="font-size:.85rem;color:var(--muted)">Gestiona las marcas (arrastra para reordenar)</span><button class="btn-add" id="addBrandBtn">+ Nueva marca</button></div>
      <div class="product-table"><table><thead><tr><th style="width:24px"></th><th>Nombre</th><th>Slug</th><th style="width:90px">Productos</th><th>Dist. Autorizado</th><th>Estado</th><th>Acciones</th></tr></thead><tbody id="brandTableBody"></tbody></table></div>
    </div>
    <div id="tab-categories" style="display:none">
      <div class="toolbar"><span style="font-size:.85rem;color:var(--muted)">Gestiona las categorías (arrastra para reordenar)</span><button class="btn-add" id="addCatBtn">+ Nueva categoría</button></div>
      <div class="product-table"><table><thead><tr><th style="width:24px"></th><th>Nombre</th><th>Slug</th><th style="width:130px">Menú (título/img)</th><th>Estado</th><th>Acciones</th></tr></thead><tbody id="catTableBody"></tbody></table></div>
    </div>

    <div id="tab-recommended" style="display:none">
      <div class="toolbar"><span style="font-size:.85rem;color:var(--muted)">Productos de la página <strong>Recomendaciones</strong>, cada uno con su motivo (arrastra para reordenar)</span><button class="btn-add" id="addRecBtn">+ Agregar recomendado</button></div>
      <div class="product-table"><table><thead><tr><th style="width:24px"></th><th style="width:60px">Img</th><th>Producto</th><th>Motivo</th><th>Acciones</th></tr></thead><tbody id="recTableBody"></tbody></table></div>
    </div>

    <div id="tab-promos" style="display:none">
      <p style="font-size:.85rem;color:var(--muted);margin-bottom:1rem">Banners promocionales de la página principal. El primero va debajo del inicio (productos destacados/ofertas) y el segundo en medio del catálogo (temporada: Día del Padre, Navidad, etc.). Puedes activarlos o desactivarlos para que no se muestren.</p>
      <div id="promosContainer"></div>
    </div>

    <div id="tab-promopage" style="display:none">
      <div style="background:var(--white);padding:1.3rem;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.06);margin-bottom:1.4rem;max-width:800px">
        <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:.04em;margin-bottom:.3rem">Página de Promoción</h3>
        <p style="font-size:.8rem;color:var(--muted);margin-bottom:1rem">Es la página a la que lleva el <strong>Banner 1</strong>. Personaliza su encabezado y abajo elige los productos.</p>
        <div class="form-grid">
          <div class="field"><label>Texto pequeño (arriba)</label><input type="text" id="promoPageEyebrow" placeholder="Ej: Ofertas"/></div>
          <div class="field"><label>Título de la página</label><input type="text" id="promoPageTitle" placeholder="Ej: Promoción Día del Padre"/></div>
          <div class="field full" style="grid-column:1/-1"><label>Descripción</label><textarea id="promoPageDesc" rows="2" placeholder="Texto que aparece bajo el título"></textarea></div>
        </div>
        <button class="btn-save" id="promoPageSaveBtn">Guardar encabezado</button>
      </div>
      <div class="toolbar"><span style="font-size:.85rem;color:var(--muted)">Productos de la página de Promoción, cada uno con su motivo (arrastra para reordenar)</span><button class="btn-add" id="addPromoProdBtn">+ Agregar producto</button></div>
      <div class="product-table"><table><thead><tr><th style="width:24px"></th><th style="width:60px">Img</th><th>Producto</th><th>Motivo</th><th>Acciones</th></tr></thead><tbody id="promoProdTableBody"></tbody></table></div>
    </div>

    <div id="tab-settings" style="display:none">
      <div style="background:var(--white);padding:1.5rem;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.06);max-width:800px">
        <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.04em;margin-bottom:.3rem">Textos del Sitio</h3>
        <p style="font-size:.82rem;color:var(--muted);margin-bottom:1.5rem">Aquí puedes personalizar los textos que aparecen en la página principal del sitio.</p>

        <div class="field" style="margin-bottom:1.5rem">
          <label style="display:block;font-size:.78rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);margin-bottom:.4rem">Texto de introducción del catálogo</label>
          <small style="display:block;color:var(--muted);font-size:.72rem;margin-bottom:.5rem">Aparece en la página principal, debajo del título "Todos los productos". Puedes usar **texto en negrita** poniendo dos asteriscos al inicio y al final de las palabras.</small>
          <textarea id="setHomeIntro" rows="4" style="width:100%;padding:.7rem .9rem;border:2px solid var(--grey2);border-radius:6px;font-size:.88rem;font-family:inherit;outline:none;resize:vertical;line-height:1.5" placeholder="Escribe aquí el texto que verán tus clientes..."></textarea>
        </div>

        <div style="background:var(--grey);padding:1rem;border-radius:6px;margin-bottom:1.5rem">
          <div style="font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:.5rem">Vista previa</div>
          <div id="introPreview" style="font-size:.88rem;color:var(--black);line-height:1.5"></div>
        </div>

        <button class="btn-save" id="settingsSaveBtn">Guardar cambios</button>
      </div>
    </div>
  </div>
</div>

<!-- PRODUCT MODAL -->
<div class="modal-bg" id="productModal">
  <div class="form-modal">
    <div class="form-header"><h3 id="formTitle">Nuevo Producto</h3><button class="form-close" id="formClose">&times;</button></div>
    <div class="form-body">
      <input type="hidden" id="productId"/>
      <div class="form-grid">
        <div class="field"><label>Nombre *</label><input type="text" id="pName" placeholder="Ej: Dakar"/></div>
        <div class="field"><label>Slug (URL) *</label><input type="text" id="pSlug" placeholder="auto-generado"/></div>
        <div class="field"><label>Marca</label><select id="pBrand"><option value="">Seleccionar...</option></select></div>
        <div class="field full"><label>Géneros (puedes elegir varios)</label>
          <div class="genders-checkbox-row">
            <label class="gender-check"><input type="checkbox" value="hombre" data-gender/> <span>Hombre</span></label>
            <label class="gender-check"><input type="checkbox" value="mujer" data-gender/> <span>Mujer</span></label>
            <label class="gender-check"><input type="checkbox" value="unisex" data-gender/> <span>Unisex</span></label>
            <label class="gender-check"><input type="checkbox" value="nino" data-gender/> <span>Niño</span></label>
            <label class="gender-check"><input type="checkbox" value="nina" data-gender/> <span>Niña</span></label>
          </div>
        </div>
        <div class="field full"><label>Categorías (puedes elegir varias)</label>
          <div class="cats-checkbox-grid" id="pCategoriesGrid"></div>
        </div>
        <div class="field"><label>Precio (COP)</label><input type="number" id="pPrice" placeholder="0"/></div>
        <div class="field"><label>Precio rebajado (oferta)</label><input type="number" id="pSalePrice" placeholder="Opcional"/><small style="color:var(--muted);font-size:.72rem">Si lo llenas, el precio normal se muestra tachado.</small></div>
        <div class="field"><label><input type="checkbox" id="pShowPrice"/> Mostrar precio en el sitio</label></div>
        <div class="field"><label><input type="checkbox" id="pFeatured"/> Producto destacado</label></div>
        <div class="field full"><label>Descripción corta (SEO)</label><textarea id="pShortDesc" rows="2" maxlength="160"></textarea></div>
        <div class="field full"><label>Descripción completa</label><textarea id="pDesc" rows="4"></textarea></div>
        <div class="field full">
          <label>Aviso especial (opcional)</label>
          <input type="text" id="pNotice" placeholder="Ej: Solo se vende por docena" maxlength="120"/>
          <small style="color:var(--muted);font-size:.72rem">Aparecerá destacado en la página del producto. Déjalo vacío si no aplica.</small>
        </div>
        <div class="field">
          <label>Tipo de aviso</label>
          <select id="pNoticeType">
            <option value="info">Información (azul)</option>
            <option value="warning">Importante (amarillo)</option>
            <option value="success">Positivo (verde)</option>
            <option value="danger">Atención (rojo)</option>
          </select>
        </div>
        <div class="field"></div>
      </div>

      <div class="section-label">Especificaciones Técnicas</div>
      <div id="specsContainer"></div>
      <button type="button" class="add-row-btn" id="addSpecBtn">+ Agregar especificación</button>

      <div class="section-label">Tallas Disponibles</div>
      <p style="font-size:.78rem;color:var(--muted);margin-bottom:.3rem">Marca las tallas que tienes disponibles.</p>
      <div class="sizes-grid" id="sizesGrid"></div>

      <div class="section-label">Colores e Imágenes</div>
      <p style="font-size:.78rem;color:var(--muted);margin-bottom:.5rem">Por cada color: nombre, color visual e imágenes específicas. Las imágenes del primer color se muestran por defecto.</p>
      <div id="colorsContainer"></div>
      <button type="button" class="add-row-btn" id="addColorBtn">+ Agregar color</button>
    </div>
    <div class="form-actions"><button class="btn-cancel" id="formCancelBtn">Cancelar</button><button class="btn-save" id="formSaveBtn">Guardar producto</button></div>
  </div>
</div>

