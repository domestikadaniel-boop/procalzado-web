// SAVE
$('formSaveBtn').addEventListener('click',async()=>{
  const name=$('pName').value.trim(),slug=$('pSlug').value.trim();
  if(!name||!slug){alert('Nombre y slug obligatorios');return}

  const specRows=$('specsContainer').querySelectorAll('.spec-row');const specs={};
  specRows.forEach(r=>{const i=r.querySelectorAll('input');const k=i[0].value.trim(),v=i[1].value.trim();if(k&&v)specs[k]=v});

  const selectedCatIds = getSelectedCategories();
  const primaryCatId = selectedCatIds[0] || null; // primera = principal

  const selectedGenders = Array.from(document.querySelectorAll('[data-gender]:checked')).map(i=>i.value);
  const pd={name,slug,brand_id:$('pBrand').value||null,category_id:primaryCatId,gender:selectedGenders[0]||null,genders:selectedGenders,price:$('pPrice').value?parseFloat($('pPrice').value):null,sale_price:$('pSalePrice').value?parseFloat($('pSalePrice').value):null,show_price:$('pShowPrice').checked,featured:$('pFeatured').checked,short_description:$('pShortDesc').value.trim()||null,description:$('pDesc').value.trim()||null,notice:$('pNotice').value.trim()||null,notice_type:$('pNoticeType').value||'info',specs,active:true};

  loading(true);let pid=$('productId').value;
  if(pid){const{error}=await supabase.from('products').update(pd).eq('id',pid);if(error){loading(false);alert('Error: '+error.message);return}}
  else{const{data,error}=await supabase.from('products').insert(pd).select().single();if(error){loading(false);alert('Error: '+error.message);return}pid=data.id}

  // CATEGORÍAS (múltiples)
  await supabase.from('product_categories').delete().eq('product_id', pid);
  if (selectedCatIds.length > 0) {
    await supabase.from('product_categories').insert(
      selectedCatIds.map((cid, idx) => ({
        product_id: pid,
        category_id: cid,
        is_primary: idx === 0
      }))
    );
  }

  // VARIANTS = combinación de cada color con cada talla
  await supabase.from('product_variants').delete().eq('product_id',pid);
  const sizes = getSelectedSizes();
  const validColors = formColors.filter(c=>c.name.trim());
  const variants=[];
  if (validColors.length === 0 && sizes.length === 0) {
    variants.push({product_id:pid,color:'Único',color_hex:'#000000',color_hex_2:null,size:'Única',stock:0,active:true});
  } else if (validColors.length === 0) {
    sizes.forEach(s => variants.push({product_id:pid,color:'Único',color_hex:'#000000',color_hex_2:null,size:s,stock:0,active:true}));
  } else if (sizes.length === 0) {
    validColors.forEach(c => variants.push({product_id:pid,color:c.name.trim(),color_hex:c.hex,color_hex_2:c.dual?c.hex2:null,size:'Única',stock:0,active:true}));
  } else {
    validColors.forEach(c => sizes.forEach(s => variants.push({product_id:pid,color:c.name.trim(),color_hex:c.hex,color_hex_2:c.dual?c.hex2:null,size:s,stock:0,active:true})));
  }
  if(variants.length)await supabase.from('product_variants').insert(variants);

  // IMAGES - asociadas a cada color
  // Borrar imágenes existentes que ya no están
  const allCurrentImgIds = formColors.flatMap(c=>(c.images||[]).filter(i=>i.existing).map(i=>i.id));
  const existingImgs = editingProduct?.product_images || [];
  const toDelete = existingImgs.filter(i => !allCurrentImgIds.includes(i.id));
  for (const img of toDelete) await supabase.from('product_images').delete().eq('id', img.id);

  // Insertar imágenes nuevas
  const newImgs = [];
  formColors.forEach((c,colorIdx) => {
    (c.images||[]).filter(i=>!i.existing).forEach((img,imgIdx) => {
      newImgs.push({
        product_id:pid,
        color:c.name.trim(),
        url:img.url,
        alt_text:`${name} - ${c.name}`,
        is_primary: colorIdx===0 && imgIdx===0 && !existingImgs.length,
        display_order: colorIdx*100 + imgIdx
      });
    });
  });
  if(newImgs.length)await supabase.from('product_images').insert(newImgs);

  // Si no hay primary, asignar la primera
  if (existingImgs.length && !existingImgs.some(i=>i.is_primary) && allCurrentImgIds.length) {
    await supabase.from('product_images').update({is_primary:true}).eq('id', allCurrentImgIds[0]);
  }

  $('productModal').classList.remove('open');await loadData();loading(false);showToast('Producto guardado ✓');
});

