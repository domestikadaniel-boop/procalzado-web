---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Recuperar Contraseña | Procalzado">

<main class="auth-page">
  <div class="auth-card">
    <h1>Recuperar Contraseña</h1>
    <p class="auth-sub">Ingresa tu correo y te enviaremos un enlace para restablecer tu contraseña.</p>

    <div class="auth-alert" id="authAlert" style="display:none"></div>

    <form id="forgotForm" novalidate>
      <label class="auth-label">
        Correo electrónico
        <input type="email" id="forgotEmail" required autocomplete="email" placeholder="tu@correo.com"/>
      </label>
      <div class="turnstile-wrap"><div class="cf-turnstile" data-sitekey="0x4AAAAAADnyx1B9r_FPdBeB" data-callback="onTurnstileSuccess" data-size="flexible" data-theme="light"></div></div>
      <button type="submit" class="auth-btn" id="forgotBtn">Enviar enlace</button>
    </form>

    <p class="auth-footer">
      <a href="/cuenta/login">Volver a iniciar sesión</a>
    </p>
  </div>
</main>

<style>
.auth-page{max-width:440px;margin:0 auto;padding:3rem clamp(1rem,4vw,2rem) 5rem;min-height:65vh;display:flex;align-items:flex-start;justify-content:center}
.auth-card{width:100%}
.auth-card h1{font-family:var(--fd);font-size:clamp(1.6rem,4vw,2rem);letter-spacing:.03em;margin-bottom:.3rem}
.auth-sub{color:var(--muted);font-size:.88rem;margin-bottom:2rem;line-height:1.5}
.auth-label{display:block;font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:1.2rem}
.auth-label input{display:block;width:100%;margin-top:.4rem;padding:.75rem .9rem;border:1.5px solid var(--grey2);border-radius:8px;font-family:var(--fb);font-size:.95rem;color:var(--black);background:var(--white);transition:border-color .15s;outline:none}
.auth-label input:focus{border-color:var(--red)}
.turnstile-wrap{display:flex;justify-content:center;width:100%;margin-bottom:1.2rem;overflow:hidden;border-radius:8px}
.turnstile-wrap .cf-turnstile{width:100%}
.auth-btn{display:flex;align-items:center;justify-content:center;gap:.5rem;width:100%;padding:.8rem;border:none;border-radius:8px;font-family:var(--fb);font-size:.9rem;font-weight:700;cursor:pointer;transition:background .15s,opacity .15s;text-transform:uppercase;letter-spacing:.05em;background:var(--black);color:var(--white)}
.auth-btn:hover{background:var(--red)}
.auth-btn:disabled{opacity:.5;pointer-events:none}
.auth-footer{text-align:center;margin-top:1.8rem;font-size:.85rem;color:var(--muted)}
.auth-footer a{color:var(--red);font-weight:600;text-decoration:none}
.auth-footer a:hover{text-decoration:underline}
.auth-alert{padding:.75rem 1rem;border-radius:8px;font-size:.85rem;margin-bottom:1.2rem;line-height:1.4}
.auth-alert.error{background:#FFF0F0;color:#CC0000;border:1px solid #FFCCCC}
.auth-alert.success{background:#F0FFF0;color:#006600;border:1px solid #CCFFCC}
</style>

<script is:inline>
(function waitSb(){
  if (!window.__sb) { setTimeout(waitSb, 100); return; }
  var sb = window.__sb;
  window.__turnstileToken = null;
  window.onTurnstileSuccess = function(token) { window.__turnstileToken = token; };

  var form = document.getElementById('forgotForm');
  var alert = document.getElementById('authAlert');
  var btn = document.getElementById('forgotBtn');

  function showAlert(msg, type) {
    alert.textContent = msg;
    alert.className = 'auth-alert ' + type;
    alert.style.display = 'block';
  }

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    alert.style.display = 'none';
    var email = document.getElementById('forgotEmail').value.trim();
    if (!email) { showAlert('Ingresa tu correo.', 'error'); return; }
    if (!window.__turnstileToken) { showAlert('Completa la verificación de seguridad.', 'error'); return; }

    btn.disabled = true;
    btn.textContent = 'Enviando...';

    var result = await sb.auth.resetPasswordForEmail(email, {
      redirectTo: window.location.origin + '/cuenta/restablecer',
      captchaToken: window.__turnstileToken
    });

    btn.disabled = false;
    btn.textContent = 'Enviar enlace';
    if (window.turnstile) window.turnstile.reset();
    window.__turnstileToken = null;

    if (result.error) {
      showAlert('No se pudo enviar el correo. Intenta de nuevo.', 'error');
      return;
    }

    showAlert('Si el correo existe, te enviamos un enlace para restablecer tu contraseña. Revisa tu bandeja de entrada (y spam).', 'success');
    form.reset();
  });
})();
</script>

</Layout>
