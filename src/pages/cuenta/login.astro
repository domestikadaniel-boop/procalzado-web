---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Iniciar Sesión | Procalzado">

<main class="auth-page">
  <div class="auth-card">
    <h1>Iniciar Sesión</h1>
    <p class="auth-sub">Ingresa a tu cuenta para comprar y ver tus pedidos.</p>

    <div class="auth-alert" id="authAlert" style="display:none"></div>

    <form id="loginForm" novalidate>
      <label class="auth-label">
        Correo electrónico
        <input type="email" id="loginEmail" required autocomplete="email" placeholder="tu@correo.com"/>
      </label>
      <label class="auth-label">
        Contraseña
        <input type="password" id="loginPass" required autocomplete="current-password" placeholder="Tu contraseña" minlength="6"/>
      </label>
      <p class="auth-forgot"><a href="/cuenta/olvide-password">¿Olvidaste tu contraseña?</a></p>
      <button type="submit" class="auth-btn" id="loginBtn">Ingresar</button>
    </form>

    <div class="auth-divider"><span>o</span></div>

    <button type="button" class="auth-btn auth-btn-google" id="googleBtn">
      <svg viewBox="0 0 24 24" width="20" height="20"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
      Continuar con Google
    </button>

    <p class="auth-footer">
      ¿No tienes cuenta? <a href="/cuenta/registro">Crear cuenta</a>
    </p>
  </div>
</main>

<style>
.auth-page{max-width:440px;margin:0 auto;padding:3rem clamp(1rem,4vw,2rem) 5rem;min-height:65vh;display:flex;align-items:flex-start;justify-content:center}
.auth-card{width:100%}
.auth-card h1{font-family:var(--fd);font-size:clamp(1.6rem,4vw,2rem);letter-spacing:.03em;margin-bottom:.3rem}
.auth-sub{color:var(--muted);font-size:.88rem;margin-bottom:2rem}
.auth-label{display:block;font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:1.2rem}
.auth-forgot{text-align:right;margin:-0.6rem 0 1.2rem;font-size:.8rem}
.auth-forgot a{color:var(--muted);text-decoration:none}
.auth-forgot a:hover{color:var(--red);text-decoration:underline}
.auth-label input{display:block;width:100%;margin-top:.4rem;padding:.75rem .9rem;border:1.5px solid var(--grey2);border-radius:8px;font-family:var(--fb);font-size:.95rem;color:var(--black);background:var(--white);transition:border-color .15s;outline:none}
.auth-label input:focus{border-color:var(--red)}
.auth-btn{display:flex;align-items:center;justify-content:center;gap:.5rem;width:100%;padding:.8rem;border:none;border-radius:8px;font-family:var(--fb);font-size:.9rem;font-weight:700;cursor:pointer;transition:background .15s,opacity .15s;text-transform:uppercase;letter-spacing:.05em}
.auth-btn:not(.auth-btn-google){background:var(--black);color:var(--white)}
.auth-btn:not(.auth-btn-google):hover{background:var(--red)}
.auth-btn:disabled{opacity:.5;pointer-events:none}
.auth-btn-google{background:var(--white);color:var(--black);border:1.5px solid var(--grey2);text-transform:none;font-weight:600;letter-spacing:0}
.auth-btn-google:hover{background:var(--grey)}
.auth-divider{display:flex;align-items:center;gap:1rem;margin:1.5rem 0;color:var(--muted);font-size:.78rem}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--grey2)}
.auth-footer{text-align:center;margin-top:1.8rem;font-size:.85rem;color:var(--muted)}
.auth-footer a{color:var(--red);font-weight:600;text-decoration:none}
.auth-footer a:hover{text-decoration:underline}
.auth-alert{padding:.75rem 1rem;border-radius:8px;font-size:.85rem;margin-bottom:1.2rem;line-height:1.4}
.auth-alert.error{background:#FFF0F0;color:#CC0000;border:1px solid #FFCCCC}
.auth-alert.success{background:#F0FFF0;color:#006600;border:1px solid #CCFFCC}
</style>

<script is:inline>
(function waitSb(){
  if (!window.__sb) { setTimeout(waitSb, 100); return; }
  var sb = window.__sb;

  sb.auth.getSession().then(function(r) {
    if (r.data && r.data.session && r.data.session.user) window.location.href = '/cuenta';
  });

  var form = document.getElementById('loginForm');
  var alert = document.getElementById('authAlert');
  var btn = document.getElementById('loginBtn');

  function showAlert(msg, type) {
    alert.textContent = msg;
    alert.className = 'auth-alert ' + type;
    alert.style.display = 'block';
  }

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    alert.style.display = 'none';
    var email = document.getElementById('loginEmail').value.trim();
    var pass = document.getElementById('loginPass').value;
    if (!email || !pass) { showAlert('Completa todos los campos.', 'error'); return; }

    btn.disabled = true;
    btn.textContent = 'Ingresando...';

    var result = await sb.auth.signInWithPassword({ email: email, password: pass });
    if (result.error) {
      btn.disabled = false;
      btn.textContent = 'Ingresar';
      var msg = result.error.message.indexOf('Invalid login') >= 0 ? 'Correo o contraseña incorrectos.' : result.error.message;
      showAlert(msg, 'error');
      return;
    }
    window.location.href = '/cuenta';
  });

  document.getElementById('googleBtn').addEventListener('click', async function() {
    await sb.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: window.location.origin + '/cuenta' }
    });
  });
})();
</script>

</Layout>
