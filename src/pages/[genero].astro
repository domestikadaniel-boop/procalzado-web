---
import Layout from '../layouts/Layout.astro';
import PromoBanner from '../components/PromoBanner.astro';
import { getProducts, getCategories, getPromoBlocks } from '../lib/supabase';
import type { Product, Category } from '../lib/supabase';

// Páginas estáticas: hombre, mujer, ninos
export function getStaticPaths() {
  return [
    { params: { genero: 'hombre' } },
    { params: { genero: 'mujer' } },
    { params: { genero: 'ninos' } },
  ];
}

const { genero } = Astro.params;

// Config por género
const GENDER_CONFIG: Record<string, { label: string; matches: string[]; title: string; sub: string }> = {
  hombre: {
    label: 'Hombre',
    matches: ['hombre', 'unisex'],
    title: 'Calzado para Hombre',
    sub: 'Botas, calzado de trabajo, zapatos y más para el día a día.',
  },
  mujer: {
    label: 'Mujer',
    matches: ['mujer', 'unisex'],
    title: 'Calzado para Mujer',
    sub: 'Botas, sandalias, zapatos y más con estilo y resistencia.',
  },
  ninos: {
    label: 'Niños',
    matches: ['nino', 'nina'],
    title: 'Calzado para Niños',
    sub: 'Resistente, cómodo y para toda ocasión.',
  },
};

const config = GENDER_CONFIG[genero!] || GENDER_CONFIG.hombre;

// Datos
const allProducts: Product[] = await getProducts();
const allCategories: Category[] = await getCategories();
const promos = await getPromoBlocks();
const parentCats = allCategories.filter(c => !c.parent_id);

// Filtrar productos por género
function productGenders(p: Product): string[] {
  return (p.genders && p.genders.length) ? p.genders : (p.gender ? [p.gender] : []);
}
const products = allProducts.filter(p => {
  const g = productGenders(p);
  return g.some(x => config.matches.includes(x));
});

// Datos de cada producto para render + filtrado por tarjeta
function productData(p: Product) {
  const brandName = p.brands?.name || '';
  const cats = (p.product_categories && p.product_categories.length)
    ? p.product_categories.map(pc => pc.categories).filter(Boolean) as Category[]
    : (p.categories ? [p.categories as Category] : []);
  const primaryCat = (p.product_categories?.find(pc => pc.is_primary)?.categories as Category) || cats[0] || null;
  const catSlugs = cats.map(c => c.slug);
  const primaryImg = p.product_images?.find(i => i.is_primary) || p.product_images?.[0];
  const secondImg = p.product_images?.filter(i => i !== primaryImg)?.[0] || null;
  const variants = (p.product_variants || []).filter(v => v.active);
  const sizes = [...new Set(variants.map(v => v.size).filter(Boolean))];
  const colors = [...new Set(variants.map(v => v.color).filter(c => c && c !== 'Único'))];
  const colorHexes = variants.reduce((acc, v) => {
    if (v.color && v.color !== 'Único' && v.color_hex) acc[v.color] = v.color_hex;
    return acc;
  }, {} as Record<string, string>);

  return {
    slug: p.slug, name: p.name, brandName, brandSlug: p.brands?.slug || '', catSlugs,
    primaryImg, secondImg, featured: p.featured,
    price: p.price, salePrice: p.sale_price, showPrice: p.show_price,
    catName: primaryCat?.name || '',
    shortDesc: p.short_description || '',
    effectivePrice: p.sale_price || p.price || 0,
    sizes, colors,
  };
}
const items = products.map(productData);

// Datos para filtros
const uniqueBrands = [...new Map(items.filter(i => i.brandName).map(i => [i.brandSlug, i.brandName])).entries()]
  .map(([slug, name]) => ({ slug, name }))
  .sort((a, b) => a.name.localeCompare(b.name));

const allSizes = [...new Set(items.flatMap(i => i.sizes))].sort((a, b) => {
  const na = parseFloat(a), nb = parseFloat(b);
  return isNaN(na) || isNaN(nb) ? a.localeCompare(b) : na - nb;
});

const allColors = [...new Set(items.flatMap(i => i.colors))].sort();

// Color hex map for colored squares
const colorHexMap: Record<string, string> = {};
products.forEach(p => {
  (p.product_variants || []).forEach(v => {
    if (v.color && v.color !== 'Único' && v.color_hex && !colorHexMap[v.color]) {
      colorHexMap[v.color] = v.color_hex;
    }
  });
});

// Categorías a mostrar: si padre tiene subs → solo subs; si no → el padre
const subcatsByParent: Record<string, Category[]> = {};
allCategories.filter(c => c.parent_id).forEach(c => {
  if (!subcatsByParent[c.parent_id!]) subcatsByParent[c.parent_id!] = [];
  subcatsByParent[c.parent_id!].push(c);
});

const displayCats: Category[] = [];
parentCats.forEach(parent => {
  const subs = subcatsByParent[parent.id];
  if (subs && subs.length > 0) {
    subs.forEach(s => displayCats.push(s));
  } else {
    displayCats.push(parent);
  }
});

// Filtrar solo las que tienen productos en este género
const genreCats = displayCats.filter(cat => {
  return items.some(it => it.catSlugs.includes(cat.slug));
});

const pageTitle = `${config.title} | Procalzado`;
const pageDesc = `${config.sub} Procalzado, distribuidor autorizado con envíos a todo Colombia.`;
---

<Layout title={pageTitle} description={pageDesc}>

<!-- ENCABEZADO DE GÉNERO -->
<section class="gender-hero" style={`background-image:url(/portada_${genero}.jpg)`}>
  <div class="gender-hero-inner">
    <span class="gender-hero-tag">{config.label}</span>
    <h1>{config.title}</h1>
    <p>{config.sub}</p>
  </div>
</section>

{promos.hero && promos.hero.active && (
  <div class="promo-wrap-page"><PromoBanner block={promos.hero} /></div>
)}

<!-- CATEGORÍAS + FILTROS -->
<div class="filter-section">
  {genreCats.length > 0 && (
    <div class="pills-wrap">
      <button type="button" class="pills-arrow pills-arrow-left" aria-label="Anterior">&#8249;</button>
      <div class="cat-pills-scroll">
        {genreCats.map(cat => (
          <button type="button" class="cat-pill" data-cat-slugs={cat.slug}>
            {cat.name}
          </button>
        ))}
      </div>
      <button type="button" class="pills-arrow pills-arrow-right" aria-label="Siguiente">&#8250;</button>
    </div>
  )}
  <div class="filter-bar-row">
    <div class="filter-dropdowns">
      <div class="filter-dropdown">
        <button type="button" class="filter-btn" data-menu="priceMenu">Precio <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></button>
        <div class="filter-menu filter-menu-price" id="priceMenu">
          <div class="price-inputs">
            <div class="price-field">
              <label>Mínimo</label>
              <input type="number" id="priceMin" placeholder="0" min="0" step="1000"/>
            </div>
            <div class="price-field">
              <label>Máximo</label>
              <input type="number" id="priceMax" placeholder="999999" min="0" step="1000"/>
            </div>
          </div>
          <button type="button" class="price-apply" id="priceApply">Aplicar</button>
          <button type="button" class="price-clear" id="priceClear">Limpiar</button>
        </div>
      </div>
      {allSizes.length > 0 && (
        <div class="filter-dropdown">
          <button type="button" class="filter-btn" data-menu="sizeMenu">Talla <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></button>
          <div class="filter-menu" id="sizeMenu">
            <button type="button" class="filter-option active" data-size="">Todas</button>
            {allSizes.map(s => (
              <button type="button" class="filter-option" data-size={s}>{s}</button>
            ))}
          </div>
        </div>
      )}
      <div class="filter-dropdown">
        <button type="button" class="filter-btn" data-menu="brandMenu">Marca <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></button>
        <div class="filter-menu" id="brandMenu">
          <button type="button" class="filter-option active" data-brand="">Todas</button>
          {uniqueBrands.map(b => (
            <button type="button" class="filter-option" data-brand={b.slug}>{b.name}</button>
          ))}
        </div>
      </div>
      {allColors.length > 0 && (
        <div class="filter-dropdown">
          <button type="button" class="filter-btn" data-menu="colorMenu">Color <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></button>
          <div class="filter-menu filter-menu-colors" id="colorMenu">
            <button type="button" class="filter-option active" data-color="">Todos</button>
            {allColors.map(c => (
              <button type="button" class="filter-color-opt" data-color={c}>
                <span class="color-swatch" style={`background:${colorHexMap[c] || '#999'}`}></span>
                {c}
              </button>
            ))}
          </div>
        </div>
      )}
    </div>
    <div class="filter-sort">
      <span class="filter-sort-label">Ordenar:</span>
      <select id="sortSelect">
        <option value="default">Relevancia</option>
        <option value="price-asc">Menor precio</option>
        <option value="price-desc">Mayor precio</option>
        <option value="name-asc">Nombre A-Z</option>
      </select>
    </div>
  </div>

  <!-- Mobile: Filtros + Ordenar -->
  <div class="mobile-filter-row">
    <button type="button" class="mobile-filter-btn" id="mobileFilterBtn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/><circle cx="6" cy="6" r="2" fill="currentColor"/><circle cx="10" cy="12" r="2" fill="currentColor"/><circle cx="6" cy="18" r="2" fill="currentColor"/></svg>
      Filtros
    </button>
    <div class="filter-sort">
      <span class="filter-sort-label">Ordenar:</span>
      <select id="sortSelectMobile">
        <option value="default">Relevancia</option>
        <option value="price-asc">Menor precio</option>
        <option value="price-desc">Mayor precio</option>
        <option value="name-asc">Nombre A-Z</option>
      </select>
    </div>
  </div>
</div>

<div class="mobile-filter-overlay" id="mobileFilterOverlay"></div>
<div class="mobile-filter-panel" id="mobileFilterPanel">
  <div class="mobile-fp-header">
    <h3>Filtros</h3>
    <button type="button" class="mobile-fp-close" id="mobileFilterClose">&times;</button>
  </div>
  <div class="mobile-fp-section">
    <h4>Precio</h4>
    <div class="mobile-fp-price">
      <input type="number" id="mPriceMin" placeholder="Min" min="0" step="1000"/>
      <span>—</span>
      <input type="number" id="mPriceMax" placeholder="Max" min="0" step="1000"/>
    </div>
  </div>
  {allSizes.length > 0 && (
    <div class="mobile-fp-section">
      <h4>Talla</h4>
      <div class="mobile-fp-options">
        <button type="button" class="mobile-fp-opt active" data-msize="">Todas</button>
        {allSizes.map(s => (
          <button type="button" class="mobile-fp-opt" data-msize={s}>{s}</button>
        ))}
      </div>
    </div>
  )}
  <div class="mobile-fp-section">
    <h4>Marca</h4>
    <div class="mobile-fp-options">
      <button type="button" class="mobile-fp-opt active" data-mbrand="">Todas</button>
      {uniqueBrands.map(b => (
        <button type="button" class="mobile-fp-opt" data-mbrand={b.slug}>{b.name}</button>
      ))}
    </div>
  </div>
  {allColors.length > 0 && (
    <div class="mobile-fp-section">
      <h4>Color</h4>
      <div class="mobile-fp-options">
        <button type="button" class="mobile-fp-opt active" data-mcolor="">Todos</button>
        {allColors.map(c => (
          <button type="button" class="mobile-fp-color" data-mcolor={c}>
            <span class="color-swatch" style={`background:${colorHexMap[c] || '#999'}`}></span>
            {c}
          </button>
        ))}
      </div>
    </div>
  )}
  <button type="button" class="mobile-fp-apply" id="mobileFilterApply">Aplicar filtros</button>
</div>

<!-- PRODUCTOS DEL GÉNERO -->

<main class="products-section" id="main-content">
  <div class="section-header">
    <h2 class="section-title">Productos <span class="red">{config.label}</span></h2>
    <span class="section-count" id="resultCount">{items.length} productos</span>
  </div>

  <div class="active-cat-banner" id="gActiveBanner" style="display:none">
    <span>Mostrando: <strong id="gActiveLabel"></strong></span>
    <button type="button" id="gActiveClear">Ver todo &times;</button>
  </div>

  <div class="product-grid" id="productGrid">
    {items.map((it, i) => {
      return (
        <>
          <a href={`/productos/${it.slug}`} class="card" data-cats={it.catSlugs.join('|')} data-brand={it.brandSlug} data-price={it.effectivePrice} data-sizes={it.sizes.join('|')} data-colors={it.colors.join('|')} style={`animation-delay:${Math.min(i * 0.03, 0.4)}s`}>
            {it.featured && (
              <span class="card-badge-featured">
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                Destacado
              </span>
            )}
            {it.salePrice && it.showPrice && it.price && (
              <span class="card-badge-sale">-{Math.round((1 - it.salePrice / it.price) * 100)}%</span>
            )}
            <div class="card-img">
              {it.primaryImg
                ? <>
                    <img src={it.primaryImg.url} alt={`${it.brandName} ${it.name}`} width="240" height="240" loading={i < 8 ? 'eager' : 'lazy'} class={it.secondImg ? 'card-img-main' : ''}/>
                    {it.secondImg && <img src={it.secondImg.url} alt={`${it.brandName} ${it.name}`} width="240" height="240" loading="lazy" class="card-img-hover"/>}
                  </>
                : <span>👢</span>}
            </div>
            <div class="card-body">
              {it.brandName && <div class="card-brand">{it.brandName}</div>}
              <div class="card-name">{it.name}</div>
              {it.shortDesc && <div class="card-desc">{it.shortDesc.length > 60 ? it.shortDesc.slice(0, 60) + '...' : it.shortDesc}</div>}
              {it.showPrice && it.price ? (
                it.salePrice ? (
                  <div class="card-price-row"><span class="card-price-old">${Number(it.price).toLocaleString('es-CO')}</span><span class="card-price card-price-sale">${Number(it.salePrice).toLocaleString('es-CO')}</span></div>
                ) : (
                  <div class="card-price">${Number(it.price).toLocaleString('es-CO')}</div>
                )
              ) : (
                <div class="card-price-note" style="margin-top:auto">Precio a consultar</div>
              )}
            </div>
          </a>
        </>
      );
    })}
  </div>

  {promos.mid && promos.mid.active && (
    <div class="promo-bottom"><PromoBanner block={promos.mid} /></div>
  )}

  <div class="empty" id="emptyState" style="display:none">
    <strong>Sin productos</strong>
    <p>Aún no hay productos en esta categoría.</p>
  </div>
</main>

<style>
.gender-hero{background:var(--black);color:var(--white);padding:clamp(2rem,5vw,3.5rem) clamp(1rem,4vw,3rem);padding-top:calc(var(--header-h) + clamp(2rem,5vw,3.5rem));margin-top:calc(-1 * var(--header-h));background-size:cover;background-position:center;background-repeat:no-repeat;position:relative}
.gender-hero-inner{max-width:var(--max-w);margin:0 auto}
.promo-wrap-page{max-width:var(--max-w);margin:0 auto;padding:1.5rem clamp(1rem,4vw,3rem) 0}
.promo-bottom{margin:2rem 0 0}
.promo-grid-full{grid-column:1/-1;margin:1rem 0}
.gender-hero-tag{display:inline-block;background:var(--red);color:var(--white);font-size:.68rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;padding:.28rem .7rem;border-radius:2px;margin-bottom:.8rem}
.gender-hero h1{font-family:var(--fd);font-size:clamp(2.2rem,5vw,3.4rem);letter-spacing:.03em;line-height:1}
.gender-hero p{font-size:.95rem;font-weight:300;color:rgba(255,255,255,.85);margin-top:.6rem;max-width:540px}

.filter-section{max-width:var(--max-w);margin:0 auto;padding:1rem clamp(1rem,4vw,3rem) 0;position:sticky;top:var(--header-h);z-index:200;background:var(--white);border-bottom:1px solid var(--grey2)}
.pills-wrap{position:relative;display:flex;align-items:center;gap:.3rem;padding-bottom:.6rem}
.pills-arrow{width:28px;height:28px;border-radius:50%;border:1px solid var(--grey2);background:var(--white);color:var(--black);font-size:1.2rem;line-height:1;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:all .15s}
.pills-arrow:hover{border-color:var(--black);background:var(--black);color:var(--white)}
.cat-pills-scroll{display:flex;gap:.5rem;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;scroll-behavior:smooth;flex:1;min-width:0}
.cat-pills-scroll::-webkit-scrollbar{display:none}
.cat-pill{padding:.45rem 1rem;border:1.5px solid var(--grey2);border-radius:20px;background:var(--white);font-family:var(--fb);font-size:.82rem;font-weight:600;cursor:pointer;transition:all .18s;color:var(--black);white-space:nowrap;flex-shrink:0}
.cat-pill:hover{border-color:var(--black)}
.cat-pill.active{background:var(--black);border-color:var(--black);color:var(--white)}
.filter-bar-row{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding-top:.4rem;padding-bottom:.5rem}
.filter-dropdowns{display:flex;gap:.1rem}
.filter-dropdown{position:relative}
.filter-btn{display:flex;align-items:center;gap:.3rem;padding:.4rem .7rem;background:none;border:none;font-family:var(--fb);font-size:.85rem;font-weight:600;color:var(--black);cursor:pointer;transition:color .15s;white-space:nowrap}
.filter-btn:hover,.filter-btn.open{color:var(--red)}
.filter-btn svg{width:14px;height:14px;transition:transform .2s}
.filter-btn.open svg{transform:rotate(180deg)}
.filter-btn.has-value{color:var(--red)}
.filter-menu{display:none;position:absolute;top:calc(100% + 4px);left:0;background:var(--white);border:1px solid var(--grey2);border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.12);min-width:180px;max-height:280px;overflow-y:auto;z-index:10;padding:.3rem 0}
.filter-menu.open{display:block}
.filter-option{display:block;width:100%;text-align:left;padding:.5rem .9rem;background:none;border:none;font-family:var(--fb);font-size:.82rem;color:var(--black);cursor:pointer;transition:background .1s}
.filter-option:hover{background:var(--grey)}
.filter-option.active{color:var(--red);font-weight:700}
.filter-sort{display:flex;align-items:center;gap:.4rem;flex-shrink:0}
.filter-sort-label{font-size:.78rem;color:var(--muted);white-space:nowrap}
.filter-sort select{padding:.35rem .6rem;border:1px solid var(--grey2);border-radius:6px;font-family:var(--fb);font-size:.82rem;background:var(--white);cursor:pointer}

.active-cat-banner{align-items:center;justify-content:space-between;gap:1rem;background:#fff5f5;border:1px solid var(--red);border-radius:8px;padding:.7rem 1rem;margin-bottom:1.2rem;font-size:.9rem}
.active-cat-banner strong{text-transform:uppercase;letter-spacing:.03em}
.active-cat-banner button{background:var(--red);color:var(--white);border:none;border-radius:5px;padding:.4rem .8rem;font-size:.8rem;font-weight:600;cursor:pointer;font-family:inherit;white-space:nowrap}
.active-cat-banner button:hover{background:#cc0000}

.card-badge-sale{position:absolute;top:.6rem;right:.6rem;background:var(--red);color:var(--white);font-family:var(--fb);font-weight:700;font-size:.75rem;padding:.22rem .5rem;border-radius:4px;z-index:5}
.card-desc{font-size:.75rem;color:var(--muted);line-height:1.35;margin-bottom:.4rem}
.card-price-row{display:flex;align-items:baseline;gap:.5rem;flex-wrap:wrap}
.card-price-old{font-size:.85rem;color:var(--muted);text-decoration:line-through}
.card-price-sale{color:var(--red)}
.filter-menu-price{padding:.8rem;min-width:220px}
.price-inputs{display:flex;gap:.5rem;margin-bottom:.6rem}
.price-field{flex:1}
.price-field label{display:block;font-size:.68rem;font-weight:600;color:var(--muted);margin-bottom:.2rem;text-transform:uppercase;letter-spacing:.05em}
.price-field input{width:100%;padding:.4rem .5rem;border:1px solid var(--grey2);border-radius:5px;font-family:var(--fb);font-size:.85rem}
.price-apply{width:100%;padding:.45rem;background:var(--black);color:var(--white);border:none;border-radius:5px;font-family:var(--fb);font-size:.8rem;font-weight:700;cursor:pointer;margin-bottom:.3rem;text-transform:uppercase;letter-spacing:.03em}
.price-apply:hover{background:var(--red)}
.price-clear{width:100%;padding:.3rem;background:none;border:none;font-family:var(--fb);font-size:.75rem;color:var(--muted);cursor:pointer}
.price-clear:hover{color:var(--red)}
.filter-menu-colors{flex-wrap:wrap;gap:.2rem;padding:.5rem;min-width:220px;max-width:300px}
.filter-menu-colors.open{display:flex}
.filter-menu-colors .filter-option{width:100%;padding:.4rem .7rem}
.filter-color-opt{display:flex;align-items:center;gap:.5rem;width:100%;text-align:left;padding:.45rem .7rem;background:none;border:none;font-family:var(--fb);font-size:.82rem;color:var(--black);cursor:pointer;transition:background .1s;border-radius:4px}
.filter-color-opt:hover{background:var(--grey)}
.filter-color-opt.active{font-weight:700;color:var(--red)}
.color-swatch{width:18px;height:18px;border-radius:4px;border:1px solid rgba(0,0,0,.15);flex-shrink:0}

/* Mobile: collapse filters into one button */
.mobile-filter-btn{display:none}
.mobile-filter-overlay{display:none}
.mobile-filter-panel{display:none}
@media(max-width:640px){
  .filter-section{padding:.6rem .8rem 0}
  .filter-bar-row{display:none}
  .mobile-filter-row{display:flex;align-items:center;justify-content:space-between;padding:.4rem 0 .5rem}
  .mobile-filter-btn{display:flex;align-items:center;gap:.4rem;background:none;border:1.5px solid var(--grey2);border-radius:8px;padding:.5rem 1rem;font-family:var(--fb);font-size:.85rem;font-weight:600;cursor:pointer;color:var(--black)}
  .mobile-filter-btn svg{width:16px;height:16px}
  .mobile-filter-btn.has-filters{border-color:var(--red);color:var(--red)}
  .mobile-filter-overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:5000;opacity:0;visibility:hidden;transition:opacity .2s}
  .mobile-filter-overlay.open{display:block;opacity:1;visibility:visible}
  .mobile-filter-panel{position:fixed;bottom:0;left:0;right:0;background:var(--white);z-index:5001;border-radius:16px 16px 0 0;max-height:80vh;overflow-y:auto;transform:translateY(100%);transition:transform .28s ease;padding:0 0 env(safe-area-inset-bottom)}
  .mobile-filter-panel.open{display:block;transform:translateY(0)}
  .mobile-fp-header{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.2rem;border-bottom:1px solid var(--grey2)}
  .mobile-fp-header h3{font-family:var(--fd);font-size:1.3rem}
  .mobile-fp-close{background:none;border:none;font-size:1.6rem;cursor:pointer;width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:50%;color:var(--black)}
  .mobile-fp-section{padding:.8rem 1.2rem;border-bottom:1px solid var(--grey)}
  .mobile-fp-section h4{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:.5rem}
  .mobile-fp-options{display:flex;flex-wrap:wrap;gap:.4rem}
  .mobile-fp-opt{padding:.4rem .8rem;border:1px solid var(--grey2);border-radius:6px;font-size:.82rem;background:var(--white);cursor:pointer;font-family:var(--fb)}
  .mobile-fp-opt.active{background:var(--black);color:var(--white);border-color:var(--black)}
  .mobile-fp-color{display:flex;align-items:center;gap:.4rem;padding:.4rem .7rem;border:1px solid var(--grey2);border-radius:6px;font-size:.82rem;background:var(--white);cursor:pointer;font-family:var(--fb)}
  .mobile-fp-color.active{border-color:var(--red);font-weight:700;color:var(--red)}
  .mobile-fp-color .color-swatch{width:16px;height:16px;border-radius:3px;border:1px solid rgba(0,0,0,.15)}
  .mobile-fp-price{display:flex;gap:.5rem;align-items:center}
  .mobile-fp-price input{flex:1;padding:.45rem .5rem;border:1px solid var(--grey2);border-radius:6px;font-size:.85rem;font-family:var(--fb)}
  .mobile-fp-apply{display:block;margin:1rem 1.2rem;padding:.75rem;background:var(--black);color:var(--white);border:none;border-radius:8px;font-family:var(--fb);font-size:.9rem;font-weight:700;text-transform:uppercase;cursor:pointer;width:calc(100% - 2.4rem)}
  .mobile-fp-apply:hover{background:var(--red)}
  .cat-pill{font-size:.78rem;padding:.4rem .9rem}
  .pills-arrow{display:none}
  .filter-menu{position:fixed;left:5%;right:5%;top:auto;bottom:0;max-height:50vh;border-radius:12px 12px 0 0;box-shadow:0 -4px 20px rgba(0,0,0,.15)}
}
@media(min-width:641px){.mobile-filter-row{display:none}}
</style>

<script is:inline>
(function () {
  const grid = document.getElementById('productGrid');
  if (!grid) return;
  const cards = Array.from(grid.querySelectorAll('.card'));
  const pills = Array.from(document.querySelectorAll('.cat-pill'));
  const resultCount = document.getElementById('resultCount');
  const emptyState = document.getElementById('emptyState');
  const banner = document.getElementById('gActiveBanner');
  const bannerLabel = document.getElementById('gActiveLabel');

  let filters = { cats: [], brand: '', priceMin: 0, priceMax: Infinity, size: '', color: '' };

  function apply() {
    let visible = 0;
    // First pass: determine which products match category filter only
    const catMatchProducts = [];
    cards.forEach(card => {
      const cc = (card.dataset.cats || '').split('|').filter(Boolean);
      const matchesCat = !filters.cats.length || cc.some(c => filters.cats.includes(c));
      if (matchesCat) catMatchProducts.push(card);
    });
    // Update available filter options based on category-matched products
    updateFilterOptions(catMatchProducts);
    // Second pass: apply all filters
    cards.forEach(card => {
      const cc = (card.dataset.cats || '').split('|').filter(Boolean);
      const cb = card.dataset.brand || '';
      const cp = parseFloat(card.dataset.price) || 0;
      const cs = (card.dataset.sizes || '').split('|').filter(Boolean);
      const ccol = (card.dataset.colors || '').split('|').filter(Boolean);
      let show = true;
      if (filters.cats.length && !cc.some(c => filters.cats.includes(c))) show = false;
      if (filters.brand && cb !== filters.brand) show = false;
      if (filters.size && !cs.includes(filters.size)) show = false;
      if (filters.color && !ccol.includes(filters.color)) show = false;
      if (cp < filters.priceMin || cp > filters.priceMax) show = false;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (resultCount) resultCount.textContent = visible + (visible === 1 ? ' producto' : ' productos');
    if (emptyState) emptyState.style.display = visible === 0 ? 'block' : 'none';
  }

  function updateFilterOptions(matchedCards) {
    const availSizes = new Set();
    const availBrands = new Set();
    const availColors = new Set();
    matchedCards.forEach(card => {
      (card.dataset.sizes || '').split('|').filter(Boolean).forEach(s => availSizes.add(s));
      if (card.dataset.brand) availBrands.add(card.dataset.brand);
      (card.dataset.colors || '').split('|').filter(Boolean).forEach(c => availColors.add(c));
    });
    // Desktop filters
    document.querySelectorAll('.filter-option[data-size]').forEach(o => {
      if (!o.dataset.size) { o.style.display = ''; return; } // "Todas"
      o.style.display = availSizes.has(o.dataset.size) ? '' : 'none';
    });
    document.querySelectorAll('.filter-option[data-brand]').forEach(o => {
      if (!o.dataset.brand) { o.style.display = ''; return; }
      o.style.display = availBrands.has(o.dataset.brand) ? '' : 'none';
    });
    document.querySelectorAll('.filter-option[data-color],.filter-color-opt').forEach(o => {
      if (!o.dataset.color) { o.style.display = ''; return; }
      o.style.display = availColors.has(o.dataset.color) ? '' : 'none';
    });
    // Mobile filters
    document.querySelectorAll('[data-msize]').forEach(o => {
      if (!o.dataset.msize) { o.style.display = ''; return; }
      o.style.display = availSizes.has(o.dataset.msize) ? '' : 'none';
    });
    document.querySelectorAll('[data-mbrand]').forEach(o => {
      if (!o.dataset.mbrand) { o.style.display = ''; return; }
      o.style.display = availBrands.has(o.dataset.mbrand) ? '' : 'none';
    });
    document.querySelectorAll('[data-mcolor]').forEach(o => {
      if (!o.dataset.mcolor) { o.style.display = ''; return; }
      o.style.display = availColors.has(o.dataset.mcolor) ? '' : 'none';
    });
    // Clear filters that no longer have valid options
    if (filters.size && !availSizes.has(filters.size)) {
      filters.size = '';
      const sizeBtn = document.querySelector('[data-menu="sizeMenu"]');
      if (sizeBtn) { sizeBtn.classList.remove('has-value'); sizeBtn.childNodes[0].textContent = 'Talla '; }
      document.querySelectorAll('.filter-option[data-size]').forEach(o => o.classList.remove('active'));
      const allOpt = document.querySelector('.filter-option[data-size=""]');
      if (allOpt) allOpt.classList.add('active');
    }
    if (filters.brand && !availBrands.has(filters.brand)) {
      filters.brand = '';
      const brandBtn = document.querySelector('[data-menu="brandMenu"]');
      if (brandBtn) { brandBtn.classList.remove('has-value'); brandBtn.childNodes[0].textContent = 'Marca '; }
      document.querySelectorAll('.filter-option[data-brand]').forEach(o => o.classList.remove('active'));
      const allOpt = document.querySelector('.filter-option[data-brand=""]');
      if (allOpt) allOpt.classList.add('active');
    }
    if (filters.color && !availColors.has(filters.color)) {
      filters.color = '';
      const colorBtn = document.querySelector('[data-menu="colorMenu"]');
      if (colorBtn) { colorBtn.classList.remove('has-value'); colorBtn.childNodes[0].textContent = 'Color '; }
      document.querySelectorAll('.filter-option[data-color],.filter-color-opt').forEach(o => o.classList.remove('active'));
      const allOpt = document.querySelector('.filter-option[data-color=""]');
      if (allOpt) allOpt.classList.add('active');
    }
  }

  // Category pills
  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const slugs = (pill.dataset.catSlugs || '').split(',');
      if (pill.classList.contains('active')) {
        filters.cats = [];
        pills.forEach(p => p.classList.remove('active'));
        if (banner) banner.style.display = 'none';
      } else {
        filters.cats = slugs;
        pills.forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        if (banner) { banner.style.display = 'flex'; if (bannerLabel) bannerLabel.textContent = pill.textContent.trim(); }
      }
      apply();
    });
  });
  document.getElementById('gActiveClear')?.addEventListener('click', () => {
    filters.cats = []; pills.forEach(p => p.classList.remove('active'));
    if (banner) banner.style.display = 'none'; apply();
  });

  // Dropdown management
  function closeAll() {
    document.querySelectorAll('.filter-menu.open').forEach(m => m.classList.remove('open'));
    document.querySelectorAll('.filter-btn.open').forEach(b => b.classList.remove('open'));
  }

  document.querySelectorAll('.filter-btn[data-menu]').forEach(btn => {
    const menu = document.getElementById(btn.dataset.menu);
    if (!menu) return;
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const isOpen = menu.classList.contains('open');
      closeAll();
      if (!isOpen) { btn.classList.add('open'); menu.classList.add('open'); }
    });
    menu.addEventListener('click', e => e.stopPropagation());
  });

  // Filter option clicks (size, brand, color)
  function handleFilterClick(opt, key, labels) {
    const btn = opt.closest('.filter-dropdown').querySelector('.filter-btn');
    const menu = opt.closest('.filter-menu');
    filters[key] = opt.dataset[key] || '';
    menu.querySelectorAll('.filter-option,.filter-color-opt').forEach(o => o.classList.remove('active'));
    opt.classList.add('active');
    if (btn) {
      btn.classList.toggle('has-value', !!filters[key]);
      const txt = filters[key] ? (opt.querySelector('.color-swatch') ? opt.textContent.trim() : opt.textContent.trim()) : labels[key];
      btn.childNodes[0].textContent = txt + ' ';
    }
    closeAll(); apply();
  }

  const labels = { brand: 'Marca', size: 'Talla', color: 'Color' };
  document.querySelectorAll('.filter-option[data-size]').forEach(o => o.addEventListener('click', () => handleFilterClick(o, 'size', labels)));
  document.querySelectorAll('.filter-option[data-brand]').forEach(o => o.addEventListener('click', () => handleFilterClick(o, 'brand', labels)));
  document.querySelectorAll('.filter-option[data-color],.filter-color-opt').forEach(o => o.addEventListener('click', () => handleFilterClick(o, 'color', labels)));

  // Price filter
  const priceApply = document.getElementById('priceApply');
  const priceClear = document.getElementById('priceClear');
  const priceMin = document.getElementById('priceMin');
  const priceMax = document.getElementById('priceMax');
  const priceBtn = document.querySelector('[data-menu="priceMenu"]');
  if (priceApply) {
    priceApply.addEventListener('click', () => {
      filters.priceMin = parseFloat(priceMin.value) || 0;
      filters.priceMax = parseFloat(priceMax.value) || Infinity;
      if (priceBtn) {
        const hasVal = filters.priceMin > 0 || filters.priceMax < Infinity;
        priceBtn.classList.toggle('has-value', hasVal);
        priceBtn.childNodes[0].textContent = hasVal ? '$' + (filters.priceMin||0).toLocaleString('es-CO') + '–$' + (filters.priceMax===Infinity?'...':filters.priceMax.toLocaleString('es-CO')) + ' ' : 'Precio ';
      }
      closeAll(); apply();
    });
  }
  if (priceClear) {
    priceClear.addEventListener('click', () => {
      filters.priceMin = 0; filters.priceMax = Infinity;
      if (priceMin) priceMin.value = ''; if (priceMax) priceMax.value = '';
      if (priceBtn) { priceBtn.classList.remove('has-value'); priceBtn.childNodes[0].textContent = 'Precio '; }
      closeAll(); apply();
    });
  }

  document.addEventListener('click', closeAll);

  // Sort
  const sortSelect = document.getElementById('sortSelect');
  if (sortSelect) {
    sortSelect.addEventListener('change', () => {
      const val = sortSelect.value;
      const sorted = [...cards].sort((a, b) => {
        const pa = parseFloat(a.dataset.price) || 0, pb = parseFloat(b.dataset.price) || 0;
        const na = (a.querySelector('.card-name')?.textContent || '').toLowerCase();
        const nb = (b.querySelector('.card-name')?.textContent || '').toLowerCase();
        if (val === 'price-asc') return pa - pb;
        if (val === 'price-desc') return pb - pa;
        if (val === 'name-asc') return na.localeCompare(nb);
        return 0;
      });
      sorted.forEach(c => grid.appendChild(c));
    });
  }

  // Scrollers with arrow visibility
  function setupScroller(container, leftBtn, rightBtn) {
    if (!container) return;
    function update() {
      if (leftBtn) leftBtn.style.visibility = container.scrollLeft <= 4 ? 'hidden' : 'visible';
      if (rightBtn) rightBtn.style.visibility = container.scrollLeft + container.clientWidth >= container.scrollWidth - 4 ? 'hidden' : 'visible';
    }
    const amt = () => container.clientWidth * 0.85;
    if (leftBtn) leftBtn.addEventListener('click', () => container.scrollBy({ left: -amt(), behavior: 'smooth' }));
    if (rightBtn) rightBtn.addEventListener('click', () => container.scrollBy({ left: amt(), behavior: 'smooth' }));
    container.addEventListener('scroll', update);
    update(); window.addEventListener('resize', update);
  }
  setupScroller(document.querySelector('.cat-pills-scroll'), document.querySelector('.pills-arrow-left'), document.querySelector('.pills-arrow-right'));

  // Mobile filter panel
  const mfBtn = document.getElementById('mobileFilterBtn');
  const mfOverlay = document.getElementById('mobileFilterOverlay');
  const mfPanel = document.getElementById('mobileFilterPanel');
  const mfClose = document.getElementById('mobileFilterClose');
  const mfApply = document.getElementById('mobileFilterApply');

  function openMobileFilters() { mfOverlay?.classList.add('open'); mfPanel?.classList.add('open'); }
  function closeMobileFilters() { mfOverlay?.classList.remove('open'); mfPanel?.classList.remove('open'); }

  mfBtn?.addEventListener('click', openMobileFilters);
  mfOverlay?.addEventListener('click', closeMobileFilters);
  mfClose?.addEventListener('click', closeMobileFilters);

  // Mobile option selection (toggle active)
  document.querySelectorAll('[data-msize]').forEach(o => o.addEventListener('click', () => {
    o.closest('.mobile-fp-options').querySelectorAll('.mobile-fp-opt,.mobile-fp-color').forEach(x => x.classList.remove('active'));
    o.classList.add('active');
  }));
  document.querySelectorAll('[data-mbrand]').forEach(o => o.addEventListener('click', () => {
    o.closest('.mobile-fp-options').querySelectorAll('.mobile-fp-opt,.mobile-fp-color').forEach(x => x.classList.remove('active'));
    o.classList.add('active');
  }));
  document.querySelectorAll('[data-mcolor]').forEach(o => o.addEventListener('click', () => {
    o.closest('.mobile-fp-options').querySelectorAll('.mobile-fp-opt,.mobile-fp-color').forEach(x => x.classList.remove('active'));
    o.classList.add('active');
  }));

  mfApply?.addEventListener('click', () => {
    filters.priceMin = parseFloat(document.getElementById('mPriceMin')?.value) || 0;
    filters.priceMax = parseFloat(document.getElementById('mPriceMax')?.value) || Infinity;
    const activeSize = document.querySelector('[data-msize].active');
    filters.size = activeSize?.dataset.msize || '';
    const activeBrand = document.querySelector('[data-mbrand].active');
    filters.brand = activeBrand?.dataset.mbrand || '';
    const activeColor = document.querySelector('[data-mcolor].active');
    filters.color = activeColor?.dataset.mcolor || '';
    // Update mobile filter btn indicator
    const hasFilters = filters.priceMin > 0 || filters.priceMax < Infinity || filters.size || filters.brand || filters.color;
    mfBtn?.classList.toggle('has-filters', hasFilters);
    closeMobileFilters();
    apply();
  });

  // Mobile sort
  const sortMobile = document.getElementById('sortSelectMobile');
  if (sortMobile) {
    sortMobile.addEventListener('change', () => {
      const val = sortMobile.value;
      if (sortSelect) sortSelect.value = val;
      const sorted = [...cards].sort((a, b) => {
        const pa = parseFloat(a.dataset.price) || 0, pb = parseFloat(b.dataset.price) || 0;
        const na = (a.querySelector('.card-name')?.textContent || '').toLowerCase();
        const nb = (b.querySelector('.card-name')?.textContent || '').toLowerCase();
        if (val === 'price-asc') return pa - pb;
        if (val === 'price-desc') return pb - pa;
        if (val === 'name-asc') return na.localeCompare(nb);
        return 0;
      });
      sorted.forEach(c => grid.appendChild(c));
    });
  }

  apply();
})();
</script>

</Layout>
