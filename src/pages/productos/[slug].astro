---
import Layout from '../../layouts/Layout.astro';
import { getProducts, getProductBySlug } from '../../lib/supabase';
import type { Product } from '../../lib/supabase';

// Generar todas las páginas de producto en build time
export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((p: Product) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const product = await getProductBySlug(slug!);

if (!product) {
  return Astro.redirect('/404');
}

const brandName = product.brands?.name || '';
const catName = product.categories?.name || '';
const catSlug = product.categories?.slug || '';
const primaryImg = product.product_images?.find(img => img.is_primary) || product.product_images?.[0];
const images = product.product_images?.sort((a, b) => a.display_order - b.display_order) || [];
const variants = product.product_variants?.filter(v => v.active) || [];

// Extraer tallas y colores únicos de las variantes
const sizes = [...new Set(variants.map(v => v.size))];
const colors = [...new Set(variants.map(v => v.color))].map(colorName => {
  const variant = variants.find(v => v.color === colorName);
  return { name: colorName, hex: variant?.color_hex || '#999' };
});

// Specs
const specs = product.specs && typeof product.specs === 'object' ? Object.entries(product.specs) : [];

// SEO
const pageTitle = product.meta_title || `${brandName} ${product.name} | Procalzado`;
const pageDesc = product.meta_description || product.short_description || `${brandName} ${product.name} - ${catName}. Compra en Procalzado, distribuidores autorizados en Colombia.`;
const pageImg = primaryImg?.url || '';

// WhatsApp link
const waMsg = encodeURIComponent(`Hola, me interesa el producto: *${brandName} - ${product.name}*. ¿Me pueden dar más información?`);
const waLink = `https://wa.me/573213154654?text=${waMsg}`;

// Schema.org Product
const schemaProduct = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `${brandName} ${product.name}`,
  "description": product.short_description || '',
  "brand": { "@type": "Brand", "name": brandName },
  "category": catName,
  "image": images.map(img => img.url),
  "url": `https://procalzado.com/productos/${product.slug}`,
  ...(product.show_price && product.price ? {
    "offers": {
      "@type": "Offer",
      "price": product.price,
      "priceCurrency": "COP",
      "availability": "https://schema.org/InStock",
      "seller": { "@type": "Organization", "name": "Procalzado" }
    }
  } : {})
};
---

<Layout title={pageTitle} description={pageDesc} ogImage={pageImg}>

<script type="application/ld+json" set:html={JSON.stringify(schemaProduct)} />

<div class="product-page">
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Inicio</a> <span>/</span>
    {catSlug && <><a href={`/?cat=${catSlug}`}>{catName}</a> <span>/</span></>}
    <span>{brandName} {product.name}</span>
  </nav>

  <div class="product-layout">
    <!-- GALERÍA -->
    <div class="product-gallery" id="gallery">
      {primaryImg ? (
        <img src={primaryImg.url} alt={`${brandName} ${product.name}`} id="mainImg" width="600" height="600"/>
      ) : (
        <span>👢</span>
      )}
    </div>

    <!-- INFO -->
    <div class="product-info">
      <div class="product-brand-tag">{brandName}</div>
      <h1>{product.name}</h1>
      {catName && <p class="card-cat-tag" style="margin-bottom:1rem">{catName}</p>}

      {product.show_price && product.price ? (
        <div style="margin-bottom:1rem">
          <span style="font-family:var(--fd);font-size:2rem;letter-spacing:.03em">${Number(product.price).toLocaleString('es-CO')}</span>
          <span style="font-size:.78rem;color:var(--muted);margin-left:.5rem">Al por mayor consultar precio</span>
        </div>
      ) : (
        <div style="margin-bottom:1rem;font-style:italic;color:var(--muted)">Precio: consultar por WhatsApp</div>
      )}

      {(product.short_description || product.description) && (
        <p class="product-description">{product.description || product.short_description}</p>
      )}

      <!-- SPECS -->
      {specs.length > 0 && (
        <table class="specs-table">
          <tbody>
            {specs.map(([key, val]) => (
              <tr>
                <th>{key.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}</th>
                <td>{String(val)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}

      <!-- TALLAS -->
      {sizes.length > 0 && (
        <div class="product-variants">
          <div class="variant-title">Tallas disponibles</div>
          <div class="size-list">
            {sizes.map(s => <span class="size-tag">{s}</span>)}
          </div>
        </div>
      )}

      <!-- COLORES -->
      {colors.length > 0 && (
        <div class="product-variants">
          <div class="variant-title">Colores disponibles</div>
          <div class="color-list">
            {colors.map(c => (
              <span class="color-dot" style={`background:${c.hex}`} title={c.name}></span>
            ))}
          </div>
        </div>
      )}

      <!-- GALERÍA THUMBS -->
      {images.length > 1 && (
        <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.5rem">
          {images.map(img => (
            <button type="button" style={`width:60px;height:60px;border:2px solid var(--grey2);border-radius:6px;overflow:hidden;cursor:pointer;padding:0;background:var(--grey)`} onclick={`document.getElementById('mainImg').src='${img.url}'`}>
              <img src={img.url} alt={img.alt_text || ''} style="width:100%;height:100%;object-fit:cover" loading="lazy"/>
            </button>
          ))}
        </div>
      )}

      <!-- ACCIONES -->
      <div class="product-actions">
        <a href={waLink} class="btn-wa" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Consultar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</div>
</Layout>
