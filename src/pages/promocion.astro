---
import Layout from '../layouts/Layout.astro';
import { getPromoProducts, getSettings } from '../lib/supabase';
import type { Category } from '../lib/supabase';

const recs = await getPromoProducts();
const cfg = await getSettings(['promo_page_title','promo_page_desc','promo_page_eyebrow']);
const promoTitle = cfg.promo_page_title || 'Promoción Especial';
const promoDesc = cfg.promo_page_desc || 'Aprovecha nuestra selección por tiempo limitado.';
const promoEyebrow = cfg.promo_page_eyebrow || 'Ofertas';

function build(rec: any) {
  const p = rec.products;
  if (!p) return null;
  const brandName = p.brands?.name || '';
  const cats = (p.product_categories && p.product_categories.length)
    ? p.product_categories.map((pc: any) => pc.categories).filter(Boolean) as Category[]
    : (p.categories ? [p.categories] : []);
  const primaryCat = cats[0] || null;
  const primaryImg = (p.product_images || []).find((i: any) => i.is_primary) || (p.product_images || [])[0];
  const secondImg = (p.product_images || []).filter((i: any) => i !== primaryImg)?.[0] || null;
  return {
    slug: p.slug, name: p.name, brandName,
    primaryImg, secondImg, featured: p.featured,
    price: p.price, salePrice: p.sale_price, showPrice: p.show_price,
    catName: primaryCat?.name || '',
    reason: rec.reason || '',
    shortDesc: p.short_description || '',
  };
}
const items = recs.map(build).filter(Boolean);

const pageTitle = `${promoTitle} | Procalzado`;
const pageDesc = promoDesc;
---

<Layout title={pageTitle} description={pageDesc}>

<section class="gender-hero" style="background-image:url(/portada_promocion.jpg)">
  <div class="gender-hero-inner">
    <span class="gender-hero-tag">{promoEyebrow}</span>
    <h1>{promoTitle}</h1>
    <p>{promoDesc}</p>
  </div>
</section>

<main class="products-section" id="main-content">
  {items.length > 0 ? (
    <div class="rec-grid">
      {items.map((it: any, i: number) => (
        <div class="rec-card" style={`animation-delay:${Math.min(i * 0.04, 0.4)}s`}>
          <a href={`/productos/${it.slug}`} class="rec-card-media">
            {it.primaryImg
              ? <>
                  <img src={it.primaryImg.url} alt={`${it.brandName} ${it.name}`} loading={i < 6 ? 'eager' : 'lazy'} class={it.secondImg ? 'rec-img-main' : ''}/>
                  {it.secondImg && <img src={it.secondImg.url} alt={`${it.brandName} ${it.name}`} loading="lazy" class="rec-img-hover"/>}
                </>
              : <span class="rec-noimg">👢</span>}
            {it.salePrice && it.showPrice && it.price && (
              <span class="rec-discount">-{Math.round((1 - it.salePrice / it.price) * 100)}%</span>
            )}
          </a>
          <div class="rec-card-body">
            {it.brandName && <div class="rec-brand">{it.brandName}</div>}
            <a href={`/productos/${it.slug}`} class="rec-name">{it.name}</a>

            {it.reason && (
              <div class="rec-reason">
                <p>{it.reason}</p>
              </div>
            )}

            <div class="rec-foot">
              {it.showPrice && it.price ? (
                it.salePrice ? (
                  <div class="rec-price-wrap">
                    <span class="rec-price-old">${Number(it.price).toLocaleString('es-CO')}</span>
                    <span class="rec-price rec-price-sale">${Number(it.salePrice).toLocaleString('es-CO')}</span>
                  </div>
                ) : (
                  <div class="rec-price">${Number(it.price).toLocaleString('es-CO')}</div>
                )
              ) : (
                <div class="rec-price-note">Precio a consultar</div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <div class="empty"><strong>Pronto</strong><p>Aún no hay productos recomendados. Agrégalos desde el panel de administración.</p></div>
  )}
</main>

<style>
.gender-hero{background:var(--black);color:var(--white);padding:clamp(2rem,5vw,3.5rem) clamp(1rem,4vw,3rem);padding-top:calc(var(--header-h) + clamp(2rem,5vw,3.5rem));margin-top:calc(-1 * var(--header-h));background-size:cover;background-position:center;background-repeat:no-repeat;position:relative}
.gender-hero-inner{max-width:var(--max-w);margin:0 auto}
.gender-hero-tag{display:inline-block;background:var(--red);color:var(--white);font-size:.68rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;padding:.28rem .7rem;border-radius:2px;margin-bottom:.8rem}
.gender-hero h1{font-family:var(--fd);font-size:clamp(2.2rem,5vw,3.4rem);letter-spacing:.03em;line-height:1}
.gender-hero p{font-size:.95rem;font-weight:300;color:rgba(255,255,255,.85);margin-top:.6rem;max-width:540px}

.rec-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1.4rem}
.rec-card{display:flex;background:var(--white);border-radius:12px;overflow:hidden;animation:fadeUp .32s ease both;transition:box-shadow .2s;min-height:220px}
.rec-card:hover{box-shadow:0 8px 24px rgba(0,0,0,.1)}
.rec-card-media{position:relative;width:44%;flex-shrink:0;background:var(--grey);display:flex;align-items:center;justify-content:center;text-decoration:none;overflow:hidden;border-radius:12px}
.rec-card-media img{width:100%;height:100%;object-fit:cover;display:block}
.rec-card-media .rec-img-hover{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .3s ease}
.rec-card:hover .rec-img-hover{opacity:1}
.rec-noimg{font-size:3rem}
.rec-discount{position:absolute;top:.6rem;left:.6rem;background:var(--red);color:var(--white);font-family:var(--fb);font-weight:700;font-size:.82rem;padding:.25rem .55rem;border-radius:5px}
.rec-card-body{flex:1;padding:1rem 1.1rem;display:flex;flex-direction:column;min-width:0}
.rec-brand{font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--red);margin-bottom:.15rem}
.rec-name{font-family:var(--fb);font-size:1.05rem;font-weight:700;color:var(--black);text-decoration:none;line-height:1.15;margin-bottom:.5rem}
.rec-name:hover{color:var(--red)}
.rec-reason{margin-bottom:.5rem}
.rec-reason p{font-size:.82rem;line-height:1.4;color:var(--muted);font-style:italic}
.rec-foot{margin-top:auto;display:flex;align-items:center;gap:.6rem;flex-wrap:wrap}
.rec-price-wrap{display:flex;flex-direction:column;line-height:1}
.rec-price-old{font-size:.78rem;color:var(--muted);text-decoration:line-through}
.rec-price{font-family:var(--fb);font-size:1.15rem;font-weight:700;color:var(--black)}
.rec-price-sale{color:var(--red)}
.rec-price-note{font-size:.78rem;color:var(--muted)}
@media(max-width:640px){
  .rec-grid{grid-template-columns:1fr}
  .rec-card{flex-direction:column;min-height:auto}
  .rec-card-media{width:100%;aspect-ratio:1/1}
}
</style>

</Layout>
