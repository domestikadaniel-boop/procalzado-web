---
import Layout from '../layouts/Layout.astro';
import PromoBanner from '../components/PromoBanner.astro';
import { getProducts, getCategories, getPromoBlocks } from '../lib/supabase';
import type { Product, Category } from '../lib/supabase';

const products: Product[] = await getProducts();
const promos = await getPromoBlocks();
const categories: Category[] = await getCategories();

const parentCats = categories.filter(c => !c.parent_id);
const subcatsByParent: Record<string, Category[]> = {};
categories.filter(c => c.parent_id).forEach(c => {
  if (!subcatsByParent[c.parent_id!]) subcatsByParent[c.parent_id!] = [];
  subcatsByParent[c.parent_id!].push(c);
});

// Categorías a mostrar: si padre tiene subs, mostrar sólo subs; si no tiene, mostrar el padre
const displayCats: Category[] = [];
parentCats.forEach(parent => {
  const subs = subcatsByParent[parent.id];
  if (subs && subs.length > 0) {
    subs.forEach(s => displayCats.push(s));
  } else {
    displayCats.push(parent);
  }
});

// Datos de cada producto
function productData(p: Product) {
  const brandName = p.brands?.name || '';
  const cats = (p.product_categories && p.product_categories.length)
    ? p.product_categories.map(pc => pc.categories).filter(Boolean) as Category[]
    : (p.categories ? [p.categories as Category] : []);
  const primaryCat = (p.product_categories?.find(pc => pc.is_primary)?.categories as Category)
    || cats[0] || null;
  const catSlugs = cats.map(c => c.slug);
  const primaryImg = p.product_images?.find(i => i.is_primary) || p.product_images?.[0];
  const secondImg = p.product_images?.filter(i => i !== primaryImg)?.[0] || null;
  return {
    slug: p.slug, name: p.name, brandName,
    primaryImg, secondImg, featured: p.featured,
    price: p.price, salePrice: p.sale_price, showPrice: p.show_price,
    catSlugs, primaryCatSlug: primaryCat?.slug || '',
    shortDesc: p.short_description || '',
  };
}
const items = products.map(productData);

// Agrupar productos por categoría de display
const catSections = displayCats.map(cat => {
  const catProducts = items.filter(it => it.catSlugs.includes(cat.slug));
  return { cat, products: catProducts };
}).filter(s => s.products.length > 0);

const pageTitle = 'Procalzado | Botas de Caucho, Trabajo, Moto y más en Colombia';
const pageDesc = 'Compra botas de caucho, botas de lluvia, botas de moto, botas de trabajo, sandalias, zapatos industriales y mucho más en Colombia. Procalzado: distribuidor autorizado.';
---

<Layout title={pageTitle} description={pageDesc}>

<section class="hero-banner">
  <picture>
    <source media="(max-width: 768px)" srcset="/portada_vertical.jpg"/>
    <img src="/portada_horizontal.jpg" alt="Procalzado — Calidad Garantizada" class="hero-banner-img" loading="eager"/>
  </picture>
</section>

{promos.hero && promos.hero.active && (
  <div class="promo-wrap"><PromoBanner block={promos.hero} /></div>
)}

<main class="catalog-section">

  {catSections.map((section, si) => (
    <section class="cat-section" id={`cat-${section.cat.slug}`}>
      <div class="cat-section-header">
        <h2 class="cat-section-title">{section.cat.name} <span class="swipe-hint">Desliza <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="9 18 15 12 9 6"/></svg></span></h2>
      </div>
      <div class="cat-carousel-wrap">
        <button type="button" class="carousel-arrow carousel-left" aria-label="Anterior">&#8249;</button>
        <div class="cat-carousel">
        {section.products.map((it, i) => (
          <a href={`/productos/${it.slug}`} class="card" style={`animation-delay:${Math.min(i * 0.03, 0.3)}s`}>
            {it.featured && (
              <span class="card-badge-featured">
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                Destacado
              </span>
            )}
            {it.salePrice && it.showPrice && it.price && (
              <span class="card-badge-sale">-{Math.round((1 - it.salePrice / it.price) * 100)}%</span>
            )}
            <div class="card-img">
              {it.primaryImg
                ? <>
                    <img src={it.primaryImg.url} alt={`${it.brandName} ${it.name}`} width="240" height="240" loading={si < 2 && i < 4 ? 'eager' : 'lazy'} class={it.secondImg ? 'card-img-main' : ''}/>
                    {it.secondImg && <img src={it.secondImg.url} alt={`${it.brandName} ${it.name}`} width="240" height="240" loading="lazy" class="card-img-hover"/>}
                  </>
                : <span class="card-noimg">—</span>}
            </div>
            <div class="card-body">
              {it.brandName && <div class="card-brand">{it.brandName}</div>}
              <div class="card-name">{it.name}</div>
              {it.shortDesc && <div class="card-desc">{it.shortDesc.length > 60 ? it.shortDesc.slice(0, 60) + '...' : it.shortDesc}</div>}
              {it.showPrice && it.price ? (
                it.salePrice ? (
                  <div class="card-price-row"><span class="card-price-old">${Number(it.price).toLocaleString('es-CO')}</span><span class="card-price card-price-sale">${Number(it.salePrice).toLocaleString('es-CO')}</span></div>
                ) : (
                  <div class="card-price">${Number(it.price).toLocaleString('es-CO')}</div>
                )
              ) : (
                <div class="card-price-note" style="margin-top:auto">Precio a consultar</div>
              )}
            </div>
          </a>
        ))}
        </div>
        <button type="button" class="carousel-arrow carousel-right" aria-label="Siguiente">&#8250;</button>
      </div>
    </section>
  ))}

  {promos.mid && promos.mid.active && (
    <div class="promo-bottom"><PromoBanner block={promos.mid} /></div>
  )}
</main>

<style>
.hero-banner{width:100vw;margin-left:calc(-50vw + 50%);overflow:hidden;background:var(--red);margin-top:calc(-1 * var(--header-h))}
.hero-banner-img{width:100%;height:100vh;display:block;object-fit:cover}
.hero-banner picture{display:block;width:100%}
.promo-wrap{max-width:var(--max-w);margin:0 auto;padding:1.5rem clamp(1rem,4vw,3rem) 0}
.promo-bottom{margin:2rem 0 0}
.catalog-section{max-width:var(--max-w);margin:0 auto;padding:2rem clamp(1rem,4vw,3rem) 3rem}
.cat-section{margin-bottom:2.5rem}
.cat-section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;border-bottom:2px solid var(--grey2);padding-bottom:.5rem}
.cat-section-title{font-family:var(--fd);font-size:clamp(1.4rem,3vw,1.8rem);letter-spacing:.03em;display:flex;align-items:center;gap:.5rem}
.swipe-hint{display:none;font-family:var(--fb);font-size:.7rem;font-weight:500;color:var(--muted);letter-spacing:.02em;align-items:center;gap:.15rem}
.swipe-hint svg{flex-shrink:0}
@media(max-width:640px){
  .swipe-hint{display:inline-flex}
}
.cat-carousel-wrap{position:relative;padding:0 40px}
.carousel-arrow{position:absolute;top:50%;transform:translateY(-50%);z-index:3;width:34px;height:34px;border-radius:50%;border:1.5px solid var(--grey2);background:var(--white);color:var(--black);font-size:1.4rem;line-height:1;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;box-shadow:0 2px 6px rgba(0,0,0,.08)}
.carousel-arrow:hover{border-color:var(--black);background:var(--black);color:var(--white)}
.carousel-left{left:0}
.carousel-right{right:0}
.cat-carousel{display:flex;gap:1.1rem;overflow-x:auto;-webkit-overflow-scrolling:touch;scroll-snap-type:x mandatory;scroll-behavior:smooth;scrollbar-width:none}
.cat-carousel::-webkit-scrollbar{display:none}
.cat-carousel .card{flex:0 0 240px;scroll-snap-align:start}
@media(max-width:640px){
  .cat-carousel .card{flex:0 0 180px}
  .cat-carousel-wrap{padding:0}
  .carousel-arrow{display:none}
  .hero-banner-img{height:auto;min-height:100vh}
}
.card-noimg{font-size:2rem;color:var(--grey2)}
.card-badge-sale{position:absolute;top:.6rem;right:.6rem;background:var(--red);color:var(--white);font-family:var(--fb);font-weight:700;font-size:.75rem;padding:.22rem .5rem;border-radius:4px;z-index:5}
.card-desc{font-size:.75rem;color:var(--muted);line-height:1.35;margin-bottom:.5rem}
.card-price-row{display:flex;align-items:baseline;gap:.5rem;flex-wrap:wrap}
.card-price-old{font-size:.85rem;color:var(--muted);text-decoration:line-through}
.card-price-sale{color:var(--red)}
</style>

<script is:inline>
document.querySelectorAll('.cat-section').forEach(section => {
  const carousel = section.querySelector('.cat-carousel');
  const left = section.querySelector('.carousel-left');
  const right = section.querySelector('.carousel-right');
  if (!carousel) return;
  function update() {
    if (left) left.style.visibility = carousel.scrollLeft <= 4 ? 'hidden' : 'visible';
    if (right) right.style.visibility = carousel.scrollLeft + carousel.clientWidth >= carousel.scrollWidth - 4 ? 'hidden' : 'visible';
  }
  const amt = () => carousel.clientWidth * 0.85;
  if (left) left.addEventListener('click', () => carousel.scrollBy({ left: -amt(), behavior: 'smooth' }));
  if (right) right.addEventListener('click', () => carousel.scrollBy({ left: amt(), behavior: 'smooth' }));
  carousel.addEventListener('scroll', update);
  update();
  window.addEventListener('resize', update);
});
</script>

</Layout>
