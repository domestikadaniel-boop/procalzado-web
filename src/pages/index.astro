---
import Layout from '../layouts/Layout.astro';
import PromoBanner from '../components/PromoBanner.astro';
import { getProducts, getCategories, getBrands, getSiteSetting, getPromoBlocks } from '../lib/supabase';
import type { Product, Category, Brand } from '../lib/supabase';

// Datos en build time
const products: Product[] = await getProducts();
const promos = await getPromoBlocks();
const categories: Category[] = await getCategories();
const brands: Brand[] = await getBrands();
// Marcas destacadas en filtros (show_in_filters != false) y el resto bajo "Ver más"
const filterBrands = brands.filter(b => (b as any).show_in_filters !== false);
const moreBrands = brands.filter(b => (b as any).show_in_filters === false);
const homeIntro = await getSiteSetting('home_intro');

// Categorías principales y subcategorías
const parentCats = categories.filter(c => !c.parent_id);
const subcatsByParent: Record<string, Category[]> = {};
categories.filter(c => c.parent_id).forEach(c => {
  if (!subcatsByParent[c.parent_id!]) subcatsByParent[c.parent_id!] = [];
  subcatsByParent[c.parent_id!].push(c);
});

// Etiquetas de género legibles
const GENDER_LABELS: Record<string, string> = {
  hombre: 'Hombre', mujer: 'Mujer', unisex: 'Unisex', nino: 'Niño', nina: 'Niña'
};

// Recolectar géneros presentes en los productos
const gendersInUse = [...new Set(products.flatMap(p => {
  const g = (p.genders && p.genders.length) ? p.genders : (p.gender ? [p.gender] : []);
  return g;
}).filter(Boolean))];

// Construir datos de cada producto para render + búsqueda + filtros
function productData(p: Product) {
  const brandName = p.brands?.name || '';
  // Categorías: usa product_categories (múltiples) con fallback a la principal
  const cats = (p.product_categories && p.product_categories.length)
    ? p.product_categories.map(pc => pc.categories).filter(Boolean) as Category[]
    : (p.categories ? [p.categories as Category] : []);
  const primaryCat = (p.product_categories?.find(pc => pc.is_primary)?.categories as Category)
    || cats[0] || null;
  const catNames = cats.map(c => c.name).join(', ');
  const catSlugs = cats.map(c => c.slug);

  const primaryImg = p.product_images?.find(i => i.is_primary) || p.product_images?.[0];

  const variants = (p.product_variants || []).filter(v => v.active);

  // Colores únicos para las bolitas (diferenciando por nombre de color)
  const colors = [...new Set(variants.map(v => v.color))].map(cname => {
    const v = variants.find(x => x.color === cname);
    return { name: cname, hex: v?.color_hex || '#999', hex2: v?.color_hex_2 || null };
  }).filter(c => c.name && c.name !== 'Único');

  const productGenders = (p.genders && p.genders.length) ? p.genders : (p.gender ? [p.gender] : []);

  return {
    id: p.id, slug: p.slug, name: p.name, brandName,
    brandId: p.brand_id, catNames, catSlugs, primaryCat,
    primaryImg, colors, featured: p.featured,
    price: p.price, salePrice: p.sale_price, showPrice: p.show_price,
    genders: productGenders,
    catName: primaryCat?.name || '',
  };
}
const items = products.map(productData);
const midIndex = items.length >= 4 ? Math.floor(items.length / 2) - 1 : -1;

// Intro con **negrita** -> <strong>
const introHtml = homeIntro
  ? homeIntro.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
  : '';

const pageTitle = 'Procalzado | Botas de Caucho, Trabajo, Moto y más en Colombia';
const pageDesc = 'Compra botas de caucho, botas de lluvia, botas de moto, botas de trabajo, sandalias, zapatos industriales y mucho más en Colombia. Procalzado: distribuidor autorizado. Venta al detal y al por mayor con envíos a todo el país.';
---

<Layout title={pageTitle} description={pageDesc}>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <span class="hero-tag">Catálogo Oficial 2026</span>
      <h1>Calzado de <span class="accent">calidad</span> garantizada</h1>
      <p class="hero-sub">Botas de caucho, de lluvia, de moto y de trabajo, calzado industrial, sandalias y mucho más. Distribuidores autorizados de las principales marcas en Colombia.</p>
      <div class="hero-stats">
        <div class="stat"><div class="stat-num" data-count={parentCats.length}>0</div><div class="stat-label">Categorías</div></div>
        <div class="stat"><div class="stat-num" data-count={products.length}>0</div><div class="stat-label">Productos</div></div>
        <div class="stat"><div class="stat-num" data-count={brands.length} data-suffix="+">0+</div><div class="stat-label">Marcas</div></div>
      </div>
    </div>
    <div class="hero-badge">
      <img src="/isotipo.png" class="hero-isotipo" alt="Procalzado" loading="eager"/>
    </div>
  </div>
</section>

{promos.hero && promos.hero.active && (
  <div class="promo-wrap"><PromoBanner block={promos.hero} /></div>
)}

<!-- PRODUCTOS -->
<main class="products-section" id="main-content">
  {introHtml && (
    <div style="margin-bottom:1.5rem;font-size:.92rem;line-height:1.6;color:var(--muted)" set:html={introHtml}></div>
  )}
  <div class="section-header">
    <h2 class="section-title">Todos los <span class="red">productos</span></h2>
    <span class="section-count" id="resultCount">{items.length} productos</span>
  </div>

  <div class="product-grid" id="productGrid">
    {items.map((it, i) => {
      const dataAttrs = {
        'data-name': it.name.toLowerCase(),
        'data-brand-name': it.brandName.toLowerCase(),
        'data-brand-id': it.brandId || '',
        'data-cats': it.catSlugs.join('|'),
        'data-genders': it.genders.join('|'),
        'data-price': (it.showPrice && it.price) ? it.price : '',
        'data-featured': it.featured ? '1' : '0',
      };
      return (
        <>
        <a href={`/productos/${it.slug}`} class="card" style={`animation-delay:${Math.min(i * 0.03, 0.4)}s`} {...dataAttrs}>
          <div class="card-top-bar"></div>
          {it.featured && (
            <span class="card-badge-featured">
              <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              Destacado
            </span>
          )}
          <div class="card-img">
            {it.primaryImg
              ? <img src={it.primaryImg.url} alt={`${it.brandName} ${it.name}`} width="240" height="240" loading={i < 8 ? 'eager' : 'lazy'}/>
              : <span>👢</span>}
          </div>
          <div class="card-body">
            {it.brandName && <div class="card-brand">{it.brandName}</div>}
            <div class="card-name">{it.name}</div>
            {it.catName && <div class="card-cat-tag">{it.catName}</div>}

            {it.colors.length > 0 && (
              <div class="card-colors">
                {it.colors.slice(0, 6).map(c => {
                  const bg = c.hex2
                    ? `linear-gradient(135deg, ${c.hex} 0%, ${c.hex} 50%, ${c.hex2} 50%, ${c.hex2} 100%)`
                    : c.hex;
                  return <span class="card-color-dot" style={`background:${bg}`} title={c.name}></span>;
                })}
                {it.colors.length > 6 && <span class="card-color-more">+{it.colors.length - 6}</span>}
              </div>
            )}

            {it.showPrice && it.price ? (
              it.salePrice ? (
                <>
                  <div class="card-price-row"><span class="card-price-old">${Number(it.price).toLocaleString('es-CO')}</span><span class="card-price card-price-sale">${Number(it.salePrice).toLocaleString('es-CO')}</span></div>
                  <div class="card-price-note">Al por mayor consultar precio</div>
                </>
              ) : (
                <>
                  <div class="card-price">${Number(it.price).toLocaleString('es-CO')}</div>
                  <div class="card-price-note">Al por mayor consultar precio</div>
                </>
              )
            ) : (
              <div class="card-price-note" style="margin-top:auto">Precio a consultar</div>
            )}

            <div class="card-cta">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              Ver detalles
            </div>
          </div>
        </a>
        {i === midIndex && promos.mid && promos.mid.active && (
          <div class="promo-grid-full"><PromoBanner block={promos.mid} /></div>
        )}
        </>
      );
    })}
  </div>

  <div class="empty" id="emptyState" style="display:none">
    <strong>Sin resultados</strong>
    <p>No encontramos productos con esos filtros. Prueba con otros.</p>
  </div>
</main>

<style>
/* Precio rebajado en tarjetas */
.promo-grid-full{grid-column:1/-1;margin:1rem 0}
.promo-wrap{max-width:1280px;margin:0 auto;padding:1.5rem clamp(1rem,4vw,3rem) 0}
.promo-wrap-mid{padding:2.5rem clamp(1rem,4vw,3rem) .5rem}
.card-price-row{display:flex;align-items:baseline;gap:.5rem;flex-wrap:wrap}
.card-price-old{font-size:.85rem;color:var(--muted);text-decoration:line-through}
.card-price-sale{color:var(--red)}
/* Banner de categoría activa */
.active-cat-banner{align-items:center;justify-content:space-between;gap:1rem;background:#fff5f5;border:1px solid var(--red);border-radius:8px;padding:.7rem 1rem;margin-bottom:1.2rem;font-size:.9rem}
.active-cat-banner strong{text-transform:uppercase;letter-spacing:.03em}
.active-cat-banner button{background:var(--red);color:var(--white);border:none;border-radius:5px;padding:.4rem .8rem;font-size:.8rem;font-weight:600;cursor:pointer;font-family:inherit;white-space:nowrap}
.active-cat-banner button:hover{background:#cc0000}
/* Hero isotipo circular (sin resplandor) */
.hero-isotipo{display:block;width:clamp(220px,30vw,380px);height:auto}
/* Bolitas de color en las tarjetas */
.more-brands{flex-direction:column;gap:inherit}
.more-brands:not([hidden]){display:flex}
.more-brands-btn{display:inline-flex;align-items:center;gap:.3rem;background:none;border:none;color:var(--red);font-size:.8rem;font-weight:600;cursor:pointer;padding:.4rem 0 0;font-family:inherit}
.more-brands-btn svg{width:15px;height:15px;transition:transform .2s}
.more-brands-btn[aria-expanded="true"] svg{transform:rotate(180deg)}
.card-colors{display:flex;align-items:center;gap:.32rem;flex-wrap:wrap;margin-bottom:.7rem}
.card-color-dot{width:16px;height:16px;border-radius:50%;border:1.5px solid var(--white);box-shadow:0 0 0 1px var(--grey2);flex-shrink:0}
.card-color-more{font-size:.68rem;font-weight:600;color:var(--muted);margin-left:.1rem}
@media(max-width:640px){
  .card-color-dot{width:14px;height:14px}
}
</style>

<script is:inline>
(function () {
  // Contadores animados del hero
  const counters = document.querySelectorAll('.stat-num[data-count]');
  counters.forEach(el => {
    const target = parseInt(el.dataset.count) || 0;
    const suffix = el.dataset.suffix || '';
    if (target === 0) { el.textContent = '0' + suffix; return; }
    const duration = 1200;
    const start = performance.now();
    function tick(now) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(eased * target) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  });
})();
</script>

</Layout>
