---
import Layout from '../layouts/Layout.astro';
import { getProducts, getCategories, getBrands } from '../lib/supabase';

const products = await getProducts();
const categories = await getCategories();
const brands = await getBrands();

// Separar categorías principales y subcategorías
const mainCategories = categories.filter(c => !c.parent_id);
const subCategoriesByParent: Record<string, typeof categories> = {};
categories.filter(c => c.parent_id).forEach(c => {
  if (!subCategoriesByParent[c.parent_id!]) subCategoriesByParent[c.parent_id!] = [];
  subCategoriesByParent[c.parent_id!].push(c);
});

// Lista de marcas únicas presentes en productos
const brandsInUse = brands.filter(b => products.some(p => p.brands?.id === b.id));

// Géneros únicos
const gendersInUse = [...new Set(products.map(p => p.gender).filter(Boolean))] as string[];
const genderLabels: Record<string, string> = {
  'nino': 'Niño',
  'nina': 'Niña',
  'hombre': 'Hombre',
  'mujer': 'Mujer',
  'unisex': 'Unisex'
};

// Rango de precios
const productPrices = products.filter(p => p.show_price && p.price).map(p => Number(p.price));
const minPrice = productPrices.length ? Math.floor(Math.min(...productPrices)) : 0;
const maxPrice = productPrices.length ? Math.ceil(Math.max(...productPrices)) : 0;

const totalProducts = products.length;
const totalCategories = mainCategories.length;
const totalBrands = brandsInUse.length;
---

<Layout title="Procalzado | Botas de Caucho, Botas de Lluvia y Calzado Industrial en Colombia">

<!-- Schema.org -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Store",
      "@id": "https://procalzado.com/#store",
      "name": "Procalzado",
      "description": "Distribuidores autorizados de botas de caucho, botas de lluvia, botas de moto, botas de trabajo, sandalias, zuecos y calzado industrial en Colombia.",
      "url": "https://procalzado.com",
      "telephone": "+573213154654",
      "address": { "@type": "PostalAddress", "addressCountry": "CO", "addressLocality": "Bogotá" },
      "priceRange": "$$"
    },
    {
      "@type": "WebSite",
      "@id": "https://procalzado.com/#website",
      "url": "https://procalzado.com",
      "name": "Procalzado",
      "inLanguage": "es-CO"
    }
  ]
})} />

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-tag">Catálogo Oficial 2026</div>
      <h1>BOTAS Y<br>CALZADO DE <span class="accent">CALIDAD</span><br>GARANTIZADA</h1>
      <p class="hero-sub">Botas de caucho, botas de lluvia, botas de moto y calzado industrial. Distribuidores autorizados de las principales marcas en Colombia.</p>
      <div class="hero-stats">
        <div class="stat"><div class="stat-num">{totalCategories}</div><div class="stat-label">Categorías</div></div>
        <div class="stat"><div class="stat-num">{totalProducts}</div><div class="stat-label">Productos</div></div>
        <div class="stat"><div class="stat-num">{totalBrands}+</div><div class="stat-label">Marcas</div></div>
      </div>
    </div>
    <div class="hero-badge">
      <svg viewBox="0 0 1080 1080" xmlns="http://www.w3.org/2000/svg" style="width:140px;height:140px;display:block">
        <rect fill="red" x="0" y="0" width="1080" height="1080" rx="540" ry="540"/>
        <path fill="#fff" d="M938.98,465.16c-1.92-31.68-33.56-58.61-94.11-80.09-74.68-26.49-185.71-41.68-304.61-41.68-146.23,0-279.43,23.17-347.62,60.46-32.12,17.57-49.26,37.9-51.03,60.48-5.53,2.9-9.31,8.68-9.31,15.36v131.55c0,32.01,30.39,59.29,90.34,81.1,49.24,17.91,115.6,31.1,191.91,38.14.53.05,1.07.07,1.59.07,1.51,0,2.99-.22,4.42-.6,5.38,4.3,11.99,6.66,18.98,6.66h100.21c121.67,0,235.26-15.18,311.66-41.64,63.91-22.14,96.31-50.14,96.31-83.22v-131.54c0-6.44-3.52-12.05-8.73-15.04ZM200.95,419.07c63.34-34.64,191.5-58.34,339.3-58.34,121.06,0,228.93,15.9,298.82,40.69,51.74,18.35,82.66,41.58,82.66,66.84s-29.75,47.59-79.7,65.77c-.98-.36-1.97-.71-2.96-1.07-69.88-24.79-177.76-40.69-298.82-40.69s-232,16.35-301.78,41.75c-.88-.32-1.76-.64-2.62-.96-48.37-18.02-77.08-40.47-77.08-64.81,0-17.72,15.23-34.45,42.18-49.19ZM518.7,570.35h-78.73c-.36,0-.71.04-1.06.05-2.83-2.86-6.64-4.74-10.87-5.09-57.24-4.79-110.2-13.38-153.36-24.71,69.67-19.82,164.19-30.98,265.58-30.98s196.49,11.25,266.29,31.19c-50.64,13.45-114.4,22.92-183.73,27.11-.54.03-1.08.05-1.62.05-5.69,0-11.18-1.76-15.88-5.09l-40.74-28.88c-5.18-3.68-11.28-5.62-17.63-5.62-9.87,0-19.18,4.81-24.89,12.86-6.23,8.8-7.14,19.79-3.36,29.12ZM415,706.75c0,2.27.41,4.44,1.12,6.46-75.41-6.95-140.57-20.07-187.57-37.17-49.53-18.02-78.93-40.47-78.93-64.81v-131.54c0,24.34,29.4,46.79,78.93,64.81l2.69.96c48.98,17.41,116.95,30.57,195.36,37.12-6.82,3.02-11.59,9.84-11.59,17.78s4.72,14.69,11.49,17.73c-6.77,3.04-11.49,9.83-11.49,17.73s4.72,14.69,11.49,17.73c-6.77,3.04-11.49,9.83-11.49,17.73s4.72,14.69,11.49,17.73c-6.77,3.04-11.49,9.83-11.49,17.73ZM930.38,611.75c0,25.26-31.66,48.49-84.65,66.84-71.56,24.79-182.02,40.69-305.98,40.69h-100.21c-7.35,0-13.29-6.02-13.15-13.4.13-7.24,6.35-12.91,13.59-12.91h73.58c2.42,0,4.38-1.96,4.38-4.38h0c0-2.42-1.96-4.38-4.38-4.38h-74.02c-7.35,0-13.29-6.02-13.15-13.4.13-7.24,6.35-12.91,13.59-12.91h73.56c2.51,0,4.53-2.1,4.39-4.64-.12-2.38-2.26-4.16-4.64-4.16h-73.31c-7.24,0-13.46-5.67-13.59-12.91-.14-7.38,5.81-13.4,13.15-13.4l73.7.26c2.73,0,4.89-2.47,4.32-5.3-.41-2.06-2.31-3.49-4.41-3.5l-73.62-.26c-7.35,0-13.29-6.02-13.15-13.4.13-7.24,6.35-12.91,13.59-12.91h99.77v.04c4.27,0,8.53-.02,12.77-.06,3.81-.04,5.34-4.94,2.23-7.14l-15.42-10.93c-5.93-4.2-7.32-12.41-3.12-18.34,4.2-5.93,12.41-7.32,18.34-3.12l40.74,28.88c8.32,5.9,18.4,8.82,28.58,8.21,89.2-5.39,166.98-19.17,221.87-38.18,1.02-.35,2.03-.71,3.03-1.07,51.15-18.18,81.61-41,81.61-65.77v131.54Z"/>
      </svg>
    </div>
  </div>
</section>

<main id="main-content">
<!-- FILTER BAR -->
<div class="filter-bar" id="filterBar">
  <div class="filter-inner">
    <div class="filter-top-row">
      <div class="search-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="searchInput" placeholder="Buscar producto o marca…"/>
      </div>
      <button class="toggle-cats-btn" id="toggleFiltersBtn" type="button" title="Mostrar filtros">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
        <span class="toggle-label">Filtros</span>
        <span class="filter-count-badge" id="filterCountBadge" style="display:none">0</span>
      </button>
    </div>

    <!-- Todo lo que se puede ocultar/mostrar -->
    <div class="collapsible-filters hidden" id="collapsibleFilters">
      <!-- Categorías principales -->
      <div class="filter-section-title">Categorías</div>
      <div class="pills main-pills">
        <button class="pill active" type="button" data-cat="todas">Todas</button>
        {mainCategories.map(cat => (
          <button class="pill" type="button" data-cat={cat.slug} data-cat-id={cat.id}>{cat.name}</button>
        ))}
      </div>

      <!-- Subcategorías (aparecen al elegir una categoría principal) -->
      <div class="subcats-wrapper" id="subcatsWrapper" style="display:none">
        <div class="filter-section-title">Subcategorías</div>
        <div class="pills subcats-pills" id="subcatsPills"></div>
      </div>

      <!-- Panel de filtros avanzados -->
      <div class="filters-panel" id="filtersPanel">
        {brandsInUse.length > 0 && (
          <div class="filter-group">
            <div class="filter-group-title">Marca</div>
            <div class="filter-options">
              {brandsInUse.map(b => (
                <label class="filter-check">
                  <input type="checkbox" data-filter="brand" value={b.slug}/>
                  <span>{b.name}</span>
                </label>
              ))}
            </div>
          </div>
        )}

        {gendersInUse.length > 0 && (
          <div class="filter-group">
            <div class="filter-group-title">Género</div>
            <div class="filter-options">
              {gendersInUse.map(g => (
                <label class="filter-check">
                  <input type="checkbox" data-filter="gender" value={g}/>
                  <span>{genderLabels[g] || g.charAt(0).toUpperCase() + g.slice(1)}</span>
                </label>
              ))}
            </div>
          </div>
        )}

        {productPrices.length > 0 && (
          <div class="filter-group">
            <div class="filter-group-title">Precio</div>
            <div class="filter-price">
              <div style="display:flex;gap:.4rem;align-items:center">
                <input type="number" id="priceMin" placeholder="Min" min={minPrice} max={maxPrice}/>
                <span style="color:var(--muted)">—</span>
                <input type="number" id="priceMax" placeholder="Max" min={minPrice} max={maxPrice}/>
              </div>
              <small style="color:var(--muted);font-size:.7rem">Rango: ${minPrice.toLocaleString('es-CO')} - ${maxPrice.toLocaleString('es-CO')}</small>
            </div>
          </div>
        )}

        <div class="filter-group">
          <div class="filter-group-title">Otros</div>
          <div class="filter-options">
            <label class="filter-check">
              <input type="checkbox" data-filter="hasPrice" value="true"/>
              <span>Solo con precio visible</span>
            </label>
            <label class="filter-check">
              <input type="checkbox" data-filter="featured" value="true"/>
              <span>Destacados ⭐</span>
            </label>
          </div>
        </div>
      </div>

      <button class="filter-clear" id="filterClearBtn" type="button">Limpiar todos los filtros</button>
    </div>
  </div>
</div>

<!-- PRODUCTS -->
<div class="products-section">
  <div class="section-header">
    <h2 class="section-title" id="sectionTitle">TODOS LOS <span class="red">PRODUCTOS</span></h2>
    <span class="section-count" id="sectionCount">{totalProducts} productos</span>
  </div>
  <p style="font-size:.82rem;color:var(--muted);line-height:1.6;max-width:700px;margin-bottom:2rem;padding:1rem 1.2rem;background:var(--grey);border-radius:8px;border-left:3px solid var(--red)">
    Catálogo completo de <strong>botas de caucho</strong>, <strong>botas de lluvia</strong>, <strong>botas de moto</strong>, <strong>botas de trabajo</strong>, sandalias, zuecos y zapatos de lona. Venta al detal y al por mayor en toda Colombia.
  </p>
  <div class="product-grid" id="productGrid">
    {products.map((p, i) => {
      const primaryImg = p.product_images?.find(img => img.is_primary) || p.product_images?.[0];
      const brandName = p.brands?.name || '';
      const brandSlug = p.brands?.slug || '';
      // Categorías del producto (de la nueva tabla, con fallback a la vieja)
      const productCats = p.product_categories?.length
        ? p.product_categories.map(pc => pc.categories).filter(Boolean)
        : (p.categories ? [p.categories] : []);
      const catSlugs = productCats.map(c => c?.slug).filter(Boolean).join(',');
      const primaryCat = p.product_categories?.find(pc => pc.is_primary)?.categories || p.categories;
      const catName = primaryCat?.name || '';
      return (
        <a href={`/productos/${p.slug}`} class="card" style={`animation-delay:${i * 30}ms`}
          data-cat={catSlugs}
          data-name={p.name.toLowerCase()}
          data-brand={brandName.toLowerCase()}
          data-brand-slug={brandSlug}
          data-gender={p.gender || ''}
          data-price={p.show_price && p.price ? p.price : ''}
          data-has-price={p.show_price && p.price ? 'true' : 'false'}
          data-featured={p.featured ? 'true' : 'false'}>
          <div class="card-top-bar"></div>
          <div class="card-img">
            {primaryImg ? (
              <img src={primaryImg.url} alt={`${brandName} ${p.name} - ${catName}`} loading="lazy" width="210" height="210"/>
            ) : (
              <span>👢</span>
            )}
          </div>
          <div class="card-body">
            <div class="card-brand">{brandName}</div>
            <div class="card-name">{p.name}</div>
            <div class="card-cat-tag">{catName}</div>
            {p.show_price && p.price ? (
              <>
                <div class="card-price">${Number(p.price).toLocaleString('es-CO')}</div>
                <div class="card-price-note">Al por mayor consultar precio</div>
              </>
            ) : (
              <div class="card-price" style="font-size:.82rem;font-weight:400;color:var(--muted);font-style:italic">Consultar precio</div>
            )}
            <div class="card-cta">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              Ver Detalles
            </div>
          </div>
        </a>
      );
    })}
    {products.length === 0 && (
      <div class="empty">
        <strong>No hay productos aún</strong>
        <p>Entra al <a href="/admin" style="color:var(--red);text-decoration:underline">panel de administración</a> para agregar productos.</p>
      </div>
    )}
  </div>
</div>
</main>

<script type="application/json" id="subcatsData" set:html={JSON.stringify(subCategoriesByParent)}></script>

<script is:inline>
// === FILTRADO AVANZADO ===
const searchInput = document.getElementById('searchInput');
const toggleFiltersBtn = document.getElementById('toggleFiltersBtn');
const collapsibleFilters = document.getElementById('collapsibleFilters');
const subcatsWrapper = document.getElementById('subcatsWrapper');
const subcatsPills = document.getElementById('subcatsPills');
const filterCountBadge = document.getElementById('filterCountBadge');
const cards = document.querySelectorAll('.card');
const sectionCount = document.getElementById('sectionCount');
const subcatsData = JSON.parse(document.getElementById('subcatsData').textContent || '{}');

let currentCat = 'todas';
let currentSubcat = '';

// Toggle TODO el panel (categorías + subcategorías + filtros)
toggleFiltersBtn.addEventListener('click', () => {
  collapsibleFilters.classList.toggle('hidden');
  toggleFiltersBtn.classList.toggle('active-toggle', !collapsibleFilters.classList.contains('hidden'));
});

// Click en pill principal
document.querySelectorAll('.main-pills .pill').forEach(pill => {
  pill.addEventListener('click', () => {
    document.querySelectorAll('.main-pills .pill').forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    currentCat = pill.dataset.cat || 'todas';
    currentSubcat = '';
    renderSubcategories(pill.dataset.catId);
    filterProducts();
  });
});

function renderSubcategories(parentId) {
  const subs = parentId ? (subcatsData[parentId] || []) : [];
  if (subs.length === 0) {
    subcatsWrapper.style.display = 'none';
    subcatsPills.innerHTML = '';
    return;
  }
  subcatsWrapper.style.display = 'block';
  subcatsPills.innerHTML = '<button class="pill subcat-pill active" type="button" data-subcat="">Todas las subcategorías</button>' +
    subs.map(s => `<button class="pill subcat-pill" type="button" data-subcat="${s.slug}">${s.name}</button>`).join('');

  subcatsPills.querySelectorAll('.subcat-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      subcatsPills.querySelectorAll('.subcat-pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      currentSubcat = pill.dataset.subcat || '';
      filterProducts();
    });
  });
}

// Search input
searchInput?.addEventListener('input', filterProducts);

// Filtros checkbox
document.querySelectorAll('[data-filter]').forEach(inp => {
  inp.addEventListener('change', () => { updateFilterBadge(); filterProducts(); });
});

// Filtros precio
document.getElementById('priceMin')?.addEventListener('input', filterProducts);
document.getElementById('priceMax')?.addEventListener('input', filterProducts);

// Limpiar filtros
document.getElementById('filterClearBtn')?.addEventListener('click', () => {
  document.querySelectorAll('[data-filter]').forEach(inp => inp.checked = false);
  const min = document.getElementById('priceMin'); if (min) min.value = '';
  const max = document.getElementById('priceMax'); if (max) max.value = '';
  updateFilterBadge();
  filterProducts();
});

function updateFilterBadge() {
  let count = 0;
  document.querySelectorAll('[data-filter]:checked').forEach(() => count++);
  if (document.getElementById('priceMin')?.value) count++;
  if (document.getElementById('priceMax')?.value) count++;
  if (count > 0) {
    filterCountBadge.textContent = count;
    filterCountBadge.style.display = 'inline-flex';
  } else {
    filterCountBadge.style.display = 'none';
  }
}

function filterProducts() {
  const q = searchInput?.value.toLowerCase().trim() || '';
  const selectedBrands = Array.from(document.querySelectorAll('[data-filter="brand"]:checked')).map(i => i.value);
  const selectedGenders = Array.from(document.querySelectorAll('[data-filter="gender"]:checked')).map(i => i.value);
  const onlyWithPrice = document.querySelector('[data-filter="hasPrice"]:checked') !== null;
  const onlyFeatured = document.querySelector('[data-filter="featured"]:checked') !== null;
  const priceMin = parseFloat(document.getElementById('priceMin')?.value) || 0;
  const priceMax = parseFloat(document.getElementById('priceMax')?.value) || Infinity;

  let count = 0;
  cards.forEach(card => {
    const cats = (card.dataset.cat || '').split(',').filter(Boolean);
    const name = card.dataset.name || '';
    const brand = card.dataset.brand || '';
    const brandSlug = card.dataset.brandSlug || '';
    const gender = card.dataset.gender || '';
    const price = parseFloat(card.dataset.price) || 0;
    const hasPrice = card.dataset.hasPrice === 'true';
    const featured = card.dataset.featured === 'true';

    const matchCat = currentCat === 'todas' || cats.includes(currentCat) || (currentSubcat && cats.includes(currentSubcat));
    const matchSubcat = !currentSubcat || cats.includes(currentSubcat);
    const matchSearch = !q || name.includes(q) || brand.includes(q);
    const matchBrand = selectedBrands.length === 0 || selectedBrands.includes(brandSlug);
    const matchGender = selectedGenders.length === 0 || selectedGenders.includes(gender);
    const matchPriceMin = !onlyWithPrice || hasPrice;
    const matchPriceRange = !hasPrice ? (priceMin === 0 && priceMax === Infinity) : (price >= priceMin && price <= priceMax);
    const matchFeatured = !onlyFeatured || featured;

    const show = matchCat && matchSubcat && matchSearch && matchBrand && matchGender && matchPriceMin && matchPriceRange && matchFeatured;
    card.style.display = show ? '' : 'none';
    if (show) count++;
  });
  sectionCount.textContent = `${count} producto${count !== 1 ? 's' : ''}`;
}
</script>
</Layout>
