---
import Layout from '../layouts/Layout.astro';
import { getProducts, getCategories, getBrands, getSiteSetting } from '../lib/supabase';
import type { Product, Category, Brand } from '../lib/supabase';

// Datos en build time
const products: Product[] = await getProducts();
const categories: Category[] = await getCategories();
const brands: Brand[] = await getBrands();
const homeIntro = await getSiteSetting('home_intro');

// Categorías principales y subcategorías
const parentCats = categories.filter(c => !c.parent_id);
const subcatsByParent: Record<string, Category[]> = {};
categories.filter(c => c.parent_id).forEach(c => {
  if (!subcatsByParent[c.parent_id!]) subcatsByParent[c.parent_id!] = [];
  subcatsByParent[c.parent_id!].push(c);
});

// Etiquetas de género legibles
const GENDER_LABELS: Record<string, string> = {
  hombre: 'Hombre', mujer: 'Mujer', unisex: 'Unisex', nino: 'Niño', nina: 'Niña'
};

// Recolectar géneros presentes en los productos
const gendersInUse = [...new Set(products.flatMap(p => {
  const g = (p.genders && p.genders.length) ? p.genders : (p.gender ? [p.gender] : []);
  return g;
}).filter(Boolean))];

// Construir datos de cada producto para render + búsqueda + filtros
function productData(p: Product) {
  const brandName = p.brands?.name || '';
  // Categorías: usa product_categories (múltiples) con fallback a la principal
  const cats = (p.product_categories && p.product_categories.length)
    ? p.product_categories.map(pc => pc.categories).filter(Boolean) as Category[]
    : (p.categories ? [p.categories as Category] : []);
  const primaryCat = (p.product_categories?.find(pc => pc.is_primary)?.categories as Category)
    || cats[0] || null;
  const catNames = cats.map(c => c.name).join(', ');
  const catSlugs = cats.map(c => c.slug);

  const primaryImg = p.product_images?.find(i => i.is_primary) || p.product_images?.[0];

  const variants = (p.product_variants || []).filter(v => v.active);

  // Colores únicos para las bolitas (diferenciando por nombre de color)
  const colors = [...new Set(variants.map(v => v.color))].map(cname => {
    const v = variants.find(x => x.color === cname);
    return { name: cname, hex: v?.color_hex || '#999', hex2: v?.color_hex_2 || null };
  }).filter(c => c.name && c.name !== 'Único');

  const productGenders = (p.genders && p.genders.length) ? p.genders : (p.gender ? [p.gender] : []);

  return {
    id: p.id, slug: p.slug, name: p.name, brandName,
    brandId: p.brand_id, catNames, catSlugs, primaryCat,
    primaryImg, colors, featured: p.featured,
    price: p.price, showPrice: p.show_price,
    genders: productGenders,
    catName: primaryCat?.name || '',
  };
}
const items = products.map(productData);

// Intro con **negrita** -> <strong>
const introHtml = homeIntro
  ? homeIntro.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
  : '';

const pageTitle = 'Procalzado | Botas de Caucho, Trabajo, Moto y más en Colombia';
const pageDesc = 'Compra botas de caucho, botas de lluvia, botas de moto, botas de trabajo, sandalias y zapatos industriales en Colombia. Procalzado: distribuidor autorizado. Venta al detal y al por mayor con envíos a todo el país.';
---

<Layout title={pageTitle} description={pageDesc}>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <span class="hero-tag">Distribuidores Autorizados</span>
      <h1>Calzado que <span class="accent">trabaja</span> contigo</h1>
      <p class="hero-sub">Botas de caucho, de moto, de trabajo, sandalias y calzado industrial. Venta al detal y al por mayor con envíos a todo el país.</p>
      <div class="hero-stats">
        <div class="stat"><div class="stat-num">{products.length}+</div><div class="stat-label">Productos</div></div>
        <div class="stat"><div class="stat-num">{brands.length}</div><div class="stat-label">Marcas</div></div>
        <div class="stat"><div class="stat-num">100%</div><div class="stat-label">Originales</div></div>
      </div>
    </div>
    <div class="hero-badge">
      <svg width="150" height="150" viewBox="0 0 1080 1080" xmlns="http://www.w3.org/2000/svg">
        <rect fill="#fff" x="0" y="0" width="1080" height="1080" rx="540" ry="540"/>
        <path fill="red" d="M938.98,465.16c-1.92-31.68-33.56-58.61-94.11-80.09-74.68-26.49-185.71-41.68-304.61-41.68-146.23,0-279.43,23.17-347.62,60.46-32.12,17.57-49.26,37.9-51.03,60.48-5.53,2.9-9.31,8.68-9.31,15.36v131.55c0,32.01,30.39,59.29,90.34,81.1,49.24,17.91,115.6,31.1,191.91,38.14.53.05,1.07.07,1.59.07,1.51,0,2.99-.22,4.42-.6,5.38,4.3,11.99,6.66,18.98,6.66h100.21c121.67,0,235.26-15.18,311.66-41.64,63.91-22.14,96.31-50.14,96.31-83.22v-131.54c0-6.44-3.52-12.05-8.73-15.04ZM200.95,419.07c63.34-34.64,191.5-58.34,339.3-58.34,121.06,0,228.93,15.9,298.82,40.69,51.74,18.35,82.66,41.58,82.66,66.84s-29.75,47.59-79.7,65.77c-.98-.36-1.97-.71-2.96-1.07-69.88-24.79-177.76-40.69-298.82-40.69s-232,16.35-301.78,41.75c-.88-.32-1.76-.64-2.62-.96-48.37-18.02-77.08-40.47-77.08-64.81,0-17.72,15.23-34.45,42.18-49.19ZM518.7,570.35h-78.73c-.36,0-.71.04-1.06.05-2.83-2.86-6.64-4.74-10.87-5.09-57.24-4.79-110.2-13.38-153.36-24.71,69.67-19.82,164.19-30.98,265.58-30.98s196.49,11.25,266.29,31.19c-50.64,13.45-114.4,22.92-183.73,27.11-.54.03-1.08.05-1.62.05-5.69,0-11.18-1.76-15.88-5.09l-40.74-28.88c-5.18-3.68-11.28-5.62-17.63-5.62-9.87,0-19.18,4.81-24.89,12.86-6.23,8.8-7.14,19.79-3.36,29.12ZM415,706.75c0,2.27.41,4.44,1.12,6.46-75.41-6.95-140.57-20.07-187.57-37.17-49.53-18.02-78.93-40.47-78.93-64.81v-131.54c0,24.34,29.4,46.79,78.93,64.81l2.69.96c48.98,17.41,116.95,30.57,195.36,37.12-6.82,3.02-11.59,9.84-11.59,17.78s4.72,14.69,11.49,17.73c-6.77,3.04-11.49,9.83-11.49,17.73s4.72,14.69,11.49,17.73c-6.77,3.04-11.49,9.83-11.49,17.73s4.72,14.69,11.49,17.73c-6.77,3.04-11.49,9.83-11.49,17.73ZM930.38,611.75c0,25.26-31.66,48.49-84.65,66.84-71.56,24.79-182.02,40.69-305.98,40.69h-100.21c-7.35,0-13.29-6.02-13.15-13.4.13-7.24,6.35-12.91,13.59-12.91h73.58c2.42,0,4.38-1.96,4.38-4.38h0c0-2.42-1.96-4.38-4.38-4.38h-74.02c-7.35,0-13.29-6.02-13.15-13.4.13-7.24,6.35-12.91,13.59-12.91h73.56c2.51,0,4.53-2.1,4.39-4.64-.12-2.38-2.26-4.16-4.64-4.16h-73.31c-7.24,0-13.46-5.67-13.59-12.91-.14-7.38,5.81-13.4,13.15-13.4l73.7.26c2.73,0,4.89-2.47,4.32-5.3-.41-2.06-2.31-3.49-4.41-3.5l-73.62-.26c-7.35,0-13.29-6.02-13.15-13.4.13-7.24,6.35-12.91,13.59-12.91h99.77v.04c4.27,0,8.53-.02,12.77-.06,3.81-.04,5.34-4.94,2.23-7.14l-15.42-10.93c-5.93-4.2-7.32-12.41-3.12-18.34,4.2-5.93,12.41-7.32,18.34-3.12l40.74,28.88c8.32,5.9,18.4,8.82,28.58,8.21,89.2-5.39,166.98-19.17,221.87-38.18,1.02-.35,2.03-.71,3.03-1.07,51.15-18.18,81.61-41,81.61-65.77v131.54Z"/>
      </svg>
    </div>
  </div>
</section>

<!-- BARRA DE FILTROS -->
<div class="filter-bar">
  <div class="filter-inner">
    <div class="filter-top-row">
      <div class="search-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="searchInput" placeholder="Buscar producto o marca..." autocomplete="off"/>
        <button type="button" class="search-clear" id="searchClear" style="display:none" aria-label="Limpiar">&times;</button>
        <div class="search-suggestions" id="searchSuggestions"></div>
      </div>
      <button type="button" class="toggle-cats-btn" id="toggleFilters">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
        <span class="toggle-label">Filtros</span>
        <span class="filter-count-badge" id="filterCountBadge" style="display:none">0</span>
      </button>
    </div>

    <!-- PANEL COLAPSABLE (modal fullscreen) -->
    <div class="collapsible-filters hidden" id="collapsibleFilters">
      <div class="filters-modal-header">
        <h3>Filtros</h3>
        <button type="button" class="filters-close-btn" id="filtersCloseBtn" aria-label="Cerrar">&times;</button>
      </div>

      {parentCats.length > 0 && (
        <>
          <div class="filter-section-title">Categorías</div>
          <div class="pills" id="catPills">
            <button type="button" class="pill active" data-cat="">Todas</button>
            {parentCats.map(c => (
              <button type="button" class="pill" data-cat={c.slug}>{c.name}</button>
            ))}
          </div>
          <div class="subcats-wrapper pills" id="subcatPills" style="display:none"></div>
        </>
      )}

      <div class="filters-panel">
        {brands.length > 0 && (
          <div class="filter-group">
            <div class="filter-group-title">Marca</div>
            <div class="filter-options">
              {brands.map(b => (
                <label class="filter-check"><input type="checkbox" class="f-brand" value={b.id}/> {b.name}</label>
              ))}
            </div>
          </div>
        )}

        {gendersInUse.length > 0 && (
          <div class="filter-group">
            <div class="filter-group-title">Género</div>
            <div class="filter-options">
              {gendersInUse.map(g => (
                <label class="filter-check"><input type="checkbox" class="f-gender" value={g}/> {GENDER_LABELS[g] || g}</label>
              ))}
            </div>
          </div>
        )}

        <div class="filter-group">
          <div class="filter-group-title">Precio (COP)</div>
          <div class="filter-price">
            <input type="number" id="priceMin" placeholder="Mínimo" min="0"/>
            <input type="number" id="priceMax" placeholder="Máximo" min="0"/>
          </div>
        </div>

        <div class="filter-group">
          <div class="filter-group-title">Otros</div>
          <div class="filter-options">
            <label class="filter-check"><input type="checkbox" id="fFeatured"/> Solo destacados</label>
            <label class="filter-check"><input type="checkbox" id="fHasPrice"/> Con precio visible</label>
          </div>
        </div>
      </div>

      <button type="button" class="filter-clear" id="filterClear">Limpiar filtros</button>
      <button type="button" class="filter-apply" id="filterApply">Ver resultados</button>
    </div>
  </div>
</div>

<!-- PRODUCTOS -->
<main class="products-section" id="main-content">
  {introHtml && (
    <div style="margin-bottom:1.5rem;font-size:.92rem;line-height:1.6;color:var(--muted)" set:html={introHtml}></div>
  )}
  <div class="section-header">
    <h2 class="section-title">Todos los <span class="red">productos</span></h2>
    <span class="section-count" id="resultCount">{items.length} productos</span>
  </div>

  <div class="product-grid" id="productGrid">
    {items.map((it, i) => {
      const dataAttrs = {
        'data-name': it.name.toLowerCase(),
        'data-brand-name': it.brandName.toLowerCase(),
        'data-brand-id': it.brandId || '',
        'data-cats': it.catSlugs.join('|'),
        'data-genders': it.genders.join('|'),
        'data-price': (it.showPrice && it.price) ? it.price : '',
        'data-featured': it.featured ? '1' : '0',
      };
      return (
        <a href={`/productos/${it.slug}`} class="card" style={`animation-delay:${Math.min(i * 0.03, 0.4)}s`} {...dataAttrs}>
          <div class="card-top-bar"></div>
          {it.featured && (
            <span class="card-badge-featured">
              <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              Destacado
            </span>
          )}
          <div class="card-img">
            {it.primaryImg
              ? <img src={it.primaryImg.url} alt={`${it.brandName} ${it.name}`} width="240" height="240" loading={i < 8 ? 'eager' : 'lazy'}/>
              : <span>👢</span>}
          </div>
          <div class="card-body">
            {it.brandName && <div class="card-brand">{it.brandName}</div>}
            <div class="card-name">{it.name}</div>
            {it.catName && <div class="card-cat-tag">{it.catName}</div>}

            {it.colors.length > 0 && (
              <div class="card-colors">
                {it.colors.slice(0, 6).map(c => {
                  const bg = c.hex2
                    ? `linear-gradient(135deg, ${c.hex} 0%, ${c.hex} 50%, ${c.hex2} 50%, ${c.hex2} 100%)`
                    : c.hex;
                  return <span class="card-color-dot" style={`background:${bg}`} title={c.name}></span>;
                })}
                {it.colors.length > 6 && <span class="card-color-more">+{it.colors.length - 6}</span>}
              </div>
            )}

            {it.showPrice && it.price ? (
              <>
                <div class="card-price">${Number(it.price).toLocaleString('es-CO')}</div>
                <div class="card-price-note">Al por mayor consultar precio</div>
              </>
            ) : (
              <div class="card-price-note" style="margin-top:auto">Precio a consultar</div>
            )}

            <div class="card-cta">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              Ver detalles
            </div>
          </div>
        </a>
      );
    })}
  </div>

  <div class="empty" id="emptyState" style="display:none">
    <strong>Sin resultados</strong>
    <p>No encontramos productos con esos filtros. Prueba con otros.</p>
  </div>
</main>

<!-- Datos de subcategorías para JS -->
<script type="application/json" id="subcatsData" set:html={JSON.stringify(subcatsByParent)}></script>
<script type="application/json" id="catsMeta" set:html={JSON.stringify(parentCats.map(c => ({ id: c.id, slug: c.slug, name: c.name })))}></script>

<style>
/* Bolitas de color en las tarjetas */
.card-colors{display:flex;align-items:center;gap:.32rem;flex-wrap:wrap;margin-bottom:.7rem}
.card-color-dot{width:16px;height:16px;border-radius:50%;border:1.5px solid var(--white);box-shadow:0 0 0 1px var(--grey2);flex-shrink:0}
.card-color-more{font-size:.68rem;font-weight:600;color:var(--muted);margin-left:.1rem}
@media(max-width:640px){
  .card-color-dot{width:14px;height:14px}
}
</style>

<script is:inline>
(function () {
  const grid = document.getElementById('productGrid');
  if (!grid) return;
  const cards = Array.from(grid.querySelectorAll('.card'));
  const resultCount = document.getElementById('resultCount');
  const emptyState = document.getElementById('emptyState');

  // Estado de filtros
  let activeCat = '';
  let activeSubcat = '';
  const selectedBrands = new Set();
  const selectedGenders = new Set();

  const subcatsData = JSON.parse(document.getElementById('subcatsData')?.textContent || '{}');
  const catsMeta = JSON.parse(document.getElementById('catsMeta')?.textContent || '[]');

  // ── BÚSQUEDA + SUGERENCIAS ──
  const searchInput = document.getElementById('searchInput');
  const searchClear = document.getElementById('searchClear');
  const suggestions = document.getElementById('searchSuggestions');

  // Construir índice de búsqueda desde las tarjetas
  const searchIndex = cards.map(card => ({
    el: card,
    name: card.dataset.name || '',
    brand: card.dataset.brandName || '',
    href: card.getAttribute('href'),
    img: card.querySelector('.card-img img')?.src || '',
    displayName: card.querySelector('.card-name')?.textContent || '',
    displayBrand: card.querySelector('.card-brand')?.textContent || '',
    price: card.querySelector('.card-price')?.textContent || '',
  }));

  function highlight(text, q) {
    if (!q) return text;
    const idx = text.toLowerCase().indexOf(q.toLowerCase());
    if (idx < 0) return text;
    return text.slice(0, idx) + '<mark>' + text.slice(idx, idx + q.length) + '</mark>' + text.slice(idx + q.length);
  }

  function renderSuggestions(q) {
    if (!q || q.length < 1) { suggestions.classList.remove('show'); return; }
    const matches = searchIndex.filter(it =>
      it.name.includes(q.toLowerCase()) || it.brand.includes(q.toLowerCase())
    ).slice(0, 7);

    if (matches.length === 0) {
      suggestions.innerHTML = '<div class="suggestion-empty">Sin coincidencias para "' + q + '"</div>';
      suggestions.classList.add('show');
      return;
    }

    suggestions.innerHTML = matches.map(m => `
      <a href="${m.href}" class="suggestion-item">
        ${m.img ? `<img src="${m.img}" alt="" width="40" height="40"/>` : '<div class="suggestion-noimg">👢</div>'}
        <div class="suggestion-info">
          ${m.displayBrand ? `<div class="suggestion-brand">${m.displayBrand}</div>` : ''}
          <div class="suggestion-name">${highlight(m.displayName, q)}</div>
        </div>
        ${m.price ? `<div class="suggestion-price">${m.price}</div>` : ''}
      </a>
    `).join('');
    suggestions.classList.add('show');
  }

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.trim();
      searchClear.style.display = q ? 'flex' : 'none';
      renderSuggestions(q);
      applyFilters();
    });
    searchInput.addEventListener('focus', () => {
      const q = searchInput.value.trim();
      if (q) renderSuggestions(q);
    });
  }
  if (searchClear) {
    searchClear.addEventListener('click', () => {
      searchInput.value = '';
      searchClear.style.display = 'none';
      suggestions.classList.remove('show');
      applyFilters();
      searchInput.focus();
    });
  }
  // Cerrar sugerencias al hacer click fuera
  document.addEventListener('click', e => {
    if (!e.target.closest('.search-wrap')) suggestions.classList.remove('show');
  });

  // ── FILTROS: abrir/cerrar modal ──
  const toggleBtn = document.getElementById('toggleFilters');
  const panel = document.getElementById('collapsibleFilters');
  const closeBtn = document.getElementById('filtersCloseBtn');
  const applyBtn = document.getElementById('filterApply');

  function openPanel() {
    panel.classList.remove('hidden');
    document.body.classList.add('filters-open');
  }
  function closePanel() {
    panel.classList.add('hidden');
    document.body.classList.remove('filters-open');
  }
  if (toggleBtn) toggleBtn.addEventListener('click', () => {
    panel.classList.contains('hidden') ? openPanel() : closePanel();
  });
  if (closeBtn) closeBtn.addEventListener('click', closePanel);
  if (applyBtn) applyBtn.addEventListener('click', closePanel);

  // ── CATEGORÍAS (pills) ──
  const catPills = document.getElementById('catPills');
  const subcatPills = document.getElementById('subcatPills');

  function renderSubcats(catSlug) {
    if (!subcatPills) return;
    const parent = catsMeta.find(c => c.slug === catSlug);
    const subs = parent ? (subcatsData[parent.id] || []) : [];
    if (subs.length === 0) {
      subcatPills.style.display = 'none';
      subcatPills.innerHTML = '';
      activeSubcat = '';
      return;
    }
    subcatPills.style.display = 'flex';
    subcatPills.innerHTML = subs.map(s =>
      `<button type="button" class="pill subcat-pill" data-subcat="${s.slug}">${s.name}</button>`
    ).join('');
    subcatPills.querySelectorAll('[data-subcat]').forEach(btn => {
      btn.addEventListener('click', () => {
        const wasActive = btn.classList.contains('active');
        subcatPills.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
        if (!wasActive) { btn.classList.add('active'); activeSubcat = btn.dataset.subcat; }
        else { activeSubcat = ''; }
        applyFilters();
      });
    });
  }

  if (catPills) {
    catPills.querySelectorAll('[data-cat]').forEach(btn => {
      btn.addEventListener('click', () => {
        catPills.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        activeCat = btn.dataset.cat;
        activeSubcat = '';
        renderSubcats(activeCat);
        applyFilters();
      });
    });
  }

  // ── CHECKBOXES marca/género ──
  document.querySelectorAll('.f-brand').forEach(cb => cb.addEventListener('change', () => {
    cb.checked ? selectedBrands.add(cb.value) : selectedBrands.delete(cb.value);
    applyFilters();
  }));
  document.querySelectorAll('.f-gender').forEach(cb => cb.addEventListener('change', () => {
    cb.checked ? selectedGenders.add(cb.value) : selectedGenders.delete(cb.value);
    applyFilters();
  }));

  // ── PRECIO + OTROS ──
  const priceMin = document.getElementById('priceMin');
  const priceMax = document.getElementById('priceMax');
  const fFeatured = document.getElementById('fFeatured');
  const fHasPrice = document.getElementById('fHasPrice');
  [priceMin, priceMax].forEach(el => el && el.addEventListener('input', applyFilters));
  [fFeatured, fHasPrice].forEach(el => el && el.addEventListener('change', applyFilters));

  // ── LIMPIAR ──
  document.getElementById('filterClear')?.addEventListener('click', () => {
    activeCat = ''; activeSubcat = '';
    selectedBrands.clear(); selectedGenders.clear();
    catPills?.querySelectorAll('.pill').forEach((p, i) => p.classList.toggle('active', i === 0));
    if (subcatPills) { subcatPills.style.display = 'none'; subcatPills.innerHTML = ''; }
    document.querySelectorAll('.f-brand, .f-gender').forEach(cb => cb.checked = false);
    if (priceMin) priceMin.value = '';
    if (priceMax) priceMax.value = '';
    if (fFeatured) fFeatured.checked = false;
    if (fHasPrice) fHasPrice.checked = false;
    applyFilters();
  });

  // ── APLICAR FILTROS ──
  function applyFilters() {
    const q = (searchInput?.value || '').trim().toLowerCase();
    const min = parseFloat(priceMin?.value) || 0;
    const max = parseFloat(priceMax?.value) || Infinity;
    const onlyFeatured = fFeatured?.checked;
    const onlyPriced = fHasPrice?.checked;

    let visible = 0;
    let activeFilterCount = 0;
    if (activeCat) activeFilterCount++;
    if (activeSubcat) activeFilterCount++;
    activeFilterCount += selectedBrands.size + selectedGenders.size;
    if (priceMin?.value || priceMax?.value) activeFilterCount++;
    if (onlyFeatured) activeFilterCount++;
    if (onlyPriced) activeFilterCount++;

    cards.forEach(card => {
      const name = card.dataset.name || '';
      const brand = card.dataset.brandName || '';
      const brandId = card.dataset.brandId || '';
      const cats = (card.dataset.cats || '').split('|').filter(Boolean);
      const genders = (card.dataset.genders || '').split('|').filter(Boolean);
      const priceStr = card.dataset.price;
      const price = priceStr ? parseFloat(priceStr) : null;
      const featured = card.dataset.featured === '1';

      let show = true;
      if (q && !name.includes(q) && !brand.includes(q)) show = false;
      if (show && activeCat && !cats.includes(activeCat)) show = false;
      if (show && activeSubcat && !cats.includes(activeSubcat)) show = false;
      if (show && selectedBrands.size && !selectedBrands.has(brandId)) show = false;
      if (show && selectedGenders.size && !genders.some(g => selectedGenders.has(g))) show = false;
      if (show && onlyFeatured && !featured) show = false;
      if (show && onlyPriced && price === null) show = false;
      if (show && (priceMin?.value || priceMax?.value)) {
        if (price === null) show = false;
        else if (price < min || price > max) show = false;
      }

      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (resultCount) resultCount.textContent = visible + (visible === 1 ? ' producto' : ' productos');
    if (emptyState) emptyState.style.display = visible === 0 ? 'block' : 'none';

    const badge = document.getElementById('filterCountBadge');
    if (badge) {
      badge.textContent = activeFilterCount;
      badge.style.display = activeFilterCount > 0 ? 'inline-flex' : 'none';
    }
    toggleBtn?.classList.toggle('active-toggle', activeFilterCount > 0);
  }

  // ── Aplicar filtro de categoría desde URL (?cat=slug) ──
  const urlParams = new URLSearchParams(window.location.search);
  const urlCat = urlParams.get('cat');
  if (urlCat && catPills) {
    const btn = catPills.querySelector(`[data-cat="${urlCat}"]`);
    if (btn) {
      catPills.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      activeCat = urlCat;
      renderSubcats(activeCat);
    } else {
      // Puede ser una subcategoría
      const parentMeta = catsMeta.find(c => (subcatsData[c.id] || []).some(s => s.slug === urlCat));
      if (parentMeta) {
        const pbtn = catPills.querySelector(`[data-cat="${parentMeta.slug}"]`);
        if (pbtn) {
          catPills.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
          pbtn.classList.add('active');
          activeCat = parentMeta.slug;
          renderSubcats(activeCat);
          setTimeout(() => {
            const sbtn = subcatPills?.querySelector(`[data-subcat="${urlCat}"]`);
            if (sbtn) { sbtn.classList.add('active'); activeSubcat = urlCat; applyFilters(); }
          }, 0);
        }
      }
    }
  }

  applyFilters();
})();
</script>

</Layout>
