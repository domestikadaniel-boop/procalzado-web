---
import Layout from '../layouts/Layout.astro';
import { getProducts, getCategories, getBrands, getSiteSetting } from '../lib/supabase';

const products = await getProducts();
const categories = await getCategories();
const brands = await getBrands();
const homeIntroRaw = await getSiteSetting('home_intro');

const homeIntroHtml = (homeIntroRaw || 'Catálogo completo de **botas de caucho**, **botas de lluvia**, **botas de moto**, **botas de trabajo**, sandalias, zuecos y zapatos de lona. Venta al detal y al por mayor en toda Colombia.')
  .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

const mainCategories = categories.filter(c => !c.parent_id);
const subCategoriesByParent: Record<string, typeof categories> = {};
categories.filter(c => c.parent_id).forEach(c => {
  if (!subCategoriesByParent[c.parent_id!]) subCategoriesByParent[c.parent_id!] = [];
  subCategoriesByParent[c.parent_id!].push(c);
});

const brandsInUse = brands.filter(b => products.some(p => p.brands?.id === b.id));

const allGenderValues = products.flatMap(p => {
  const arr = (p as any).genders as string[] | null;
  if (arr && arr.length > 0) return arr;
  return p.gender ? [p.gender] : [];
});
const gendersInUse = [...new Set(allGenderValues)];
const genderLabels: Record<string, string> = {
  'nino': 'Niño', 'nina': 'Niña', 'hombre': 'Hombre', 'mujer': 'Mujer', 'unisex': 'Unisex'
};

const productPrices = products.filter(p => p.show_price && p.price).map(p => Number(p.price));
const minPrice = productPrices.length ? Math.floor(Math.min(...productPrices)) : 0;
const maxPrice = productPrices.length ? Math.ceil(Math.max(...productPrices)) : 0;

const totalProducts = products.length;
---

<Layout title="Procalzado | Botas de Caucho, Botas de Lluvia y Calzado Industrial en Colombia">

<main id="main-content" class="catalog-wrap">
  <div class="catalog-topbar">
    <div class="search-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="searchInput" placeholder="Buscar producto o marca…" autocomplete="off"/>
      <button type="button" class="search-clear" id="searchClear" style="display:none" aria-label="Limpiar">&times;</button>
      <div class="search-suggestions" id="searchSuggestions"></div>
    </div>
    <button class="mobile-filter-btn" id="mobileFilterBtn" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
      <span>Filtros</span>
      <span class="filter-count-badge" id="filterCountBadge" style="display:none">0</span>
    </button>
  </div>

  <div class="catalog-grid">
    <aside class="catalog-sidebar" id="catalogSidebar">
      <div class="sidebar-header">
        <h3>Filtros</h3>
        <button class="sidebar-close" id="sidebarClose" type="button" aria-label="Cerrar">&times;</button>
      </div>

      <div class="active-filters" id="activeFilters" style="display:none"></div>

      <details class="filter-section" open>
        <summary><span>Categorías</span><svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></summary>
        <div class="filter-body">
          <button class="cat-item active" type="button" data-cat="todas">Todas</button>
          {mainCategories.map(cat => (
            <div class="cat-group">
              <button class="cat-item" type="button" data-cat={cat.slug} data-cat-id={cat.id}>{cat.name}</button>
              {subCategoriesByParent[cat.id] && (
                <div class="subcat-list" data-parent={cat.id} style="display:none">
                  {subCategoriesByParent[cat.id].map(sub => (
                    <button class="subcat-item" type="button" data-subcat={sub.slug}>{sub.name}</button>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </details>

      {brandsInUse.length > 0 && (
        <details class="filter-section" open>
          <summary><span>Marca</span><svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></summary>
          <div class="filter-body">
            {brandsInUse.length > 8 && (
              <div class="filter-search-mini">
                <input type="text" id="brandSearchInput" placeholder="Buscar marca…"/>
              </div>
            )}
            <div class="filter-list scroll" id="brandList">
              {brandsInUse.map(b => (
                <label class="filter-check">
                  <input type="checkbox" data-filter="brand" value={b.slug}/>
                  <span>{b.name}</span>
                </label>
              ))}
            </div>
          </div>
        </details>
      )}

      {gendersInUse.length > 0 && (
        <details class="filter-section" open>
          <summary><span>Género</span><svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></summary>
          <div class="filter-body">
            <div class="filter-list">
              {gendersInUse.map(g => (
                <label class="filter-check">
                  <input type="checkbox" data-filter="gender" value={g}/>
                  <span>{genderLabels[g] || g}</span>
                </label>
              ))}
            </div>
          </div>
        </details>
      )}

      {productPrices.length > 0 && (
        <details class="filter-section" open>
          <summary><span>Precio</span><svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></summary>
          <div class="filter-body">
            <div class="price-inputs">
              <input type="number" id="priceMin" placeholder={`$${minPrice.toLocaleString('es-CO')}`} min={minPrice} max={maxPrice}/>
              <span>—</span>
              <input type="number" id="priceMax" placeholder={`$${maxPrice.toLocaleString('es-CO')}`} min={minPrice} max={maxPrice}/>
            </div>
            <small class="price-range-label" id="priceRangeLabel">Rango: ${minPrice.toLocaleString('es-CO')} - ${maxPrice.toLocaleString('es-CO')}</small>
          </div>
        </details>
      )}

      <details class="filter-section">
        <summary><span>Otros</span><svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></summary>
        <div class="filter-body">
          <div class="filter-list">
            <label class="filter-check"><input type="checkbox" data-filter="hasPrice" value="true"/><span>Solo con precio visible</span></label>
            <label class="filter-check"><input type="checkbox" data-filter="featured" value="true"/><span>Destacados</span></label>
          </div>
        </div>
      </details>

      <div class="sidebar-footer">
        <button class="btn-clear-all" id="filterClearBtn" type="button">Limpiar filtros</button>
        <button class="btn-apply-mobile" id="filterApplyBtn" type="button">Ver resultados</button>
      </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <section class="catalog-main">
      <header class="catalog-header">
        <h2 class="catalog-title">CATÁLOGO <span class="cat-current" id="currentCatTitle">Todos los productos</span></h2>
        <span class="catalog-count" id="sectionCount">{totalProducts} productos</span>
      </header>

      <p class="catalog-intro" set:html={homeIntroHtml}></p>

      <div class="product-grid" id="productGrid">
        {products.map((p, i) => {
          const primaryImg = p.product_images?.find(img => img.is_primary) || p.product_images?.[0];
          const brandName = p.brands?.name || '';
          const brandSlug = p.brands?.slug || '';
          const productCats = p.product_categories?.length
            ? p.product_categories.map(pc => pc.categories).filter(Boolean)
            : (p.categories ? [p.categories] : []);
          const catSlugs = productCats.map(c => c?.slug).filter(Boolean).join(',');
          const primaryCat = p.product_categories?.find(pc => pc.is_primary)?.categories || p.categories;
          const catName = primaryCat?.name || '';
          const productGenders = ((p as any).genders && (p as any).genders.length > 0)
            ? (p as any).genders : (p.gender ? [p.gender] : []);
          const genderSlugs = productGenders.join(',');
          return (
            <a href={`/productos/${p.slug}`} class="card" style={`animation-delay:${i * 30}ms`}
              data-cat={catSlugs} data-name={p.name.toLowerCase()} data-brand={brandName.toLowerCase()}
              data-brand-slug={brandSlug} data-gender={genderSlugs}
              data-price={p.show_price && p.price ? p.price : ''}
              data-has-price={p.show_price && p.price ? 'true' : 'false'}
              data-featured={p.featured ? 'true' : 'false'}>
              <div class="card-top-bar"></div>
              {p.featured && (
                <div class="card-badge-featured">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  Destacado
                </div>
              )}
              <div class="card-img">
                {primaryImg ? (
                  <img src={primaryImg.url} alt={`${brandName} ${p.name} - ${catName}`} loading="lazy" width="210" height="210"/>
                ) : (<span>👢</span>)}
              </div>
              <div class="card-info">
                {brandName && <div class="card-brand">{brandName}</div>}
                <h3 class="card-name">{p.name}</h3>
                {p.show_price && p.price ? (
                  <div class="card-price">${Number(p.price).toLocaleString('es-CO')}</div>
                ) : (
                  <div class="card-price-na">Consultar precio</div>
                )}
              </div>
            </a>
          );
        })}
      </div>

      <div class="no-results" id="noResults" style="display:none">
        <h3>No se encontraron productos</h3>
        <p>Intenta ajustar o limpiar los filtros</p>
        <button type="button" class="btn-clear-all" onclick="document.getElementById('filterClearBtn').click()">Limpiar filtros</button>
      </div>
    </section>
  </div>
</main>

<script type="application/json" id="subcatsData" set:html={JSON.stringify(subCategoriesByParent)}></script>
<script type="application/json" id="productsData" set:html={JSON.stringify(products.map(p => {
  const primaryImg = p.product_images?.find(img => img.is_primary) || p.product_images?.[0];
  return { slug: p.slug, name: p.name, brand: p.brands?.name || '',
    img: primaryImg?.url || '',
    price: p.show_price && p.price ? Number(p.price) : null };
}))}></script>

<script is:inline>
const $ = id => document.getElementById(id);
const searchInput = $('searchInput');
const sidebar = $('catalogSidebar');
const sidebarOverlay = $('sidebarOverlay');
const mobileFilterBtn = $('mobileFilterBtn');
const filterCountBadge = $('filterCountBadge');
const cards = document.querySelectorAll('.card');
const sectionCount = $('sectionCount');
const currentCatTitle = $('currentCatTitle');
const noResults = $('noResults');
const activeFilters = $('activeFilters');
const subcatsData = JSON.parse($('subcatsData').textContent || '{}');
const allProducts = JSON.parse($('productsData').textContent || '[]');

let currentCat = 'todas';
let currentCatName = 'Todos los productos';
let currentSubcat = '';
let currentSubcatName = '';

function openSidebar() {
  sidebar.classList.add('open');
  sidebarOverlay.classList.add('show');
  document.body.classList.add('no-scroll');
}
function closeSidebar() {
  sidebar.classList.remove('open');
  sidebarOverlay.classList.remove('show');
  document.body.classList.remove('no-scroll');
}
mobileFilterBtn.addEventListener('click', openSidebar);
$('sidebarClose').addEventListener('click', closeSidebar);
sidebarOverlay.addEventListener('click', closeSidebar);
$('filterApplyBtn').addEventListener('click', () => {
  closeSidebar();
  document.querySelector('.catalog-main').scrollIntoView({behavior: 'smooth', block: 'start'});
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSidebar(); });

document.querySelectorAll('.cat-item').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.cat-item').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.subcat-item').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentCat = btn.dataset.cat || 'todas';
    currentCatName = btn.textContent.trim();
    currentSubcat = '';
    currentSubcatName = '';
    document.querySelectorAll('.subcat-list').forEach(list => {
      list.style.display = list.dataset.parent === btn.dataset.catId ? '' : 'none';
    });
    filterProducts();
  });
});

document.querySelectorAll('.subcat-item').forEach(btn => {
  btn.addEventListener('click', e => {
    e.stopPropagation();
    document.querySelectorAll('.subcat-item').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentSubcat = btn.dataset.subcat || '';
    currentSubcatName = btn.textContent.trim();
    filterProducts();
  });
});

$('brandSearchInput')?.addEventListener('input', e => {
  const q = e.target.value.toLowerCase().trim();
  document.querySelectorAll('#brandList .filter-check').forEach(label => {
    const text = label.textContent.toLowerCase();
    label.style.display = !q || text.includes(q) ? '' : 'none';
  });
});

document.querySelectorAll('[data-filter]').forEach(inp => {
  inp.addEventListener('change', () => { updateFilterBadge(); filterProducts(); });
});
$('priceMin')?.addEventListener('input', filterProducts);
$('priceMax')?.addEventListener('input', filterProducts);

$('filterClearBtn').addEventListener('click', () => {
  document.querySelectorAll('[data-filter]').forEach(inp => inp.checked = false);
  const min = $('priceMin'); if (min) min.value = '';
  const max = $('priceMax'); if (max) max.value = '';
  document.querySelectorAll('.cat-item, .subcat-item').forEach(b => b.classList.remove('active'));
  document.querySelector('.cat-item[data-cat="todas"]')?.classList.add('active');
  document.querySelectorAll('.subcat-list').forEach(l => l.style.display = 'none');
  currentCat = 'todas'; currentSubcat = '';
  currentCatName = 'Todos los productos'; currentSubcatName = '';
  if (searchInput) searchInput.value = '';
  $('searchClear').style.display = 'none';
  updateFilterBadge();
  filterProducts();
});

function updateFilterBadge() {
  let count = 0;
  document.querySelectorAll('[data-filter]:checked').forEach(() => count++);
  if ($('priceMin')?.value) count++;
  if ($('priceMax')?.value) count++;
  filterCountBadge.textContent = count;
  filterCountBadge.style.display = count > 0 ? 'inline-flex' : 'none';
}

function renderActiveFilters() {
  const chips = [];
  if (currentCat !== 'todas') chips.push({type: 'cat', label: currentCatName});
  if (currentSubcat) chips.push({type: 'subcat', label: currentSubcatName});
  document.querySelectorAll('[data-filter="brand"]:checked').forEach(i => {
    const label = i.closest('label').querySelector('span').textContent;
    chips.push({type: 'brand', label: label, value: i.value});
  });
  document.querySelectorAll('[data-filter="gender"]:checked').forEach(i => {
    const label = i.closest('label').querySelector('span').textContent;
    chips.push({type: 'gender', label: label, value: i.value});
  });
  if ($('priceMin')?.value || $('priceMax')?.value) {
    const min = $('priceMin').value || '?';
    const max = $('priceMax').value || '?';
    chips.push({type: 'price', label: `$${min} — $${max}`});
  }
  if (document.querySelector('[data-filter="featured"]:checked')) chips.push({type: 'featured', label: 'Destacados', value: 'true'});
  if (document.querySelector('[data-filter="hasPrice"]:checked')) chips.push({type: 'hasPrice', label: 'Con precio', value: 'true'});

  if (chips.length === 0) {
    activeFilters.style.display = 'none';
    activeFilters.innerHTML = '';
    return;
  }
  activeFilters.style.display = 'flex';
  activeFilters.innerHTML = chips.map(c => `<button type="button" class="chip" data-type="${c.type}" data-value="${c.value || ''}">${c.label} <span>×</span></button>`).join('');
  activeFilters.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const type = chip.dataset.type;
      const value = chip.dataset.value;
      if (type === 'cat') { document.querySelector('.cat-item[data-cat="todas"]').click(); }
      else if (type === 'subcat') { currentSubcat = ''; currentSubcatName = ''; document.querySelectorAll('.subcat-item').forEach(b => b.classList.remove('active')); filterProducts(); }
      else if (type === 'price') { $('priceMin').value = ''; $('priceMax').value = ''; updateFilterBadge(); filterProducts(); }
      else {
        const inp = document.querySelector(`[data-filter="${type}"][value="${value}"]`);
        if (inp) { inp.checked = false; updateFilterBadge(); filterProducts(); }
      }
    });
  });
}

function filterProducts() {
  const q = searchInput?.value.toLowerCase().trim() || '';
  const selectedBrands = Array.from(document.querySelectorAll('[data-filter="brand"]:checked')).map(i => i.value);
  const selectedGenders = Array.from(document.querySelectorAll('[data-filter="gender"]:checked')).map(i => i.value);
  const onlyWithPrice = document.querySelector('[data-filter="hasPrice"]:checked') !== null;
  const onlyFeatured = document.querySelector('[data-filter="featured"]:checked') !== null;
  const priceMin = parseFloat($('priceMin')?.value) || 0;
  const priceMax = parseFloat($('priceMax')?.value) || Infinity;

  let count = 0;
  let visiblePrices = [];

  cards.forEach(card => {
    const cats = (card.dataset.cat || '').split(',').filter(Boolean);
    const name = card.dataset.name || '';
    const brand = card.dataset.brand || '';
    const brandSlug = card.dataset.brandSlug || '';
    const productGenders = (card.dataset.gender || '').split(',').filter(Boolean);
    const price = parseFloat(card.dataset.price) || 0;
    const hasPrice = card.dataset.hasPrice === 'true';
    const featured = card.dataset.featured === 'true';

    const matchCat = currentCat === 'todas' || cats.includes(currentCat) || (currentSubcat && cats.includes(currentSubcat));
    const matchSubcat = !currentSubcat || cats.includes(currentSubcat);
    const matchSearch = !q || name.includes(q) || brand.includes(q);
    const matchBrand = selectedBrands.length === 0 || selectedBrands.includes(brandSlug);
    const matchGender = selectedGenders.length === 0 || selectedGenders.some(g => productGenders.includes(g));
    const matchFeatured = !onlyFeatured || featured;
    const matchAllExceptPrice = matchCat && matchSubcat && matchSearch && matchBrand && matchGender && matchFeatured;

    if (matchAllExceptPrice && hasPrice) visiblePrices.push(price);

    const matchHasPrice = !onlyWithPrice || hasPrice;
    const matchPriceRange = !hasPrice ? (priceMin === 0 && priceMax === Infinity) : (price >= priceMin && price <= priceMax);
    const show = matchAllExceptPrice && matchHasPrice && matchPriceRange;
    card.style.display = show ? '' : 'none';
    if (show) count++;
  });

  if (visiblePrices.length > 0) {
    const dynMin = Math.floor(Math.min(...visiblePrices));
    const dynMax = Math.ceil(Math.max(...visiblePrices));
    const rangeLabel = $('priceRangeLabel');
    if (rangeLabel) rangeLabel.textContent = `Rango: $${dynMin.toLocaleString('es-CO')} - $${dynMax.toLocaleString('es-CO')}`;
  }

  sectionCount.textContent = `${count} producto${count !== 1 ? 's' : ''}`;
  currentCatTitle.textContent = currentSubcatName || currentCatName;

  noResults.style.display = count === 0 ? 'flex' : 'none';
  document.querySelector('.product-grid').style.display = count === 0 ? 'none' : '';

  renderActiveFilters();
}

const searchSuggestions = $('searchSuggestions');
const searchClear = $('searchClear');

function renderSuggestions(query) {
  const q = query.toLowerCase().trim();
  if (q.length < 1) {
    searchSuggestions.classList.remove('show');
    searchSuggestions.innerHTML = '';
    return;
  }
  const matches = allProducts.filter(p =>
    p.name.toLowerCase().includes(q) || p.brand.toLowerCase().includes(q)
  ).slice(0, 6);

  if (matches.length === 0) {
    searchSuggestions.innerHTML = `<div class="suggestion-empty">Sin resultados para "${query}"</div>`;
    searchSuggestions.classList.add('show');
    return;
  }

  const highlight = (text) => {
    const regex = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return text.replace(regex, '<mark>$1</mark>');
  };

  searchSuggestions.innerHTML = matches.map(p => `
    <a href="/productos/${p.slug}" class="suggestion-item">
      ${p.img ? `<img src="${p.img}" alt="${p.name}" width="40" height="40"/>` : '<div class="suggestion-noimg">👢</div>'}
      <div class="suggestion-info">
        ${p.brand ? `<div class="suggestion-brand">${highlight(p.brand)}</div>` : ''}
        <div class="suggestion-name">${highlight(p.name)}</div>
      </div>
      ${p.price ? `<div class="suggestion-price">$${p.price.toLocaleString('es-CO')}</div>` : ''}
    </a>
  `).join('');
  searchSuggestions.classList.add('show');
}

searchInput.addEventListener('input', () => {
  searchClear.style.display = searchInput.value ? 'flex' : 'none';
  renderSuggestions(searchInput.value);
  filterProducts();
});
searchInput.addEventListener('focus', () => {
  if (searchInput.value) renderSuggestions(searchInput.value);
});
searchClear.addEventListener('click', () => {
  searchInput.value = '';
  searchClear.style.display = 'none';
  searchSuggestions.classList.remove('show');
  filterProducts();
  searchInput.focus();
});
document.addEventListener('click', e => {
  if (!searchInput.contains(e.target) && !searchSuggestions.contains(e.target)) {
    searchSuggestions.classList.remove('show');
  }
});
searchInput.addEventListener('keydown', e => {
  const items = searchSuggestions.querySelectorAll('.suggestion-item');
  if (items.length === 0) return;
  const current = searchSuggestions.querySelector('.suggestion-item.active');
  let nextIdx = -1;
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    nextIdx = current ? Array.from(items).indexOf(current) + 1 : 0;
    if (nextIdx >= items.length) nextIdx = 0;
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    nextIdx = current ? Array.from(items).indexOf(current) - 1 : items.length - 1;
    if (nextIdx < 0) nextIdx = items.length - 1;
  } else if (e.key === 'Enter' && current) {
    e.preventDefault();
    window.location.href = current.getAttribute('href');
    return;
  } else if (e.key === 'Escape') {
    searchSuggestions.classList.remove('show');
    return;
  } else return;
  items.forEach(i => i.classList.remove('active'));
  items[nextIdx].classList.add('active');
  items[nextIdx].scrollIntoView({block: 'nearest'});
});

filterProducts();
</script>

<style>
/* ═══ CATÁLOGO PROFESIONAL ═══ */
.catalog-wrap { max-width: 1400px; margin: 0 auto; padding: 1rem; }

.catalog-topbar {
  display: flex; gap: .8rem; align-items: center;
  padding: 1rem; background: var(--white); border-radius: 10px;
  box-shadow: 0 2px 8px rgba(0,0,0,.04); margin-bottom: 1.2rem;
}
.search-wrap { flex: 1; position: relative; }
.search-wrap svg { position: absolute; left: .85rem; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--muted); pointer-events: none; z-index: 2; }
.search-wrap input { width: 100%; padding: .75rem 2.4rem; border: 2px solid var(--grey2); border-radius: 8px; font-family: var(--fb); font-size: .9rem; outline: none; transition: border-color .18s; }
.search-wrap input:focus { border-color: var(--red); }
.search-clear { position: absolute; right: .6rem; top: 50%; transform: translateY(-50%); background: var(--grey2); color: var(--muted); border: none; width: 22px; height: 22px; border-radius: 50%; cursor: pointer; font-size: .95rem; display: flex; align-items: center; justify-content: center; padding: 0; z-index: 3; }
.search-clear:hover { background: var(--red); color: var(--white); }

