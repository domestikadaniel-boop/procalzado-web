# ══════════════════════════════════════
# SUPABASE — Copia este archivo como .env
# ══════════════════════════════════════
# 1. Copia este archivo:  copy .env.example .env
# 2. Reemplaza los valores con los tuyos de Supabase

PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ══════════════════════════════════════
# WOMPI — desde comercios.wompi.co > Desarrollo > Programadores
# ══════════════════════════════════════
WOMPI_PUBLIC_KEY=pub_test_xxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxx

# ══════════════════════════════════════
# TELEGRAM — notificaciones de venta
# ══════════════════════════════════════
TELEGRAM_BOT_TOKEN=tu-token-aqui
TELEGRAM_CHAT_ID=tu-chat-id-aqui

# ══════════════════════════════════════
# RESEND — para enviar la factura por correo
# ══════════════════════════════════════
RESEND_API_KEY=re_xxxxx

